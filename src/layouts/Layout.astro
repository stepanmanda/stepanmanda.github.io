---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
    title: string;
    description: string;
    active?: 'firmy' | 'jednotlivci' | 'o-nas' | 'pristup' | 'pripadove-studie' | 'kontakt' | null;
    primaryCta?: { label: string; href: string } | null | false;
    footerTagline?: string;
    footerVariant?: string;
}

const {
    title,
    description,
    active = null,
    primaryCta = { label: 'Zažádat o konzultaci', href: '/firmy' },
    footerTagline = 'The Velocity Operating System.',
    footerVariant = 'v0.2 preview',
} = Astro.props;
---

<!doctype html>
<html lang="cs">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.svg" />
    <meta name="theme-color" content="#0B0F19" />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="VELYOS" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="cs_CZ" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/og-image.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Fraunces:ital,wght@1,400;1,500&display=swap" />
</head>
<body>
    <div class="preview-ribbon">PREVIEW</div>

    <Header active={active} primaryCta={primaryCta} />

    <slot />

    <Footer tagline={footerTagline} variant={footerVariant} />

    <script is:inline src="/scripts/main.js" defer></script>

    <!-- ElevenLabs ConvAI — globálně plující widget (floating v rohu) -->
    <elevenlabs-convai agent-id="cu9gllbBtpZWU6CuJXky"></elevenlabs-convai>
    <script is:inline src="https://unpkg.com/@elevenlabs/convai-widget-embed" async type="text/javascript"></script>
</body>
</html>
