---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { LANGS, route, type Lang, type RouteKey } from '../i18n/ui';

interface Props {
    title: string;
    description: string;
    lang?: Lang;
    active?: RouteKey | null;
    primaryCta?: { label: string; href: string } | null | false;
    footerTagline?: string;
    footerVariant?: string;
}

const {
    title,
    description,
    lang = 'cs',
    active = null,
    primaryCta,
    footerTagline = 'The Velocity Partner.',
    footerVariant = 'v0.3 preview',
} = Astro.props;

// hreflang pairs pro aktuální route (pokud existuje)
const hreflangs = active
    ? LANGS.map((l) => ({
          lang: l === 'cs' ? 'cs-CZ' : l === 'en' ? 'en-US' : 'de-DE',
          href: new URL(route(active, l), Astro.site ?? 'https://stepanmanda.github.io').toString(),
      }))
    : [];

const xDefault = active
    ? new URL(route(active, 'cs'), Astro.site ?? 'https://stepanmanda.github.io').toString()
    : null;
---

<!doctype html>
<html lang={lang === 'cs' ? 'cs' : lang === 'en' ? 'en' : 'de'}>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Mark document as JS-enabled + first-load before CSS parses — prevents hero flicker on refresh.
         `.first-load` is removed by main.js after initial init, so view-transition navs skip the stagger. -->
    <!-- Theme bootstrap — musí běžet PŘED parsováním CSS, aby nedošlo k flash dark→light. -->
    <script is:inline>
        document.documentElement.classList.add('js');
        document.documentElement.classList.add('first-load');
        (function () {
            try {
                var stored = localStorage.getItem('velyos-theme');
                var theme;
                if (stored === 'dark' || stored === 'light') {
                    theme = stored;
                } else {
                    theme = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
                }
                document.documentElement.setAttribute('data-theme', theme);
            } catch (e) {
                document.documentElement.setAttribute('data-theme', 'light');
            }
        })();
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.svg" />
    <meta name="theme-color" content="#0B0F19" />

    <!-- hreflang (multi-language) -->
    {hreflangs.map((h) => (
        <link rel="alternate" hreflang={h.lang} href={h.href} />
    ))}
    {xDefault && <link rel="alternate" hreflang="x-default" href={xDefault} />}

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="VELYOS" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={lang === 'cs' ? 'cs_CZ' : lang === 'en' ? 'en_US' : 'de_DE'} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/og-image.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Fraunces:ital,wght@1,400;1,500&display=swap" />

    <!-- Astro View Transitions — SPA-like přechody mezi stránkami -->
    <ClientRouter fallback="swap" />
</head>
<body>
    <div class="scroll-progress" transition:persist aria-hidden="true"></div>

    <Header lang={lang} active={active} primaryCta={primaryCta} />

    <slot />

    <Footer lang={lang} tagline={footerTagline} variant={footerVariant} />

    <script is:inline src="/scripts/main.js" defer></script>

    <!-- Theme toggle — delegovaný klik handler na document, přežije ClientRouter swap. -->
    <script is:inline>
        (function () {
            function syncPressed() {
                var btn = document.getElementById('theme-toggle');
                if (!btn) return;
                var current = document.documentElement.getAttribute('data-theme') || 'light';
                btn.setAttribute('aria-pressed', current === 'dark' ? 'true' : 'false');
            }
            document.addEventListener('click', function (e) {
                var btn = e.target && e.target.closest && e.target.closest('#theme-toggle');
                if (!btn) return;
                var current = document.documentElement.getAttribute('data-theme') || 'light';
                var next = current === 'dark' ? 'light' : 'dark';
                document.documentElement.setAttribute('data-theme', next);
                try { localStorage.setItem('velyos-theme', next); } catch (err) {}
                btn.setAttribute('aria-pressed', next === 'dark' ? 'true' : 'false');
            });
            document.addEventListener('astro:page-load', syncPressed);
            syncPressed();
        })();
    </script>

    <!-- ElevenLabs ConvAI — globálně plující widget (floating v rohu) -->
    <elevenlabs-convai agent-id="cu9gllbBtpZWU6CuJXky" transition:persist></elevenlabs-convai>
    <script is:inline src="https://unpkg.com/@elevenlabs/convai-widget-embed" async type="text/javascript"></script>
</body>
</html>
