---
import Layout from '../layouts/Layout.astro';
import DiagnosticSwitcher from '../components/DiagnosticSwitcher.astro';
import DiagnosticForm from '../components/DiagnosticForm.astro';
---

<Layout
    title="VELYOS — Diagnostika"
    description="Spusťte diagnostiku — písemně nebo hlasem. Do 24 hodin se ozveme s konkrétním návrhem. Bez obchodníka, bez závazku."
    active="diagnostika"
    primaryCta={null}
    footerTagline="Brief. Ne prezentace."
>

    <!-- Sekce 1 — Hero (lightweight, ne sticky, ne time element) -->
    <section class="diag-hero">
        <div class="diag-hero__glow" aria-hidden="true"></div>
        <div class="container">
            <div class="diag-hero__inner">
                <div class="diag-hero__tagline italic-serif">„Tady se to začíná dít."</div>
                <h1 class="diag-hero__title">Spustíme diagnostiku. Zbytek dohodneme spolu.</h1>
                <p class="diag-hero__lead">
                    Žádný obchodník. Žádná prezentace. Vyberte cestu, která Vám sedí.
                    Do 24 hodin se ozveme s konkrétním návrhem.
                </p>
            </div>
        </div>
    </section>

    <!-- Sekce 2 — State switcher (klíčová sekce) -->
    <section class="diag-section">
        <div class="container container--narrow">
            <div class="diag-switcher-head">
                <span class="eyebrow">· Vyberte cestu</span>
                <h2>Jak Vám to bude pohodlnější?</h2>
                <p class="diag-switcher-head__lead">Obě cesty vedou ke stejnému závěru. Záleží jen na Vás.</p>
            </div>

            <DiagnosticSwitcher
                written={{
                    eyebrow: 'PÍSEMNÁ',
                    title: '10 otázek. Odpovězte ve svém tempu.',
                    cta: 'Vyplnit',
                }}
                voice={{
                    eyebrow: 'HLASOVÁ',
                    title: '10–15 minut s naším agentem. Mluvte jako s kolegou.',
                    cta: 'Začít hovor',
                }}
            >
                <!-- 3-column reasons pod buttons (state A) -->
                <div slot="reasons" class="diag-reasons">
                    <div>
                        <span class="eyebrow">· Do 24 hodin ·</span>
                        <p>Ozveme se s konkrétním návrhem a cenou.</p>
                    </div>
                    <div>
                        <span class="eyebrow">· Bez obchodníka ·</span>
                        <p>Nikdo Vám nebude volat z prodeje.</p>
                    </div>
                    <div>
                        <span class="eyebrow">· Bez závazku ·</span>
                        <p>Pokud nejsme to, co hledáte, řekneme to rovnou.</p>
                    </div>
                </div>

                <!-- State B: písemná -->
                <div slot="written-content">
                    <header class="diag-state-head">
                        <span class="eyebrow">· Písemná diagnostika</span>
                        <h2>10 otázek. Pět minut.</h2>
                        <p>Odpovídejte ve svém tempu. Ozveme se do 24 hodin na e-mail.</p>
                    </header>
                    <DiagnosticForm lang="cs" />
                </div>

                <!-- State C: hlasová -->
                <div slot="voice-content">
                    <header class="diag-state-head">
                        <span class="eyebrow">· Hlasová diagnostika</span>
                        <h2>Promluvte si s naším agentem. 10–15 minut.</h2>
                        <p>
                            Agent provede stejný rozhovor jako specialista.
                            Pak Vám odešle shrnutí na e-mail.
                        </p>
                    </header>

                    <ol class="diag-voice-steps">
                        <li>
                            <span class="diag-voice-steps__num">01</span>
                            <span class="diag-voice-steps__label">KLIKNĚTE</span>
                            <span class="diag-voice-steps__body">Na oranžovou kontrolku vpravo dole. Widget se rozbalí.</span>
                        </li>
                        <li>
                            <span class="diag-voice-steps__num">02</span>
                            <span class="diag-voice-steps__label">POVÍDEJTE</span>
                            <span class="diag-voice-steps__body">Agent se ptá. Vy odpovídáte. Mluvte přirozeně, jako s kolegou přes telefon.</span>
                        </li>
                        <li>
                            <span class="diag-voice-steps__num">03</span>
                            <span class="diag-voice-steps__label">SHRNUTÍ E-MAILEM</span>
                            <span class="diag-voice-steps__body">Do hodiny dostanete brief, do 24 hodin se ozveme s návrhem.</span>
                        </li>
                    </ol>

                    <p class="diag-voice-note">
                        Hlasová verze je experimentální. Pokud něco nesedí, klikněte na
                        <em>Zpět k výběru</em> a zkuste písemnou.
                    </p>
                </div>
            </DiagnosticSwitcher>
        </div>
    </section>

</Layout>

<style>
    /* Hero — lightweight, ne sticky scroll */
    .diag-hero {
        position: relative;
        padding: var(--space-20) 0 var(--space-12);
        overflow: hidden;
        text-align: center;
        border-bottom: 1px solid var(--border-soft);
    }

    .diag-hero__glow {
        position: absolute;
        top: -250px;
        left: 50%;
        transform: translateX(-50%);
        width: 900px;
        height: 600px;
        background:
            radial-gradient(ellipse at center, rgba(232, 93, 31, 0.18), transparent 60%),
            radial-gradient(ellipse at center, rgba(184, 147, 92, 0.12), transparent 70%);
        pointer-events: none;
        filter: blur(50px);
    }

    [data-theme="dark"] .diag-hero__glow {
        background:
            radial-gradient(ellipse at center, rgba(232, 93, 31, 0.28), transparent 60%),
            radial-gradient(ellipse at center, rgba(184, 147, 92, 0.18), transparent 70%);
    }

    .diag-hero .container { position: relative; z-index: 1; }

    .diag-hero__inner {
        max-width: 60ch;
        margin: 0 auto;
    }

    .diag-hero__tagline {
        color: var(--signal-gold);
        font-size: clamp(1rem, 1.4vw, 1.2rem);
        margin-bottom: var(--space-4);
    }

    .diag-hero__title {
        font-size: clamp(2rem, 4vw, 3.2rem);
        letter-spacing: -0.04em;
        line-height: 1.1;
        font-weight: 700;
        margin: 0 0 var(--space-6);
        color: var(--text-primary);
    }

    .diag-hero__lead {
        font-size: 1.15rem;
        line-height: 1.55;
        color: var(--text-secondary);
        margin: 0;
    }

    /* Switcher section */
    .diag-section {
        padding: var(--space-16) 0 var(--space-24);
    }

    .diag-switcher-head {
        text-align: center;
        margin-bottom: var(--space-12);
    }

    .diag-switcher-head .eyebrow {
        display: block;
        margin-bottom: var(--space-3);
        color: var(--signal-gold);
    }

    .diag-switcher-head h2 {
        font-size: clamp(1.6rem, 3vw, 2.2rem);
        letter-spacing: -0.02em;
        margin: 0 0 var(--space-3);
        line-height: 1.2;
        color: var(--text-primary);
    }

    .diag-switcher-head__lead {
        color: var(--text-secondary);
        font-size: 1.05rem;
        max-width: 48ch;
        margin: 0 auto;
    }

    /* Reasons (3-column pod big buttons) */
    .diag-reasons {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: var(--space-8);
        text-align: center;
    }

    .diag-reasons .eyebrow {
        display: block;
        margin-bottom: var(--space-3);
        color: var(--signal-gold);
    }

    .diag-reasons p {
        margin: 0;
        font-size: 0.95rem;
        color: var(--text-secondary);
        line-height: 1.5;
    }

    @media (max-width: 720px) {
        .diag-reasons { grid-template-columns: 1fr; gap: var(--space-6); }
    }

    /* State header (společný pro B + C) */
    .diag-state-head {
        text-align: left;
        margin-bottom: var(--space-8);
    }

    .diag-state-head .eyebrow {
        display: block;
        margin-bottom: var(--space-3);
        color: var(--accent);
    }

    .diag-state-head h2 {
        font-size: clamp(1.6rem, 3vw, 2.2rem);
        letter-spacing: -0.02em;
        margin: 0 0 var(--space-3);
        line-height: 1.2;
        color: var(--text-primary);
    }

    .diag-state-head p {
        color: var(--text-secondary);
        font-size: 1.05rem;
        max-width: 60ch;
        margin: 0;
    }

    /* Voice steps */
    .diag-voice-steps {
        list-style: none;
        margin: var(--space-8) 0;
        padding: 0;
    }

    .diag-voice-steps li {
        display: grid;
        grid-template-columns: auto 14rem 1fr;
        gap: var(--space-4);
        align-items: baseline;
        padding: var(--space-4) 0;
        border-bottom: 1px solid var(--border-soft);
    }

    .diag-voice-steps li:first-child {
        border-top: 1px solid var(--border-soft);
    }

    .diag-voice-steps__num {
        font-family: var(--font-mono);
        font-size: 0.78rem;
        color: var(--text-muted);
        font-weight: 500;
    }

    .diag-voice-steps__label {
        font-family: var(--font-mono);
        font-size: 0.92rem;
        letter-spacing: 0.06em;
        color: var(--text-primary);
        font-weight: 600;
    }

    .diag-voice-steps__body {
        color: var(--text-secondary);
        font-size: 0.98rem;
        line-height: 1.5;
    }

    @media (max-width: 720px) {
        .diag-voice-steps li {
            grid-template-columns: 1fr;
            gap: var(--space-1);
            padding: var(--space-3) 0;
        }
    }

    .diag-voice-note {
        margin: var(--space-10) 0 0;
        padding: var(--space-4) var(--space-6);
        border: 1px solid var(--border-soft);
        border-left: 3px solid var(--signal-gold);
        border-radius: var(--radius);
        background: var(--surface-subtle);
        font-size: 0.95rem;
        color: var(--text-secondary);
        line-height: 1.55;
    }

    .diag-voice-note em {
        font-family: var(--font-mono);
        font-style: normal;
        font-size: 0.85rem;
        letter-spacing: 0.04em;
        color: var(--text-primary);
    }
</style>
