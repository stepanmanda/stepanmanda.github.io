---
import Layout from '../layouts/Layout.astro';
import HeroSticky from '../components/HeroSticky.astro';
import SectionHead from '../components/SectionHead.astro';
import Features from '../components/Features.astro';
import RevealCard from '../components/RevealCard.astro';
import Steps from '../components/Steps.astro';
import Step from '../components/Step.astro';
import CtaBand from '../components/CtaBand.astro';

const heroMeta = [
    { label: 'Nasazení', value: '4 týdny' },
    { label: 'Návratnost', value: '6 měsíců' },
    { label: 'Záruka', value: 'Ve smlouvě' },
    { label: 'Klientela', value: 'Omezený počet' },
];

const day = [
    {
        time: '07:00',
        label: 'RÁNO',
        teaser: 'Agent prošel přes noc 47 e-mailů. Pět vyžaduje Vás.',
        body: 'Standardní potvrzení a faq vyřídil bez Vás. Čtyři návrhy odpovědí leží v draftu — schválíte v MHD. Jeden e-mail označil jako urgentní a poslal SMS upozornění.',
    },
    {
        time: '12:00',
        label: 'OBĚD',
        teaser: 'Tři klientské hovory naplánované, brief připraven.',
        body: 'Agent přesunul jednu schůzku, která narážela na konflikt. Před každým hovorem máte v telefonu krátký brief: kdo volá, co řešíte, jaký je kontext z posledních e-mailů.',
    },
    {
        time: '15:00',
        label: 'ODPOLEDNE',
        teaser: 'Faktury vystavené, follow-upy odeslané.',
        body: 'Týdenní fakturace proběhla autonomně. Follow-up e-maily klientům, kteří se ozvali minulý týden, odešly s personalizovaným textem ve vašem stylu. Nezbylo nic na večer.',
    },
    {
        time: '19:00',
        label: 'VEČER',
        teaser: 'Telefon ticho. Agent pořád pracuje.',
        body: 'Hlasový agent přijímá hovory, třídí je, nabízí termíny. Klient dostane profesionální reakci, vy jste u večeře. Naléhavé případy jdou na Váš mobil — zbytek čeká do rána.',
    },
];
---

<Layout
    title="VELYOS — Pro jednotlivce"
    description="Osobní agent pro advokáty, doktory, konzultanty a realitní makléře. Převezme komunikaci, kalendář a rešerše. Den se najednou vejde."
    active="jednotlivci"
    primaryCta={{ label: 'Spustit diagnostiku', href: '/diagnostika' }}
    footerTagline="Pro ty, kteří už nemají čas na ztrátu času."
>

    <!-- Sekce 1 — Hero -->
    <HeroSticky tagline={`„Pro lidi, kteří dělají všechno sami."`} meta={heroMeta}>
        <h1 slot="heading">Váš den se nevejde do <em>24 hodin</em>. Zatím.</h1>

        <p slot="lead">
            Jeden mozek. E-mail, kalendář, telefon, klienti, daně. Agent převezme to,
            co se opakuje. Den se najednou vejde.
        </p>

        <Fragment slot="ctas">
            <a href="/diagnostika" class="btn btn--primary btn-arrow btn--lg">Spustit diagnostiku →</a>
            <a href="/firmy" class="btn btn--ghost btn-arrow btn--lg">Pro firmy</a>
        </Fragment>
    </HeroSticky>

    <!-- Sekce 2 — Pro koho je agent (3 reveal cards) -->
    <section>
        <div class="container">
            <SectionHead
                eyebrow="· 01 · PRO KOHO"
                title="Tři typy lidí, kterým to dává největší smysl."
            />
            <Features cols={3}>
                <RevealCard
                    num="01"
                    title="Advokát · Doktor · Konzultant"
                    body="Fakturační sazba je vysoká, ale polovinu dne netráví u klienta. Příprava, rešerše, administrativa — práce, která s odborností nesouvisí. Agent to převezme."
                />
                <RevealCard
                    num="02"
                    title="Realitní makléř"
                    body="V realitách vyhrává rychlost, ne kvalifikace. Lead přijde o víkendu, vy jste s rodinou — agent ho ohodnotí, doplní data z katastru a odpoví dřív, než konkurence zvedne telefon."
                />
                <RevealCard
                    num="03"
                    title="Majitel malé firmy bez týmu"
                    body="Dělali jste obchod, marketing, fakturaci, podporu. Najmout někoho je nákladné a dlouhé. Agent je zítra, stejně rychle, stejně konzistentně."
                />
            </Features>
        </div>
    </section>

    <!-- Sekce 3 — Co dělá agent (3 reveal cards) -->
    <section>
        <div class="container">
            <SectionHead
                eyebrow="· 02 · CO DĚLÁ"
                title="Vrátí Vám tři věci."
            />
            <Features cols={3}>
                <RevealCard
                    num="01"
                    title="KOMUNIKACE"
                    body="E-maily, chat, telefon. Agent odpovídá ve vašem stylu, třídí podle priority, filtruje žádosti o schůzku, navrhuje odpovědi na složitější zprávy. Vy schvalujete."
                />
                <RevealCard
                    num="02"
                    title="KALENDÁŘ"
                    body="Plánování, přesouvání, follow-up, briefing před schůzkou. Agent chrání Vaše soustředěné bloky a posílá připomínky — bez Vás, ale s vámi v centru."
                />
                <RevealCard
                    num="03"
                    title="REŠERŠE & ADMIN"
                    body="Hledá, shrnuje, fakturuje, vyřizuje rutinní administrativu. Půldenní práce je hotová, než dopijete ranní kávu."
                />
            </Features>
        </div>
    </section>

    <!-- Sekce 4 — Den s agentem (Timeline reveal) -->
    <section id="den">
        <div class="container container--narrow">
            <SectionHead
                eyebrow="· 03 · DEN"
                title="Jak vypadá běžný den, když agent pracuje s vámi."
                lead="Ilustrativní scénář. Konkrétní čísla u Vás budou jiná, princip zůstává."
            />

            <ol class="day-timeline">
                {day.map((d, i) => (
                    <li class="day-timeline__item">
                        <button class="day-timeline__btn" type="button" aria-expanded="false">
                            <span class="day-timeline__time">{d.time}</span>
                            <div class="day-timeline__content">
                                <span class="day-timeline__label">· {d.label}</span>
                                <span class="day-timeline__teaser">{d.teaser}</span>
                                <p class="day-timeline__body">{d.body}</p>
                            </div>
                            <span class="day-timeline__dot" aria-hidden="true"></span>
                            {i < day.length - 1 && <span class="day-timeline__line" aria-hidden="true"></span>}
                        </button>
                    </li>
                ))}
            </ol>
        </div>
    </section>

    <!-- Sekce 5 — Jak to děláme (3 kroky, sjednoceno) -->
    <section>
        <div class="container">
            <SectionHead
                eyebrow="· 04 · JAK TO DĚLÁME"
                title="Tři kroky. Žádné pilotní fáze."
                lead="Začínáme tím, že posloucháme. Končíme tím, že to běží."
            />
            <Steps cols={3}>
                <Step num="01" title="POSLOUCHÁME" body="Diagnostika. Pochopíme, co Vás brzdí." />
                <Step num="02" title="STAVÍME"     body="Návrh, integrace, nasazení. Do 4 týdnů." />
                <Step num="03" title="STARÁME SE"  body="Provoz, dohled, ladění. Dokud to dává smysl." />
            </Steps>
        </div>
    </section>

    <!-- Sekce 6 — Investice -->
    <section>
        <div class="container container--narrow">
            <SectionHead
                eyebrow="· 05 · INVESTICE"
                title="Fixní cena. Smluvně. Začneme do 4 týdnů."
            />
            <div class="invest-block">
                <p>
                    Pro jednotlivce balíček vychází nižší než pro firmy. Pokud chcete navíc web, značku
                    nebo LinkedIn strategii, řekneme rovnou. Co konkrétně potřebujete, zjistíme v diagnostice.
                </p>
                <p class="invest-block__cta">
                    <a href="/diagnostika">Spustit diagnostiku →</a>
                </p>
            </div>
        </div>
    </section>

    <!-- Sekce 7 — Final CTA -->
    <CtaBand
        id="zacit"
        eyebrow="· Začněme"
        title="Vystupte z kolečka. Tento týden."
        lead="Krátká diagnostika. Žádný obchodník. Žádná prezentace. Do 24 hodin víte, co Vám agent vrátí."
        directPrefix="Nebo napište přímo:"
    >
        <a href="/diagnostika" class="btn btn--primary btn-arrow btn--lg">Spustit diagnostiku →</a>
    </CtaBand>

</Layout>

<style>
    /* Sekce 6 — Investice */
    .invest-block { margin-top: var(--space-8); }

    .invest-block p {
        font-size: 1.05rem;
        line-height: 1.65;
        color: var(--text-secondary);
        margin: 0 0 var(--space-4);
        max-width: 60ch;
    }

    .invest-block__cta {
        margin-top: var(--space-6) !important;
        font-family: var(--font-mono);
        font-size: 0.85rem;
        letter-spacing: 0.04em;
    }

    .invest-block__cta a {
        color: var(--accent);
        border-bottom: 1px solid transparent;
        transition: border-color 0.2s ease;
    }

    .invest-block__cta a:hover { border-bottom-color: var(--accent); }

    /* Sekce 4 — Day timeline (4 body s reveal) */
    .day-timeline {
        list-style: none;
        margin: var(--space-12) 0 0;
        padding: 0;
    }

    .day-timeline__item {
        position: relative;
    }

    .day-timeline__btn {
        position: relative;
        width: 100%;
        text-align: left;
        background: transparent;
        border: 0;
        padding: var(--space-6) 0 var(--space-6) var(--space-16);
        display: block;
        font-family: inherit;
        color: inherit;
        cursor: pointer;
    }

    .day-timeline__time {
        position: absolute;
        left: 0;
        top: var(--space-6);
        font-family: var(--font-mono);
        font-size: 1.6rem;
        font-weight: 500;
        color: var(--text-primary);
        letter-spacing: -0.02em;
        font-feature-settings: "tnum";
    }

    .day-timeline__dot {
        position: absolute;
        left: 5.6rem;
        top: calc(var(--space-6) + 0.55rem);
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: var(--accent);
        box-shadow: 0 0 0 4px var(--bg);
        z-index: 2;
        transition: transform 0.25s ease;
    }

    .day-timeline__line {
        position: absolute;
        left: calc(5.6rem + 4.5px);
        top: calc(var(--space-6) + 1.2rem);
        bottom: calc(-1 * var(--space-6));
        width: 1px;
        background: var(--border-soft);
    }

    .day-timeline__content {
        padding-left: var(--space-8);
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
    }

    .day-timeline__label {
        font-family: var(--font-mono);
        font-size: 0.72rem;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--text-muted);
    }

    .day-timeline__teaser {
        font-size: 1.1rem;
        font-weight: 600;
        letter-spacing: -0.01em;
        color: var(--text-primary);
        line-height: 1.4;
    }

    .day-timeline__body {
        max-height: 0;
        overflow: hidden;
        opacity: 0;
        transform: translateY(-6px);
        margin: 0;
        font-size: 1rem;
        line-height: 1.6;
        color: var(--text-secondary);
        transition: max-height 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                    opacity 0.3s ease,
                    transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    @media (hover: hover) {
        .day-timeline__btn:hover .day-timeline__dot,
        .day-timeline__btn[aria-expanded="true"] .day-timeline__dot {
            transform: scale(1.4);
        }
        .day-timeline__btn:hover .day-timeline__body,
        .day-timeline__btn[aria-expanded="true"] .day-timeline__body {
            max-height: 200px;
            opacity: 1;
            transform: translateY(0);
            margin-top: var(--space-2);
        }
    }

    @media (hover: none) {
        .day-timeline__btn[aria-expanded="true"] .day-timeline__dot {
            transform: scale(1.4);
        }
        .day-timeline__btn[aria-expanded="true"] .day-timeline__body {
            max-height: 200px;
            opacity: 1;
            transform: translateY(0);
            margin-top: var(--space-2);
        }
    }

    @media (max-width: 640px) {
        .day-timeline__btn {
            padding-left: 0;
            padding-top: var(--space-3);
            padding-bottom: var(--space-3);
        }
        .day-timeline__time {
            position: relative;
            top: 0;
            font-size: 1.2rem;
            display: inline-block;
            margin-bottom: var(--space-2);
        }
        .day-timeline__dot,
        .day-timeline__line { display: none; }
        .day-timeline__content { padding-left: 0; }
    }

    @media (prefers-reduced-motion: reduce) {
        .day-timeline__body,
        .day-timeline__dot { transition: none !important; }
        .day-timeline__body {
            max-height: none;
            opacity: 1;
            transform: none;
            margin-top: var(--space-2);
        }
    }
</style>

<script>
    // Tap-to-expand pro day-timeline na non-hover zařízeních
    document.addEventListener('click', (e) => {
        const target = e.target;
        if (!target || !(target instanceof Element)) return;
        const btn = target.closest('.day-timeline__btn');
        if (!btn) return;
        const hoverable = window.matchMedia('(hover: hover)').matches;
        if (hoverable) return;
        const expanded = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', expanded ? 'false' : 'true');
    });
</script>
