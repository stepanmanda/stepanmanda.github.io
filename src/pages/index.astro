---
import Layout from '../layouts/Layout.astro';
import HeroSticky from '../components/HeroSticky.astro';
import SectionHead from '../components/SectionHead.astro';
import Features from '../components/Features.astro';
import RevealCard from '../components/RevealCard.astro';
import Steps from '../components/Steps.astro';
import Step from '../components/Step.astro';
import FounderStrip from '../components/FounderStrip.astro';
import CtaBand from '../components/CtaBand.astro';

const heroMeta = [
    { label: 'Nasazení', value: '4 týdny' },
    { label: 'Návratnost', value: '6 měsíců' },
    { label: 'Záruka', value: 'Ve smlouvě' },
    { label: 'Klientela', value: 'Omezený počet' },
];

const services = [
    { num: '01', title: 'WEB & ZNAČKA',         body: 'Stránky, které prodávají.' },
    { num: '02', title: 'AGENTI & ASISTENTI',   body: 'Hlas, chat, e-mail. 24/7.' },
    { num: '03', title: 'CRM & INTEGRACE',      body: 'HubSpot, Pipedrive, vlastní.' },
    { num: '04', title: 'PROPAGACE',            body: 'SEO, Google a LinkedIn.' },
    { num: '05', title: 'AUTOMATIZACE',         body: 'Slack, Notion, fakturace.' },
    { num: '06', title: 'DATA',                 body: 'Dashboard, co dává smysl.' },
];
---

<Layout
    title="VELYOS — The Velocity Partner."
    description="Stavíme automatizaci, která vrací firmám i profesionálům čas, peníze a klid. Nejsme software. Jsme tým, který to za vás postaví."
    lang="cs"
    active="home"
    primaryCta={{ label: 'Spustit diagnostiku', href: '/diagnostika' }}
>

    <!-- Sekce 1 — Hero -->
    <HeroSticky tagline={`„The Velocity Partner."`} meta={heroMeta}>
        <h1 slot="heading">Vracíme čas tam, kde má <em>nejvyšší hodnotu</em>.</h1>

        <p slot="lead">
            Stavíme automatizaci, která vrací firmám i profesionálům <strong>čas, peníze a klid</strong>.
            Nejsme software. Jsme tým, který to za vás postaví.
        </p>

        <Fragment slot="ctas">
            <a href="/firmy" class="btn btn--primary btn-arrow btn--lg">Chci řešení pro firmu →</a>
            <a href="/jednotlivci" class="btn btn--ghost btn-arrow btn--lg">Chci řešení pro jednotlivce →</a>
        </Fragment>
    </HeroSticky>

    <!-- Sekce 2 — Komu (3 reveal cards) -->
    <section>
        <div class="container">
            <SectionHead
                eyebrow="KOMU"
                title="Pro firmy s týmem. Pro profesionály bez něj."
                lead="Pokud si nejste jistí, kam patříte — zjistíme to společně v diagnostice."
            />
            <Features cols={3}>
                <RevealCard
                    num="01"
                    title="Firmy s týmem"
                    body="5–30 lidí, kdy administrativa pohlcuje obchodní čas. Zdravotnictví, účetní, řemeslo, růstově orientované služby."
                />
                <RevealCard
                    num="02"
                    title="Profesionálové"
                    body="Advokáti, doktoři, konzultanti, realitky. Jeden mozek a chaos kalendáře, e-mailů a klientských požadavků."
                />
                <RevealCard
                    num="03"
                    title="Ne pro každého"
                    body="Pokud potřebujete jednorázové řešení nebo hledáte freelancera za hodinovku, nejsme to my. Doporučíme dál."
                />
            </Features>
        </div>
    </section>

    <!-- Sekce 3 — Co děláme (řádky, žádné karty) -->
    <section class="home-services-section">
        <div class="container">
            <SectionHead
                eyebrow="CO DĚLÁME"
                title="Stavíme za vás. Od prvního logu po poslední tlačítko."
                lead="Web. Značka. Agenti. Integrace. Reklama. Data. Jeden partner. Jedna smlouva. Žádných pět agentur, které si přehazují odpovědnost."
            />

            <dl class="home-services">
                {services.map((s) => (
                    <div class="home-services__row">
                        <dt>
                            <span class="home-services__num">{s.num}</span>
                            <span class="home-services__label">{s.title}</span>
                        </dt>
                        <dd>{s.body}</dd>
                    </div>
                ))}
            </dl>

            <p class="home-services__more">
                <a href="/pristup">Více o našem přístupu →</a>
            </p>
        </div>
    </section>

    <!-- Sekce 4 — Jak to děláme (3 kroky, sjednocená metodika) -->
    <section>
        <div class="container">
            <SectionHead
                eyebrow="JAK TO DĚLÁME"
                title="Tři kroky. Žádné pilotní fáze."
                lead="Začínáme tím, že posloucháme. Končíme tím, že to běží."
            />
            <Steps cols={3}>
                <Step num="01" title="POSLOUCHÁME"  body="Diagnostika. Pochopíme, co vás brzdí." />
                <Step num="02" title="STAVÍME"      body="Návrh, integrace, nasazení. Do 4 týdnů." />
                <Step num="03" title="STARÁME SE"   body="Provoz, dohled, ladění. Dokud to dává smysl." />
            </Steps>
        </div>
    </section>

    <!-- Sekce 5 — Kdo jsme -->
    <div class="home-who" data-reveal>
        <FounderStrip lang="cs" variant="strip" href="/o-nas" />
    </div>

    <!-- Sekce 6 — Manifesto -->
    <section class="section--editorial">
        <div class="container container--narrow" data-reveal>
            <span class="eyebrow">Manifesto</span>
            <h2>Čas je jediné aktivum, které se nedá koupit zpátky.</h2>
            <div class="home-manifesto__body">
                <p>Většina firem ho spaluje v procesech, které měly být dávno automatizované. V hovorech, které nikdo neměl vést. V administrativě, která neměla existovat.</p>
                <p>VELYOS je partner, který vám firmu postaví, zapojí a udrží v chodu. Ne další software, který si musíte nastavit sami.</p>
            </div>
            <blockquote class="home-manifesto__quote italic-serif">
                „Nepracujeme pro každého. Pracujeme pro ty, kteří chápou, proč jsou u nás."
            </blockquote>
        </div>
    </section>

    <!-- Sekce 7 — Final CTA -->
    <CtaBand
        id="zacit"
        eyebrow="Začněme"
        title="Nevíte, kam patříte? Náš agent vám během pár minut pomůže."
        lead="Žádný obchodník. Žádná prezentace. Krátká diagnostika a víte, kam dál."
        directPrefix="Nebo napište přímo:"
    >
        <a href="/diagnostika" class="btn btn--primary btn-arrow btn--lg">Spustit diagnostiku →</a>
    </CtaBand>

</Layout>

<style>
    /* ============================================================
       Home — Fáze 3 redesign
       ============================================================ */

    /* Sekce 3 — Service list (řádky, ne karty) */
    .home-services-section {
        padding-bottom: var(--space-24);
    }

    .home-services {
        margin: var(--space-12) 0 0;
        padding: 0;
    }

    .home-services__row {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1.4fr);
        gap: var(--space-6);
        align-items: baseline;
        padding: var(--space-5) 0;
        border-bottom: 1px solid var(--border-soft);
        transition: color 0.2s ease;
    }

    .home-services__row:first-of-type {
        border-top: 1px solid var(--border-soft);
    }

    .home-services__row dt {
        display: flex;
        gap: var(--space-3);
        align-items: baseline;
        margin: 0;
    }

    .home-services__num {
        font-family: var(--font-mono);
        font-size: 0.78rem;
        letter-spacing: 0.04em;
        color: var(--text-muted);
        font-weight: 500;
        transition: color 0.2s ease;
    }

    .home-services__label {
        font-family: var(--font-mono);
        font-size: 0.92rem;
        letter-spacing: 0.06em;
        color: var(--text-primary);
        font-weight: 600;
    }

    .home-services__row dd {
        margin: 0;
        color: var(--text-secondary);
        font-size: 1rem;
        line-height: 1.55;
    }

    @media (hover: hover) {
        .home-services__row:hover .home-services__num {
            color: var(--accent);
        }
    }

    @media (max-width: 720px) {
        .home-services__row {
            grid-template-columns: 1fr;
            gap: var(--space-2);
            padding: var(--space-4) 0;
        }
    }

    .home-services__more {
        margin: var(--space-10) 0 0;
        font-family: var(--font-mono);
        font-size: 0.85rem;
        letter-spacing: 0.04em;
    }

    .home-services__more a {
        color: var(--accent);
        border-bottom: 1px solid transparent;
        transition: border-color 0.2s ease;
    }

    .home-services__more a:hover {
        border-bottom-color: var(--accent);
    }

    /* Sekce 5 — Kdo jsme: reveal wrapper nad FounderStrip */
    .home-who {
        position: relative;
    }

    /* Sekce 6 — Manifesto editorial */
    .section--editorial {
        text-align: center;
        padding: var(--space-24) 0;
    }

    .section--editorial .eyebrow {
        display: block;
        margin-bottom: var(--space-4);
    }

    .section--editorial h2 {
        font-size: clamp(1.8rem, 3.2vw, 2.6rem);
        max-width: 30ch;
        margin: 0 auto var(--space-8);
        line-height: 1.2;
        letter-spacing: -0.03em;
        color: var(--text-primary);
    }

    .home-manifesto__body p {
        font-size: 1.05rem;
        line-height: 1.65;
        color: var(--text-secondary);
        max-width: 56ch;
        margin: 0 auto var(--space-4);
    }

    .home-manifesto__quote {
        margin: var(--space-12) auto 0;
        font-size: clamp(1.2rem, 2vw, 1.5rem);
        max-width: 48ch;
        color: var(--signal-gold);
        line-height: 1.5;
        font-weight: 400;
        font-style: italic;
        border: 0;
        padding: 0;
    }
</style>
