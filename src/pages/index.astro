---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionHead from '../components/SectionHead.astro';
import Split from '../components/Split.astro';
import SplitCard from '../components/SplitCard.astro';
import Duo from '../components/Duo.astro';
import Features from '../components/Features.astro';
import Feature from '../components/Feature.astro';
import CtaBand from '../components/CtaBand.astro';
import Stats from '../components/Stats.astro';
import FounderStrip from '../components/FounderStrip.astro';
import TeamGrid from '../components/TeamGrid.astro';
---

<Layout
    title="VELYOS — The Velocity Operating System."
    description="VELYOS staví automatizaci, která firmám i profesionálům vrací čas, peníze a klid. Vyberte cestu — pro firmu nebo pro vás osobně."
    lang="cs"
    active="home"
    primaryCta={{ label: 'Zažádat o konzultaci', href: '/firmy' }}
>
    <Hero tagline={`„The Velocity Operating System."`} variant="split">
        <h1 class="hero__title">Vracíme čas tam, kde má <span class="accent">nejvyšší hodnotu.</span></h1>
        <p class="hero__lead">
            Stavíme automatizaci, která vrací firmám i profesionálům
            <strong>čas, peníze a klid</strong>. Abyste se mohli soustředit na to, co je opravdu důležité.
            Nejsme software — jsme tým, který to za vás postaví.
        </p>

        <div class="hero__ctas">
            <a href="/firmy" class="btn btn--primary btn-arrow btn--lg">Chci řešení pro firmu</a>
            <a href="/jednotlivci" class="btn btn--ghost btn-arrow btn--lg">Chci řešení pro jednotlivce</a>
        </div>

        <div class="hero__meta">
            <div class="hero__meta-item">
                <span class="hero__meta-label">Nasazení</span>
                <span class="hero__meta-value mono">4 <span class="gold">týdny</span></span>
            </div>
            <div class="hero__meta-item">
                <span class="hero__meta-label">Návratnost</span>
                <span class="hero__meta-value mono">6 <span class="gold">měsíců</span></span>
            </div>
            <div class="hero__meta-item">
                <span class="hero__meta-label">Záruka</span>
                <span class="hero__meta-value">Ve smlouvě</span>
            </div>
            <div class="hero__meta-item">
                <span class="hero__meta-label">Klientela</span>
                <span class="hero__meta-value">Omezený počet</span>
            </div>
        </div>
    </Hero>

    <section class="split-section" id="vyberte">
        <div class="container">
            <SectionHead
                eyebrow="· 01 · Vyberte si, co vám sedí"
                title="Pracujeme se dvěma typy klientů. Každému nabízíme jiný přístup."
            />

            <Split>
                <SplitCard
                    href="/firmy"
                    accent="orange"
                    eyebrow="Pro firmy"
                    title="Stavíme AI agenty, kteří přeberou rutinu týmu."
                    body="Máte tým, který tráví hodiny administrativou, zákaznickou podporou nebo interním reportingem? Vrátíme ho k práci, za kterou ho platíte. Diagnostika, návrh, integrace, provoz — jedna ruka."
                    ctaLabel="Chci řešení pro firmu"
                    ctaClass="btn--primary"
                />
                <SplitCard
                    href="/jednotlivci"
                    accent="gold"
                    eyebrow="Pro jednotlivce"
                    title="Stavíme osobního AI agenta pro váš den."
                    body="Majitel firmy, konzultant, advokát? Den vám žere e-mail a kalendář. Agent převezme komunikaci, plánování a administrativu — vrátíme vám hodiny týdně."
                    ctaLabel="Chci řešení pro jednotlivce"
                    ctaClass="btn--dark"
                />
            </Split>
        </div>
    </section>

    <section class="section--alt" id="co-stavime">
        <div class="container">
            <SectionHead
                eyebrow="· 02 · Co stavíme"
                title="Máte svůj systém? Napojíme se. Nemáte? Postavíme všechno."
                lead="Nejste závislí na pěti různých agenturách. Jeden partner. Jedna smlouva. Od prvního logu po poslední tlačítko na webu."
            />

            <Duo
                leftEyebrow="← Máte už něco"
                leftTitle="Napojíme se na to, co funguje."
                rightEyebrow="→ Nebo od nuly"
                rightTitle="Postavíme vám všechno."
            >
                <Fragment slot="left">
                    <p>Máte web? CRM? E-maily? Marketing?</p>
                    <p>Nic nebouráme. Přidáme AI a propojíme to, co teď běží odděleně.</p>
                </Fragment>
                <Fragment slot="right">
                    <p>Začínáte? Přecházíte? Chcete nový směr?</p>
                    <p>Uděláme vám web, značku, AI agenty, propojení i propagaci. Od A do Z.</p>
                </Fragment>
            </Duo>

            <Features cols={3}>
                <Feature num="01 / WEB & BRAND" title="Postavíme vám web a značku." body="Stránky, které prodávají. Logo, barvy a vizuál, který si lidi zapamatují." />
                <Feature num="02 / AI AGENTI" title="Nasadíme AI, co mluví místo vás." body="Hlasový agent na telefonu. Chatbot na webu. E-mailový asistent. 24/7." />
                <Feature num="03 / CRM & INTEGRACE" title="Propojíme to s vaším systémem." body="HubSpot, Pipedrive, Salesforce, nebo vlastní. Data si sedí sama na místo." />
                <Feature num="04 / PROPAGACE" title="Postaráme se, aby o vás věděli." body="SEO. Google & Meta reklama. LinkedIn. Cold outreach. Ti správní klienti." />
                <Feature num="05 / AUTOMATIZACE" title="Propojíme nástroje, co už používáte." body="Slack, Notion, Google, fakturace. Věci, co dneska děláte ručně, pojedou samy." />
                <Feature num="06 / DATA" title="Ukážeme vám, kde utíká čas." body="Dashboard, co dává smysl. Vidíte, co funguje, co ne, a co dělat dál." />
            </Features>
        </div>
    </section>

    <CtaBand
        id="agent"
        eyebrow="· Nevíte, kam patříte? ·"
        title="Náš agent vám během pár minut pomůže najít odpověď."
        lead="Žádný obchodník. Žádná prezentace. Krátký rozhovor s AI, která zná obě cesty — a upřímně vám řekne, kam byste se měli podívat dřív."
        directPrefix="Nechcete přes agenta?"
    >
        <a href="/diagnostika" class="btn btn--primary btn-arrow btn--lg">Promluvit si s agentem</a>
        <a href="mailto:stepan@velyos.ai?subject=Dotaz%20VELYOS" class="btn btn--ghost btn--lg">Napsat obchodu</a>
    </CtaBand>

    <section class="section--tight">
        <div class="container">
            <SectionHead
                eyebrow="· 03 · Čemu věnujeme disciplínu"
                title="Tři principy. Jedna smlouva."
            />

            <Features cols={3}>
                <Feature num="01 / VELOCITY" title="Měříme v týdnech, ne měsících." body={`Integrace typicky v řádu dnů. Plné nasazení v rozmezí 4 týdnů. Žádné „pilotní fáze na půl roku".`} />
                <Feature num="02 / PRECISION" title={`Žádné „skoro". Jen exaktní výsledky.`} body="Měřitelné úspory, lidský dohled a architektura navržená v duchu ISO 27001. AI, která se nehádá s realitou." />
                <Feature num="03 / SELECTIVE" title="Přijímáme omezený počet klientů ročně." body="Pokud se do profilu netrefíme, řekneme vám to rovnou — a doporučíme dál." />
            </Features>
        </div>
    </section>

    <Stats lang="cs" />

    <FounderStrip lang="cs" variant="strip" href="/o-nas" />

    <section class="section--editorial">
        <div class="container container--narrow" data-reveal>
            <span class="eyebrow">· Manifesto</span>
            <h2 style="margin-top:var(--space-4);margin-bottom:var(--space-8);">Čas je jediné aktivum, které se nedá koupit zpátky.</h2>
            <div class="section-body">
                <p>Většina firem ho spaluje v procesech, které měly být dávno automatizované. V hovorech, které nikdo neměl vést. V administrativě, která neměla existovat.</p>
                <p>VELYOS je partner, který vám firmu postaví, zapojí a udrží v chodu. Ne další software, který si musíte nastavit sami. Pro firmy a profesionály, kteří rozumí hodnotě vlastního času.</p>
                <p><strong>Implementujeme za 4 týdny. Návratnost do 6 měsíců. Garantováno smlouvou.</strong></p>
                <p class="italic-serif" style="color:var(--signal-gold);margin-top:var(--space-6);font-size:1.2rem;">„Nepracujeme pro každého. Pracujeme pro ty, kteří chápou, proč jsou u nás."</p>
            </div>
        </div>
    </section>
</Layout>
