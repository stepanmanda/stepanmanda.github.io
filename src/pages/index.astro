---
import Layout from '../layouts/Layout.astro';
import HeroSticky from '../components/HeroSticky.astro';
import SectionHead from '../components/SectionHead.astro';
import Features from '../components/Features.astro';
import RevealCard from '../components/RevealCard.astro';
import Steps from '../components/Steps.astro';
import Step from '../components/Step.astro';
import FounderStrip from '../components/FounderStrip.astro';
import CtaBand from '../components/CtaBand.astro';

const heroMeta = [
    { label: 'Nasazení', value: '4 týdny' },
    { label: 'Návratnost', value: '6 měsíců' },
    { label: 'Záruka', value: 'Ve smlouvě' },
    { label: 'Klientela', value: 'Omezený počet' },
];

const services = [
    { title: 'Web & značka',     body: 'Stránky, kterým lidé věří a které prodávají.' },
    { title: 'AI asistenti',     body: 'Zvednou telefon, odpíšou e-mail. I v neděli v noci.' },
    { title: 'CRM & integrace',  body: 'Všechna data na jednom místě. Ne ve třech tabulkách.' },
    { title: 'Propagace',        body: 'Klienti Vás najdou. Ne Vy je.' },
    { title: 'Automatizace',     body: 'Co se opakuje, to převezmeme.' },
    { title: 'Data & reporting', body: 'Uvidíte, co funguje. Bez excelu.' },
];
---

<Layout
    title="VELYOS — The Velocity Partner."
    description="Stavíme automatizaci, která vrací firmám i profesionálům čas, peníze a klid. Nejsme software. Jsme tým, který to za Vás postaví."
    lang="cs"
    active="home"
    primaryCta={{ label: 'Spustit diagnostiku', href: '/diagnostika' }}
>

    <!-- Sekce 1 — Hero -->
    <HeroSticky tagline={`„The Velocity Partner."`} meta={heroMeta}>
        <h1 slot="heading">Vracíme čas tam, kde má <em>nejvyšší hodnotu</em>.</h1>

        <p slot="lead">
            Stavíme automatizaci, která vrací firmám i profesionálům <strong>čas, peníze a klid</strong>.
            Nejsme software. Jsme tým, který to za Vás postaví.
        </p>

        <Fragment slot="ctas">
            <a href="/firmy" class="btn btn--primary btn-arrow btn--lg">Chci řešení pro firmu →</a>
            <a href="/jednotlivci" class="btn btn--ghost btn-arrow btn--lg">Chci řešení pro jednotlivce →</a>
        </Fragment>
    </HeroSticky>

    <!-- Sekce 2 — Komu (3 reveal cards) -->
    <section class="section--alt-white">
        <div class="container">
            <SectionHead
                eyebrow="KOMU"
                title="Pro firmy s týmem. Pro profesionály bez něj."
                titleMax="19ch"
                lead="Pokud si nejste jistí, kam patříte — zjistíme to společně v diagnostice."
            />
            <Features cols={3}>
                <RevealCard
                    title="Firmy s týmem"
                    body="5–30 lidí, kdy administrativa pohlcuje obchodní čas. Zdravotnictví, účetní, řemeslo, růstově orientované služby."
                />
                <RevealCard
                    title="Profesionálové"
                    body="Advokáti, doktoři, konzultanti, realitky. Jeden mozek a chaos kalendáře, e-mailů a klientských požadavků."
                />
                <RevealCard
                    title="Nevíte?"
                    body="Není problém. Diagnostika ukáže, co dává smysl."
                />
            </Features>
        </div>
    </section>

    <!-- Sekce 3 — Co děláme (horizontální scroll strip) -->
    <section class="home-services-section section--alt-warm">
        <div class="container">
            <SectionHead
                eyebrow="CO DĚLÁME"
                title="Jeden tým. Celé řešení."
                titleMax="14ch"
                lead="Od prvního hovoru po měsíční report. Jedna smlouva, žádné přehazování odpovědnosti."
            />

            <div class="services-strip-wrap">
                <div class="services-strip" role="list">
                    {services.map((s) => (
                        <article class="services-strip__item" role="listitem">
                            <span class="services-strip__dot" aria-hidden="true"></span>
                            <h3 class="services-strip__title">{s.title}</h3>
                            <p class="services-strip__body">{s.body}</p>
                        </article>
                    ))}
                    <a href="/pristup" class="services-strip__cta">
                        <span class="services-strip__cta-label">Více o přístupu</span>
                        <span class="services-strip__cta-arrow" aria-hidden="true">→</span>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- Sekce 4 — Jak to děláme (3 kroky, sjednocená metodika) -->
    <section class="section--alt-white">
        <div class="container">
            <SectionHead
                eyebrow="JAK TO DĚLÁME"
                title="Tři kroky. Žádné pilotní fáze."
                titleMax="14ch"
                lead="Začínáme tím, že posloucháme. Končíme tím, že to běží."
            />
            <Steps cols={3}>
                <Step num="01" title="POSLOUCHÁME"  body="Diagnostika. Pochopíme, co Vás brzdí." />
                <Step num="02" title="STAVÍME"      body="Návrh, integrace, nasazení. Do 4 týdnů." />
                <Step num="03" title="STARÁME SE"   body="Provoz, dohled, ladění. Dokud to dává smysl." />
            </Steps>
        </div>
    </section>

    <!-- Sekce 5 — Kdo jsme -->
    <div class="home-who" data-reveal>
        <FounderStrip lang="cs" variant="strip" href="/o-nas" />
    </div>

    <!-- Sekce 6 — Manifesto -->
    <section class="section--editorial section--alt-warm">
        <div class="container container--narrow" data-reveal>
            <span class="eyebrow">Manifesto</span>
            <h2>Čas je jediné aktivum, které se nedá koupit zpátky.</h2>
            <div class="home-manifesto__body">
                <p>Většina firem ho spaluje v procesech, které měly být dávno automatizované. V hovorech, které nikdo neměl vést. V administrativě, která neměla existovat.</p>
                <p>VELYOS je partner, který Vám firmu postaví, zapojí a udrží v chodu. Ne další software, který si musíte nastavit sami.</p>
            </div>
            <blockquote class="home-manifesto__quote italic-serif">
                „Neděláme všechno pro všechny. Děláme všechno pro Vás."
            </blockquote>
        </div>
    </section>

    <!-- Sekce 7 — Final CTA -->
    <CtaBand
        id="zacit"
        eyebrow="Začněme"
        title="5 minut. Žádné závazky. Jen odpovědi."
        titleMax="22ch"
        lead="Žádný obchodník. Žádná prezentace. Krátká diagnostika a víte, kam dál."
        directPrefix="Nebo napište přímo:"
    >
        <a href="/diagnostika" class="btn btn--primary btn-arrow btn--lg">Spustit diagnostiku →</a>
    </CtaBand>

</Layout>

<style>
    /* ============================================================
       Home — Fáze 3 redesign
       ============================================================ */

    /* Sekce 3 — Service strip (horizontální scroll) */
    .home-services-section {
        padding-bottom: var(--space-24);
    }

    .services-strip-wrap {
        position: relative;
        margin: var(--space-12) calc(-1 * var(--space-8)) 0;
    }

    .services-strip {
        display: flex;
        gap: 0;
        overflow-x: auto;
        scrollbar-width: none;
        scroll-snap-type: x proximity;
        padding: 0 var(--space-8);
    }

    .services-strip::-webkit-scrollbar {
        display: none;
    }

    .services-strip__item,
    .services-strip__cta {
        flex: 0 0 auto;
        min-width: 260px;
        padding: var(--space-7) var(--space-8);
        border-right: 1px solid var(--border-soft);
        scroll-snap-align: start;
        position: relative;
    }

    .services-strip__item:first-child,
    .services-strip__cta:first-child {
        border-left: 1px solid var(--border-soft);
    }

    .services-strip__dot {
        display: block;
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--velocity-orange);
        margin-bottom: var(--space-5);
    }

    .services-strip__title {
        font-family: var(--font-sans);
        font-size: 1.15rem;
        font-weight: 600;
        letter-spacing: -0.01em;
        color: var(--text-primary);
        margin: 0 0 var(--space-3);
        line-height: 1.3;
    }

    .services-strip__body {
        font-family: var(--font-sans);
        font-size: 0.88rem;
        color: var(--text-secondary);
        margin: 0;
        line-height: 1.5;
        opacity: 0;
        transform: translateY(4px);
        transition: opacity 0.3s ease, transform 0.3s ease;
    }

    @media (hover: hover) {
        .services-strip__item:hover .services-strip__body,
        .services-strip__item:focus-within .services-strip__body {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @media (hover: none) {
        .services-strip__body {
            opacity: 1;
            transform: none;
        }
    }

    /* CTA položka */
    .services-strip__cta {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: flex-start;
        gap: var(--space-2);
        color: var(--velocity-orange);
        text-decoration: none;
        background: linear-gradient(135deg, transparent 0%, rgba(232, 93, 31, 0.04) 100%);
        transition: background 0.25s ease;
    }

    .services-strip__cta:hover {
        background: linear-gradient(135deg, transparent 0%, rgba(232, 93, 31, 0.1) 100%);
    }

    .services-strip__cta-label {
        font-family: var(--font-sans);
        font-size: 1.1rem;
        font-weight: 600;
        letter-spacing: -0.01em;
    }

    .services-strip__cta-arrow {
        font-size: 1.4rem;
        line-height: 1;
        transition: transform 0.25s ease;
    }

    .services-strip__cta:hover .services-strip__cta-arrow {
        transform: translateX(4px);
    }

    /* Fade gradient na pravé hraně mobilu — naznačuje pokračování */
    @media (max-width: 720px) {
        .services-strip-wrap::after {
            content: '';
            position: absolute;
            top: 0;
            bottom: 0;
            right: 0;
            width: 48px;
            background: linear-gradient(to right, transparent, var(--warm-bg) 80%);
            pointer-events: none;
        }

        .services-strip__item,
        .services-strip__cta {
            min-width: 75vw;
        }
    }

    /* Sekce 5 — Kdo jsme: reveal wrapper nad FounderStrip */
    .home-who {
        position: relative;
    }

    /* Sekce 6 — Manifesto editorial */
    .section--editorial {
        text-align: center;
        padding: var(--space-24) 0;
    }

    .section--editorial .eyebrow {
        display: block;
        margin-bottom: var(--space-4);
    }

    .section--editorial h2 {
        font-size: clamp(1.8rem, 3.2vw, 2.6rem);
        max-width: 30ch;
        margin: 0 auto var(--space-8);
        line-height: 1.2;
        letter-spacing: -0.03em;
        color: var(--text-primary);
    }

    .home-manifesto__body p {
        font-size: 1.05rem;
        line-height: 1.65;
        color: var(--text-secondary);
        max-width: 56ch;
        margin: 0 auto var(--space-4);
    }

    .home-manifesto__quote {
        margin: var(--space-12) auto 0;
        font-size: clamp(1.2rem, 2vw, 1.5rem);
        max-width: 48ch;
        color: var(--signal-gold);
        line-height: 1.5;
        font-weight: 400;
        font-style: italic;
        border: 0;
        padding: 0;
    }
</style>
