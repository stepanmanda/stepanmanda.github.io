---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import SectionHead from '../../components/SectionHead.astro';
import Features from '../../components/Features.astro';
import Feature from '../../components/Feature.astro';
import Callout from '../../components/Callout.astro';
import AgentDiagnostic from '../../components/AgentDiagnostic.astro';
---

<Layout
    title="VELYOS — Contact | Three ways to start."
    description="Three ways to reach VELYOS: AI diagnostic agent, email, phone. We respond within 24 hours. No sales. No presentation."
    lang="en"
    active="kontakt"
    primaryCta={null}
    footerTagline="No sales. No presentation."
    footerVariant="v0.3 preview · contact"
>
    <Hero tagline="· Contact · Defining the lead.">
        <h1 class="hero__title">Three ways. <span class="accent">We respond within 24 hours.</span></h1>
        <p class="hero__lead">
            Agent, email, or phone. No sales. No presentation. No „fill out the form and we'll call you".
            Pick what works for you — we'll take care of the rest.
        </p>
    </Hero>

    <section>
        <div class="container">
            <SectionHead
                eyebrow="· 02 · Choose your path"
                title="Three ways to start the conversation."
                lead="Every path ends with the same specialist. The only difference is how much time you invest up front."
            />

            <Features cols={3}>
                <Feature
                    num="Fastest"
                    title="AI diagnostic agent"
                    body="Voice conversation with our Stela. 5–7 minutes, natural tone, no forms. A specialist calls you within 24 hours with a brief. Start below →"
                />
                <Feature
                    num="Easiest"
                    title="Email"
                    body="A short message. Two sentences about your situation. We respond within 24 hours with concrete next steps — not a presentation."
                />
                <Feature
                    num="Most personal"
                    title="Phone"
                    body="Number available after company registration. Until then, after an email or form, we'll call you back — usually within one business day."
                />
            </Features>
        </div>
    </section>

    <AgentDiagnostic agentId="cu9gllbBtpZWU6CuJXky" lang="en" />

    <section class="section--alt">
        <div class="container">
            <SectionHead
                eyebrow="· 03 · Direct channels"
                title="Sales, specialist, and founder."
                lead="If you know who you want to reach, write directly. Every channel has a clear owner. No transfers."
            />

            <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(260px, 1fr)); gap:var(--space-8); margin-top:var(--space-10);" data-stagger>
                <div style="padding:var(--space-8); background:var(--surface-card); border:1px solid var(--border-soft); border-radius:var(--radius-lg); border-top:3px solid var(--velocity-orange);">
                    <span class="eyebrow" style="color:var(--velocity-orange);">Sales &amp; diagnostic</span>
                    <h3 style="margin-top:var(--space-3); margin-bottom:var(--space-4);">Štěpán Manda</h3>
                    <p style="color:var(--text-secondary); margin-bottom:var(--space-6);">Founder &amp; CEO. Takes every new client personally — your first call goes straight to the founder.</p>
                    <p style="line-height:2; margin:0;">
                        <a href="mailto:stepan@velyos.ai" style="color:var(--text-primary); border-bottom:1px solid var(--gold-30); font-weight:500;">stepan@velyos.ai</a><br>
                        <span style="color:var(--mist-gray); font-size:0.9rem; font-style:italic;">Phone number available after company registration.</span>
                    </p>
                </div>

                <div style="padding:var(--space-8); background:var(--surface-card); border:1px solid var(--border-soft); border-radius:var(--radius-lg); border-top:3px solid var(--signal-gold);">
                    <span class="eyebrow" style="color:var(--signal-gold);">Media &amp; partners</span>
                    <h3 style="margin-top:var(--space-3); margin-bottom:var(--space-4);">Collaboration, PR, investors</h3>
                    <p style="color:var(--text-secondary); margin-bottom:var(--space-6);">Press inquiries, interview requests, partnership initiatives, investor inquiries.</p>
                    <p style="line-height:2; margin:0;">
                        <a href="mailto:hello@velyos.ai" style="color:var(--text-primary); border-bottom:1px solid var(--gold-30); font-weight:500;">hello@velyos.ai</a><br>
                        <span style="color:var(--mist-gray); font-size:0.9rem; font-style:italic;">LinkedIn after registration.</span>
                    </p>
                </div>
            </div>
        </div>
    </section>

    <section>
        <div class="container container--narrow">
            <SectionHead
                eyebrow="· 04 · When and where"
                title="Where to find us and when we respond."
            />

            <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(260px, 1fr)); gap:var(--space-10); margin-top:var(--space-8);" data-stagger>
                <div>
                    <span class="eyebrow" style="color:var(--signal-gold);">Headquarters</span>
                    <p style="margin-top:var(--space-3); font-size:1.1rem; line-height:1.6;">
                        <strong>VELYOS</strong><br>
                        Františkovy Lázně 553/7<br>
                        351 01 Františkovy Lázně<br>
                        <span style="color:var(--text-secondary); font-size:0.95rem;">Czech Republic</span>
                    </p>
                </div>
                <div>
                    <span class="eyebrow" style="color:var(--signal-gold);">Working hours</span>
                    <p style="margin-top:var(--space-3); font-size:1.1rem; line-height:1.6;">
                        Monday–Friday, 9:00–17:00 CET<br>
                        <span style="color:var(--text-secondary); font-size:0.95rem;">
                            Email response: <strong>within 24 hours</strong><br>
                            Phone number available after company registration
                        </span>
                    </p>
                </div>
            </div>
        </div>
    </section>

    <section class="section--editorial">
        <div class="container container--narrow">
            <SectionHead
                eyebrow="· 05 · For suppliers and careers"
                title="Work with us — or want to?"
            />

            <div class="section-body" data-reveal>
                <p>
                    <strong>Suppliers and subcontractors:</strong> We only work with vetted partners who have track record and can deliver on time. Write us briefly: field, specialty, references.
                    We respond within a week.
                </p>
                <p>
                    <strong>Careers:</strong> We're not the team that collects juniors. We hire senior specialists with at least 5 years of experience in their field —
                    build, development, analytics, design. We're looking for people who already know, not those still learning. If that's you, write directly to Štěpán.
                </p>
            </div>
        </div>
    </section>

    <section>
        <div class="container container--narrow">
            <SectionHead
                eyebrow="· 06 · Most asked"
                title="Answers before you ask."
            />

            <div class="section-body" data-reveal>
                <h3>How much does it cost?</h3>
                <p style="color:var(--text-secondary);">
                    No public price list. Every project is different — depending on what we build, what we plug into, and how many people it touches.
                    You'll get a concrete quote after the first call, not from a form.
                </p>

                <h3>How long does deployment take?</h3>
                <p style="color:var(--text-secondary);">
                    Typically 4 weeks from signed contract to live operation. Smaller projects faster, complex cases up to 6 weeks. Speed is our principle —
                    we're not interested in drawn-out projects.
                </p>

                <h3>What if it doesn't work?</h3>
                <p style="color:var(--text-secondary);">
                    Our contract has an ROI guarantee within 6 months. If we don't deliver, we keep working at no cost, or refund the gap. You have nothing to lose.
                </p>

                <h3>Who has access to the data?</h3>
                <p style="color:var(--text-secondary);">
                    Only our team and the systems you approve. AES-256 encryption, GDPR, architecture aligned with ISO 27001 principles.
                    We never use your data to train third-party models.
                </p>

                <h3>What if we end the partnership — are we stuck on our own?</h3>
                <p style="color:var(--text-secondary);">
                    No. Everything we build is designed to function without us. We use standard tools and deliver complete documentation.
                    On exit, you get a <strong>handoff document</strong>: access credentials, architecture description, integrator contacts.
                    Short notice period — no vendor lock-in, no penalties.
                </p>

                <h3>Can I invite VELYOS to a meeting?</h3>
                <p style="color:var(--text-secondary);">
                    Yes, if you're a serious prospect and have at least completed a short agent diagnostic or email. Not because we're too busy —
                    but so you get value from the first meeting, not a presentation.
                </p>
            </div>
        </div>
    </section>

    <section class="section--alt section--tight">
        <div class="container container--narrow">
            <Callout>
                <strong>Still not sure if VELYOS fits?</strong>
                The fastest path is 5 minutes with our agent above. It'll tell you whether we're for you — and if not, it'll say so honestly.
            </Callout>
        </div>
    </section>
</Layout>
