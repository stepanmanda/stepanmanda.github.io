---
import Layout from '../../layouts/Layout.astro';
import DiagnosticForm from '../../components/DiagnosticForm.astro';
---

<Layout
    title="VELYOS — Diagnostic | We find where time is leaking."
    description="Start a diagnostic: structured form or a live conversation with our AI agent. A specialist responds within 24 hours. No sales pressure."
    lang="en"
    active="diagnostika"
    primaryCta={null}
    footerTagline="A brief. Not a pitch."
    footerVariant="v0.3 preview · diagnostic"
>
    <section class="diagnostika-hero">
        <div class="diagnostika-hero__grid"></div>
        <div class="diagnostika-hero__glow"></div>
        <div class="container">
            <div class="diagnostika-hero__inner" data-reveal>
                <span class="eyebrow">· Diagnostic · Defining the lead.</span>
                <h1 class="diagnostika-hero__title">
                    Two paths. <span class="accent">The same specialist on the other side.</span>
                </h1>
                <p class="diagnostika-hero__lead">
                    Fill out a structured form, or talk directly to our AI agent.
                    Both paths end with the same person, who'll call you within 24 hours with a concrete brief — not a presentation.
                </p>
            </div>
        </div>
    </section>

    <section class="diagnostika-main">
        <div class="container">
            <div class="diagnostika-grid">
                <div class="diagnostika-col diagnostika-col--form" data-reveal>
                    <div class="diagnostika-col__header">
                        <span class="eyebrow" style="color:var(--signal-gold);">· 01 · Written diagnostic</span>
                        <h2>Fill in what's hurting. We'll send the brief to a specialist.</h2>
                        <p class="diagnostika-col__intro">
                            Ten fields. Three minutes. The information a specialist needs
                            to arrive at the first call with a concrete proposal — not questions.
                        </p>
                    </div>

                    <DiagnosticForm lang="en" />
                </div>

                <div class="diagnostika-col diagnostika-col--agent" data-reveal>
                    <div class="diagnostika-col__header">
                        <span class="eyebrow" style="color:var(--velocity-orange);">· 02 · Voice diagnostic</span>
                        <h2>Prefer to talk? Tell the agent.</h2>
                        <p class="diagnostika-col__intro">
                            A natural voice conversation with our AI agent, Stela.
                            Five to seven minutes, no form, no sales pressure.
                        </p>
                    </div>

                    <div class="agent-card">
                        <div class="agent-card__badge">
                            <span class="agent-card__dot"></span>
                            <span>Agent online · responds now</span>
                        </div>

                        <div class="agent-card__pointer">
                            <svg class="agent-card__arrow" width="96" height="96" viewBox="0 0 96 96" fill="none" aria-hidden="true">
                                <path d="M16 16 C 16 60, 50 80, 82 82" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-dasharray="4 6" fill="none"/>
                                <path d="M76 74 L 84 84 L 74 86" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                            </svg>
                            <div class="agent-card__pointer-text">
                                <strong>Click the orange pill in the lower right.</strong><br>
                                The widget opens and Stela starts listening.
                            </div>
                        </div>

                        <ul class="agent-card__points">
                            <li>Speaks English, Czech, German, and 10 more languages</li>
                            <li>The call is free, no sales pressure, no presentation</li>
                            <li>Brief automatically forwarded to a specialist</li>
                        </ul>

                        <div class="agent-card__footnote">
                            A specialist will call you within 24 hours. Same as if you submit the form on the left.
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="section--editorial section--tight">
        <div class="container container--narrow" data-reveal>
            <div style="display:grid; grid-template-columns:repeat(3, 1fr); gap:var(--space-8); text-align:center;">
                <div>
                    <span class="eyebrow" style="color:var(--signal-gold); display:block; margin-bottom:var(--space-3);">Within 24 hours</span>
                    <p style="margin:0; color:var(--black-60); font-size:0.95rem;">
                        We respond within 24 hours on business days. During business hours, often faster.
                    </p>
                </div>
                <div>
                    <span class="eyebrow" style="color:var(--signal-gold); display:block; margin-bottom:var(--space-3);">No sales</span>
                    <p style="margin:0; color:var(--black-60); font-size:0.95rem;">
                        The first call goes straight to the founder or a senior specialist. Not a sales assistant.
                    </p>
                </div>
                <div>
                    <span class="eyebrow" style="color:var(--signal-gold); display:block; margin-bottom:var(--space-3);">No commitment</span>
                    <p style="margin:0; color:var(--black-60); font-size:0.95rem;">
                        The diagnostic is free. If VELYOS doesn't fit you, we'll tell you straight.
                    </p>
                </div>
            </div>
        </div>
    </section>
</Layout>

<style>
    .diagnostika-hero {
        background: var(--ivory-silver);
        padding: var(--space-20) 0 var(--space-12);
        position: relative;
        overflow: hidden;
        border-bottom: 1px solid var(--black-08);
    }
    .diagnostika-hero__grid {
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(rgba(11, 15, 25, 0.06) 1px, transparent 1px),
            linear-gradient(90deg, rgba(11, 15, 25, 0.06) 1px, transparent 1px);
        background-size: 72px 72px;
        mask-image: radial-gradient(ellipse at 50% 0%, black 10%, transparent 70%);
        pointer-events: none;
    }
    .diagnostika-hero__glow {
        position: absolute;
        width: 800px;
        height: 400px;
        top: -200px;
        left: 50%;
        transform: translateX(-50%);
        background: radial-gradient(circle, rgba(184, 147, 92, 0.2) 0%, transparent 65%);
        pointer-events: none;
        animation: glowBreathe 8s ease-in-out infinite;
    }
    .diagnostika-hero .container { position: relative; z-index: 1; }
    .diagnostika-hero__inner {
        text-align: center;
        max-width: 60ch;
        margin: 0 auto;
    }
    .diagnostika-hero__inner .eyebrow {
        display: block;
        margin-bottom: var(--space-4);
    }
    .diagnostika-hero__title {
        font-size: clamp(2.2rem, 4.2vw, 3.4rem);
        letter-spacing: -0.03em;
        line-height: 1.08;
        margin: 0 0 var(--space-6);
    }
    .diagnostika-hero__title .accent { color: var(--velocity-orange); }
    .diagnostika-hero__lead {
        font-size: 1.15rem;
        color: var(--black-60);
        line-height: 1.55;
        margin: 0;
    }
    .diagnostika-main {
        padding: var(--space-16) 0;
        background: var(--alpine-white);
    }
    .diagnostika-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--space-12);
        align-items: start;
    }
    .diagnostika-col {
        display: flex;
        flex-direction: column;
        gap: var(--space-8);
    }
    .diagnostika-col__header h2 {
        font-size: clamp(1.4rem, 2.2vw, 1.75rem);
        letter-spacing: -0.02em;
        margin: var(--space-3) 0 var(--space-3);
        line-height: 1.2;
    }
    .diagnostika-col__intro {
        color: var(--black-60);
        font-size: 1rem;
        line-height: 1.6;
        margin: 0;
    }
    .agent-card {
        background: var(--velocity-black);
        color: var(--ivory-silver);
        padding: var(--space-8);
        border-radius: var(--radius-lg);
        position: relative;
        overflow: hidden;
        border-top: 3px solid var(--velocity-orange);
        box-shadow: 0 30px 70px -30px rgba(11, 15, 25, 0.35);
    }
    .agent-card::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
            radial-gradient(circle at 80% 20%, rgba(232, 93, 31, 0.15) 0%, transparent 50%),
            radial-gradient(circle at 20% 80%, rgba(184, 147, 92, 0.1) 0%, transparent 50%);
        pointer-events: none;
    }
    .agent-card > * { position: relative; z-index: 1; }
    .agent-card__badge {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        padding: 0.35rem 0.85rem;
        background: rgba(232, 93, 31, 0.15);
        border: 1px solid rgba(232, 93, 31, 0.35);
        border-radius: 999px;
        font-family: var(--font-mono);
        font-size: 0.7rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--velocity-orange);
        margin-bottom: var(--space-6);
    }
    .agent-card__dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--velocity-orange);
        animation: agentPulse 2s ease-in-out infinite;
    }
    .agent-card__pointer {
        padding: var(--space-6) var(--space-6);
        border: 1px solid rgba(232, 93, 31, 0.3);
        border-radius: var(--radius);
        background: linear-gradient(135deg, rgba(232, 93, 31, 0.08) 0%, rgba(184, 147, 92, 0.06) 100%);
        text-align: left;
        margin-bottom: var(--space-6);
        display: grid;
        grid-template-columns: auto 1fr;
        gap: var(--space-5);
        align-items: center;
    }
    .agent-card__arrow {
        color: var(--velocity-orange);
        flex-shrink: 0;
        animation: agentArrowSway 3.2s ease-in-out infinite;
    }
    @keyframes agentArrowSway {
        0%, 100% { transform: translate(0, 0); }
        50%      { transform: translate(4px, 4px); }
    }
    .agent-card__pointer-text {
        font-family: var(--font-mono);
        font-size: 0.78rem;
        letter-spacing: 0.06em;
        color: var(--signal-gold);
        line-height: 1.55;
    }
    .agent-card__pointer-text strong {
        color: var(--ivory-silver);
        letter-spacing: 0.04em;
    }
    .agent-card__points {
        list-style: none;
        padding: 0;
        margin: 0 0 var(--space-6);
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
    }
    .agent-card__points li {
        padding-left: 1.2rem;
        position: relative;
        font-size: 0.92rem;
        line-height: 1.5;
        color: var(--ivory-70);
    }
    .agent-card__points li::before {
        content: "→";
        position: absolute;
        left: 0;
        top: 0;
        color: var(--velocity-orange);
        font-family: var(--font-mono);
        font-weight: 500;
    }
    .agent-card__footnote {
        padding-top: var(--space-4);
        border-top: 1px solid rgba(245, 243, 238, 0.1);
        font-family: var(--font-serif);
        font-style: italic;
        font-size: 0.88rem;
        color: var(--mist-gray);
        line-height: 1.55;
    }
    @media (max-width: 980px) {
        .diagnostika-grid {
            grid-template-columns: 1fr;
            gap: var(--space-16);
        }
    }
    @media (max-width: 720px) {
        .diagnostika-hero {
            padding: var(--space-16) 0 var(--space-10);
        }
    }
</style>
