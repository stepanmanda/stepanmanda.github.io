---
import Layout from '../layouts/Layout.astro';
import HeroSticky from '../components/HeroSticky.astro';
import SectionHead from '../components/SectionHead.astro';
import Features from '../components/Features.astro';
import RevealCard from '../components/RevealCard.astro';
import Steps from '../components/Steps.astro';
import Step from '../components/Step.astro';
import CtaBand from '../components/CtaBand.astro';

const heroMeta = [
    { label: 'Nasazení', value: '4 týdny' },
    { label: 'Návratnost', value: '6 měsíců' },
    { label: 'Záruka', value: 'Ve smlouvě' },
    { label: 'Klientela', value: 'Omezený počet' },
];

const troubles = [
    { num: '01', label: 'ADMINISTRATIVA', body: '12 hodin týdně. Faktury, reporty, lustrace.' },
    { num: '02', label: 'KOMUNIKACE',     body: '200 e-mailů denně. 80 % stejných odpovědí.' },
    { num: '03', label: 'KALENDÁŘ',       body: 'Půl dne v úterý jen na plánování.' },
];
---

<Layout
    title="VELYOS — Pro firmy"
    description="Tým 5–30 lidí, kde administrativa pohlcuje obchodní čas. Postavíme řešení, které převezme rutinu — komunikaci, fakturaci, reporting. Vy se vrátíte ke klientům."
    active="firmy"
    primaryCta={{ label: 'Spustit diagnostiku', href: '/diagnostika' }}
    footerTagline="Pro firmy, které si vybírají, s kým porostou."
>

    <!-- Sekce 1 — Hero -->
    <HeroSticky tagline={`„Pro firmy, které rostou."`} meta={heroMeta}>
        <h1 slot="heading">Vaši lidé umí mnohem víc. <em>Když jim to dovolíte.</em></h1>

        <p slot="lead">
            Tým 5–30 lidí. Hodiny týdně v administrativě. Naši agenti převezmou rutinu —
            telefony, e-maily, fakturaci, reporting. Vy se vrátíte ke klientům.
        </p>

        <Fragment slot="ctas">
            <a href="/diagnostika" class="btn btn--primary btn-arrow btn--lg">Spustit diagnostiku →</a>
            <a href="/jednotlivci" class="btn btn--ghost btn-arrow btn--lg">Pro jednotlivce</a>
        </Fragment>
    </HeroSticky>

    <!-- Sekce 2 — Komu (3 reveal cards) -->
    <section>
        <div class="container">
            <SectionHead
                eyebrow="· 01 · KOMU"
                title="Tři situace, kdy vám pomůžeme."
            />
            <Features cols={3}>
                <RevealCard
                    num="01"
                    title="Vysoký objem komunikace"
                    body="Stovky e-mailů týdně, telefon, který nezvedáte. Agent zvládne 80 % bez vás. Složité případy předá člověku s připraveným kontextem."
                />
                <RevealCard
                    num="02"
                    title="Tým, který se topí v adminu"
                    body="Faktury, reporting, kalendáře. Dvanáct hodin týdně mimo skutečnou práci. Auto-pilot to vrátí byznysu."
                />
                <RevealCard
                    num="03"
                    title="Růst, který naráží na strop"
                    body="Nemůžete najímat dál, protože onboarding trvá měsíce. Agenti jsou zítra. Stejně rychle, stejně konzistentně, bez výpadků."
                />
            </Features>
        </div>
    </section>

    <!-- Sekce 3 — Co trápí (3 řádky, žádné karty) -->
    <section>
        <div class="container">
            <SectionHead
                eyebrow="· 02 · CO TRÁPÍ"
                title="Tři věci, které vám denně berou čas."
            />
            <dl class="line-list">
                {troubles.map((t) => (
                    <div class="line-list__row">
                        <dt>
                            <span class="line-list__num">{t.num}</span>
                            <span class="line-list__label">{t.label}</span>
                        </dt>
                        <dd>{t.body}</dd>
                    </div>
                ))}
            </dl>
        </div>
    </section>

    <!-- Sekce 4 — Co stavíme (4 reveal cards) -->
    <section>
        <div class="container">
            <SectionHead
                eyebrow="· 03 · CO STAVÍME"
                title="Čtyři oblasti. Žádný 360° servis."
                lead="Děláme jen to, co umíme dotáhnout. Pokud potřebujete něco mimo, řekneme dopředu — a doporučíme dál."
            />
            <Features cols={2}>
                <RevealCard
                    num="01"
                    title="KOMUNIKACE"
                    body="E-mail asistent, telefonní agent, chat na webu. 24/7. Standardní dotazy bez vás, složité s plně připraveným kontextem."
                />
                <RevealCard
                    num="02"
                    title="ADMINISTRATIVA"
                    body="Fakturace, reporting, dokumenty, hlášení. Auto-pilot. Žádné dvojí zadávání, žádné chyby z únavy."
                />
                <RevealCard
                    num="03"
                    title="CRM & DATA"
                    body="HubSpot, Pipedrive, Salesforce nebo vlastní systém. Vše na jednom místě, dashboard, který dává smysl."
                />
                <RevealCard
                    num="04"
                    title="INTEGRACE"
                    body="Slack, Notion, Google Workspace, Microsoft 365. Co máte, propojíme. Nic nebouráme, nic neměníme zadarmo."
                />
            </Features>
        </div>
    </section>

    <!-- Sekce 5 — Jak to děláme (3 kroky, sjednoceno) -->
    <section>
        <div class="container">
            <SectionHead
                eyebrow="· 04 · JAK TO DĚLÁME"
                title="Tři kroky. Žádné pilotní fáze."
                lead="Začínáme tím, že posloucháme. Končíme tím, že to běží."
            />
            <Steps cols={3}>
                <Step num="01" title="POSLOUCHÁME" body="Diagnostika. Pochopíme, co vás brzdí." />
                <Step num="02" title="STAVÍME"     body="Návrh, integrace, nasazení. Do 4 týdnů." />
                <Step num="03" title="STARÁME SE"  body="Provoz, dohled, ladění. Dokud to dává smysl." />
            </Steps>
        </div>
    </section>

    <!-- Sekce 6 — Investice (kompaktní) -->
    <section>
        <div class="container container--narrow">
            <SectionHead
                eyebrow="· 05 · INVESTICE"
                title="Fixní cena. Smluvně. Bez překvapení."
            />
            <div class="invest-block">
                <p>
                    Cena se odvíjí od rozsahu. Fixní balíček plus měsíční provoz.
                    Nasazení 4 týdny, garance ROI 6 měsíců — pokud ne, vrátíme.
                </p>
                <p>Granty a dotace prozkoumáme za vás. Z přípravy až po čerpání.</p>
                <p class="invest-block__cta">
                    <a href="/diagnostika">Konkrétní cenu zjistíte v diagnostice →</a>
                </p>
            </div>
        </div>
    </section>

    <!-- Sekce 7 — Příběh klienta (1 reveal full-width) -->
    <section>
        <div class="container container--narrow">
            <SectionHead
                eyebrow="· 06 · PŘÍKLAD Z PRAXE"
                title="Jak to vypadá, když to běží."
            />

            <article class="case-reveal">
                <button class="case-reveal__btn" type="button" aria-expanded="false">
                    <span class="case-reveal__eyebrow">· Anonymizováno · zdravotnictví</span>
                    <h3 class="case-reveal__title">Síť 4 dermatologických ordinací. <span class="case-reveal__metric">−84 %</span> administrativy na pacienta.</h3>
                    <p class="case-reveal__teaser">
                        Před nasazením: 3,5 osoby na recepci. Po: agent vyřídí 84 % komunikace, lékař diktuje, systém strukturuje zdravotní kartu.
                    </p>
                    <span class="case-reveal__more">Více o případu →</span>
                    <div class="case-reveal__detail">
                        <p>
                            <strong>Před nasazením.</strong> Recepce zvedala telefon, objednávala, posílala
                            připomínky, vyřizovala výsledky. Lékař diktoval do mikrofonu a sestra to v pauzách
                            přepisovala do karty. Den končil tím, že někdo seděl o hodinu déle.
                        </p>
                        <p>
                            <strong>Co jsme postavili.</strong> Hlasový agent na recepci pro standardní dotazy
                            a objednávání. E-mailový asistent pro výsledky a připomínky. Diktovací pipeline,
                            která z nahrávky lékaře vygeneruje strukturovanou kartu, kódy MKN-10 a podklad pro
                            pojišťovnu — připravené ke kontrole a podpisu.
                        </p>
                        <p>
                            <strong>Stav po šesti týdnech.</strong> Recepce uvolněna na klientskou péči, ne na
                            administrativu. Lékař má dvě hodiny denně zpátky u pacientů. Doba dokumentace na
                            jednoho pacienta klesla z 25 minut na 4. ROI první kvartál.
                        </p>
                    </div>
                </button>
            </article>
        </div>
    </section>

    <!-- Sekce 8 — Final CTA -->
    <CtaBand
        id="zacit"
        eyebrow="· Začněme"
        title="Přijímáme omezený počet firem ročně. Diagnostika rozhodne."
        lead="Žádný obchodník. Žádná prezentace. Krátký rozhovor — a víte, jestli vám pomůžeme."
        directPrefix="Nebo napište přímo:"
    >
        <a href="/diagnostika" class="btn btn--primary btn-arrow btn--lg">Spustit diagnostiku →</a>
    </CtaBand>

</Layout>

<style>
    /* Sekce 3 — line-list (3 řádky bez karet) */
    .line-list {
        margin: var(--space-12) 0 0;
        padding: 0;
    }

    .line-list__row {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1.4fr);
        gap: var(--space-6);
        align-items: baseline;
        padding: var(--space-5) 0;
        border-bottom: 1px solid var(--border-soft);
    }

    .line-list__row:first-of-type {
        border-top: 1px solid var(--border-soft);
    }

    .line-list__row dt {
        display: flex;
        gap: var(--space-3);
        align-items: baseline;
        margin: 0;
    }

    .line-list__num {
        font-family: var(--font-mono);
        font-size: 0.78rem;
        color: var(--text-muted);
        font-weight: 500;
        transition: color 0.2s ease;
    }

    .line-list__label {
        font-family: var(--font-mono);
        font-size: 0.92rem;
        letter-spacing: 0.06em;
        color: var(--text-primary);
        font-weight: 600;
    }

    .line-list__row dd {
        margin: 0;
        color: var(--text-secondary);
        font-size: 1rem;
        line-height: 1.55;
    }

    @media (hover: hover) {
        .line-list__row:hover .line-list__num { color: var(--accent); }
    }

    @media (max-width: 720px) {
        .line-list__row { grid-template-columns: 1fr; gap: var(--space-2); padding: var(--space-4) 0; }
    }

    /* Sekce 6 — Investice */
    .invest-block {
        margin-top: var(--space-8);
    }

    .invest-block p {
        font-size: 1.05rem;
        line-height: 1.65;
        color: var(--text-secondary);
        margin: 0 0 var(--space-4);
        max-width: 60ch;
    }

    .invest-block__cta {
        margin-top: var(--space-6) !important;
        font-family: var(--font-mono);
        font-size: 0.85rem;
        letter-spacing: 0.04em;
    }

    .invest-block__cta a {
        color: var(--accent);
        border-bottom: 1px solid transparent;
        transition: border-color 0.2s ease;
    }

    .invest-block__cta a:hover {
        border-bottom-color: var(--accent);
    }

    /* Sekce 7 — Case reveal (full-width) */
    .case-reveal {
        margin-top: var(--space-10);
    }

    .case-reveal__btn {
        width: 100%;
        text-align: left;
        background: var(--surface-card);
        border: 1px solid var(--border-soft);
        border-radius: var(--radius-lg);
        padding: var(--space-10) var(--space-10);
        display: flex;
        flex-direction: column;
        gap: var(--space-4);
        font-family: inherit;
        color: inherit;
        cursor: pointer;
        transition: border-color 0.25s ease,
                    transform 0.35s cubic-bezier(0.16, 1, 0.3, 1),
                    box-shadow 0.25s ease;
    }

    .case-reveal__btn:hover {
        border-color: var(--border-emphasis);
        transform: translateY(-2px);
        box-shadow: 0 10px 40px rgba(11, 15, 25, 0.05);
    }

    .case-reveal__eyebrow {
        font-family: var(--font-mono);
        font-size: 0.72rem;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--text-muted);
    }

    .case-reveal__title {
        font-size: clamp(1.4rem, 2.5vw, 1.9rem);
        font-weight: 600;
        letter-spacing: -0.02em;
        color: var(--text-primary);
        margin: 0;
        line-height: 1.25;
    }

    .case-reveal__metric {
        color: var(--accent);
        font-weight: 700;
    }

    .case-reveal__teaser {
        font-size: 1.05rem;
        line-height: 1.6;
        color: var(--text-secondary);
        margin: 0;
        max-width: 64ch;
    }

    .case-reveal__more {
        font-family: var(--font-mono);
        font-size: 0.78rem;
        letter-spacing: 0.04em;
        color: var(--accent);
        margin-top: var(--space-2);
    }

    .case-reveal__detail {
        max-height: 0;
        overflow: hidden;
        opacity: 0;
        transform: translateY(-6px);
        transition: max-height 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                    opacity 0.4s ease,
                    transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .case-reveal__detail p {
        font-size: 1rem;
        line-height: 1.65;
        color: var(--text-secondary);
        margin: 0 0 var(--space-3);
    }

    .case-reveal__detail p:last-child { margin-bottom: 0; }

    @media (hover: hover) {
        .case-reveal__btn:hover .case-reveal__detail,
        .case-reveal__btn[aria-expanded="true"] .case-reveal__detail {
            max-height: 800px;
            opacity: 1;
            transform: translateY(0);
            margin-top: var(--space-4);
        }
        .case-reveal__btn:hover .case-reveal__more,
        .case-reveal__btn[aria-expanded="true"] .case-reveal__more {
            opacity: 0;
        }
    }

    @media (hover: none) {
        .case-reveal__btn[aria-expanded="true"] .case-reveal__detail {
            max-height: 800px;
            opacity: 1;
            transform: translateY(0);
            margin-top: var(--space-4);
        }
        .case-reveal__btn[aria-expanded="true"] .case-reveal__more {
            display: none;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .case-reveal__btn,
        .case-reveal__detail { transition: none !important; }
        .case-reveal__btn:hover { transform: none !important; }
        .case-reveal__detail {
            max-height: none;
            opacity: 1;
            transform: none;
            margin-top: var(--space-4);
        }
        .case-reveal__more { display: none; }
    }
</style>

<script>
    // Tap-to-expand pro case-reveal na non-hover zařízeních
    document.addEventListener('click', (e) => {
        const target = e.target;
        if (!target || !(target instanceof Element)) return;
        const btn = target.closest('.case-reveal__btn');
        if (!btn) return;
        const hoverable = window.matchMedia('(hover: hover)').matches;
        if (hoverable) return;
        const expanded = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', expanded ? 'false' : 'true');
    });
</script>
