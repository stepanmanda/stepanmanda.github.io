---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import SectionHead from '../../components/SectionHead.astro';
import Features from '../../components/Features.astro';
import Feature from '../../components/Feature.astro';
import Callout from '../../components/Callout.astro';
import AgentDiagnostic from '../../components/AgentDiagnostic.astro';
---

<Layout
    title="VELYOS — Kontakt | Drei Wege zum Anfang."
    description="Drei Wege, VELYOS zu erreichen: KI-Diagnose-Agent, E-Mail, Telefon. Wir antworten innerhalb von 24 Stunden. Kein Vertrieb. Keine Präsentation."
    lang="de"
    active="kontakt"
    primaryCta={null}
    footerTagline="Kein Vertrieb. Keine Präsentation."
    footerVariant="v0.3 preview · Kontakt"
>
    <Hero tagline="· Kontakt · Wir definieren den Vorsprung.">
        <h1 class="hero__title">Drei Wege. <span class="accent">Antwort in 24 Stunden.</span></h1>
        <p class="hero__lead">
            Agent, E-Mail oder Telefon. Kein Vertrieb. Keine Präsentation. Kein „Formular ausfüllen, wir rufen zurück".
            Wählen Sie, was Ihnen passt — wir kümmern uns um den Rest.
        </p>
    </Hero>

    <section>
        <div class="container">
            <SectionHead
                eyebrow="· 02 · Wählen Sie den Weg"
                title="Drei Arten, das Gespräch zu beginnen."
                lead="Jeder Weg endet beim selben Spezialisten. Der einzige Unterschied ist, wie viel Zeit Sie am Anfang investieren."
            />

            <Features cols={3}>
                <Feature
                    num="Am schnellsten"
                    title="KI-Diagnose-Agent"
                    body="Sprachgespräch mit unserer Stela. 5–7 Minuten, natürlicher Ton, kein Formular. Ein Spezialist ruft innerhalb von 24 Stunden mit einem Briefing an. Unten starten →"
                />
                <Feature
                    num="Am bequemsten"
                    title="E-Mail"
                    body="Eine kurze Nachricht. Zwei Sätze zur Situation. Wir antworten innerhalb von 24 Stunden mit konkreten nächsten Schritten — keine Präsentation."
                />
                <Feature
                    num="Am persönlichsten"
                    title="Telefon"
                    body="Nummer verfügbar nach Firmenregistrierung. Bis dahin rufen wir nach E-Mail oder Formular zurück — meist innerhalb eines Werktags."
                />
            </Features>
        </div>
    </section>

    <AgentDiagnostic agentId="cu9gllbBtpZWU6CuJXky" lang="de" />

    <section class="section--alt">
        <div class="container">
            <SectionHead
                eyebrow="· 03 · Direkte Kanäle"
                title="Vertrieb, Spezialist und Gründer."
                lead="Wenn Sie wissen, mit wem Sie sprechen wollen, schreiben Sie direkt. Jeder Kanal hat einen klaren Verantwortlichen. Keine Weiterleitungen."
            />

            <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(260px, 1fr)); gap:var(--space-8); margin-top:var(--space-10);" data-stagger>
                <div style="padding:var(--space-8); background:var(--surface-card); border:1px solid var(--border-soft); border-radius:var(--radius-lg); border-top:3px solid var(--velocity-orange);">
                    <span class="eyebrow" style="color:var(--velocity-orange);">Vertrieb &amp; Diagnose</span>
                    <h3 style="margin-top:var(--space-3); margin-bottom:var(--space-4);">Štěpán Manda</h3>
                    <p style="color:var(--text-secondary); margin-bottom:var(--space-6);">Gründer &amp; CEO. Übernimmt jeden neuen Kunden persönlich — Ihr erstes Gespräch geht direkt zum Gründer.</p>
                    <p style="line-height:2; margin:0;">
                        <a href="mailto:stepan@velyos.ai" style="color:var(--text-primary); border-bottom:1px solid var(--gold-30); font-weight:500;">stepan@velyos.ai</a><br>
                        <span style="color:var(--mist-gray); font-size:0.9rem; font-style:italic;">Telefonnummer nach Firmenregistrierung verfügbar.</span>
                    </p>
                </div>

                <div style="padding:var(--space-8); background:var(--surface-card); border:1px solid var(--border-soft); border-radius:var(--radius-lg); border-top:3px solid var(--signal-gold);">
                    <span class="eyebrow" style="color:var(--signal-gold);">Medien &amp; Partner</span>
                    <h3 style="margin-top:var(--space-3); margin-bottom:var(--space-4);">Kooperation, PR, Investoren</h3>
                    <p style="color:var(--text-secondary); margin-bottom:var(--space-6);">Presseanfragen, Interviewanfragen, Partnerinitiativen, Investorenanfragen.</p>
                    <p style="line-height:2; margin:0;">
                        <a href="mailto:hello@velyos.ai" style="color:var(--text-primary); border-bottom:1px solid var(--gold-30); font-weight:500;">hello@velyos.ai</a><br>
                        <span style="color:var(--mist-gray); font-size:0.9rem; font-style:italic;">LinkedIn nach Registrierung.</span>
                    </p>
                </div>
            </div>
        </div>
    </section>

    <section>
        <div class="container container--narrow">
            <SectionHead
                eyebrow="· 04 · Zeit und Ort"
                title="Wo Sie uns finden und wann wir antworten."
            />

            <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(260px, 1fr)); gap:var(--space-10); margin-top:var(--space-8);" data-stagger>
                <div>
                    <span class="eyebrow" style="color:var(--signal-gold);">Sitz</span>
                    <p style="margin-top:var(--space-3); font-size:1.1rem; line-height:1.6;">
                        <strong>VELYOS</strong><br>
                        Františkovy Lázně 553/7<br>
                        351 01 Františkovy Lázně<br>
                        <span style="color:var(--text-secondary); font-size:0.95rem;">Tschechische Republik</span>
                    </p>
                </div>
                <div>
                    <span class="eyebrow" style="color:var(--signal-gold);">Arbeitszeiten</span>
                    <p style="margin-top:var(--space-3); font-size:1.1rem; line-height:1.6;">
                        Montag–Freitag, 9:00–17:00 MEZ<br>
                        <span style="color:var(--text-secondary); font-size:0.95rem;">
                            E-Mail-Antwort: <strong>innerhalb 24 Stunden</strong><br>
                            Telefonnummer nach Firmenregistrierung verfügbar
                        </span>
                    </p>
                </div>
            </div>
        </div>
    </section>

    <section class="section--editorial">
        <div class="container container--narrow">
            <SectionHead
                eyebrow="· 05 · Für Lieferanten und Karriere"
                title="Arbeiten Sie mit uns — oder wollen Sie?"
            />

            <div class="section-body" data-reveal>
                <p>
                    <strong>Lieferanten und Subunternehmer:</strong> Wir arbeiten nur mit geprüften Partnern, die eine Erfolgsbilanz haben und pünktlich liefern. Schreiben Sie kurz: Fachgebiet, Spezialisierung, Referenzen.
                    Wir antworten innerhalb einer Woche.
                </p>
                <p>
                    <strong>Karriere:</strong> Wir sind nicht das Team, das Juniors sammelt. Wir stellen Senior-Spezialisten mit mindestens 5 Jahren Berufserfahrung ein —
                    Bau, Entwicklung, Analytik, Design. Wir suchen Menschen, die bereits können, nicht die, die noch lernen. Wenn das Sie sind, schreiben Sie direkt an Štěpán.
                </p>
            </div>
        </div>
    </section>

    <section>
        <div class="container container--narrow">
            <SectionHead
                eyebrow="· 06 · Häufigste Fragen"
                title="Antworten, bevor Sie fragen."
            />

            <div class="section-body" data-reveal>
                <h3>Was kostet es?</h3>
                <p style="color:var(--text-secondary);">
                    Keine öffentliche Preisliste. Jedes Projekt ist anders — je nachdem, was wir bauen, an was wir anbinden und wie viele Menschen es betrifft.
                    Eine konkrete Kalkulation bekommen Sie nach dem ersten Gespräch, nicht aus einem Formular.
                </p>

                <h3>Wie lange dauert der Einsatz?</h3>
                <p style="color:var(--text-secondary);">
                    Typischerweise 4 Wochen von der Vertragsunterschrift bis zum Live-Betrieb. Kleinere Projekte schneller, komplexe Fälle bis 6 Wochen. Geschwindigkeit ist unser Prinzip —
                    ausgedehnte Projekte interessieren uns nicht.
                </p>

                <h3>Was, wenn es nicht funktioniert?</h3>
                <p style="color:var(--text-secondary);">
                    In unserem Vertrag steht eine ROI-Garantie innerhalb von 6 Monaten. Liefern wir nicht, arbeiten wir kostenlos weiter oder erstatten die Differenz. Sie haben nichts zu verlieren.
                </p>

                <h3>Wer hat Zugriff auf die Daten?</h3>
                <p style="color:var(--text-secondary);">
                    Nur unser Team und die von Ihnen freigegebenen Systeme. AES-256-Verschlüsselung, DSGVO, Architektur nach ISO-27001-Prinzipien.
                    Wir nutzen Ihre Daten niemals zum Training fremder Modelle.
                </p>

                <h3>Was, wenn wir die Zusammenarbeit beenden — stehen wir dann allein da?</h3>
                <p style="color:var(--text-secondary);">
                    Nein. Alles, was wir bauen, ist so konzipiert, dass es auch ohne uns funktioniert. Wir nutzen Standard-Tools und liefern vollständige Dokumentation.
                    Bei Beendigung bekommen Sie ein <strong>Übergabedokument</strong>: Zugangsdaten, Architekturbeschreibung, Kontakte zu Integratoren.
                    Kurze Kündigungsfrist — kein Vendor-Lock-in, keine Strafgebühren.
                </p>

                <h3>Kann ich VELYOS zu einem Treffen einladen?</h3>
                <p style="color:var(--text-secondary);">
                    Ja, wenn Sie ernsthaft interessiert sind und mindestens eine kurze Agent-Diagnose oder E-Mail hinter sich haben. Nicht, weil wir zu beschäftigt wären —
                    sondern damit Sie vom ersten Treffen einen Mehrwert haben, keine Präsentation.
                </p>
            </div>
        </div>
    </section>

    <section class="section--alt section--tight">
        <div class="container container--narrow">
            <Callout>
                <strong>Noch nicht sicher, ob VELYOS passt?</strong>
                Der schnellste Weg sind 5 Minuten mit unserem Agenten oben. Er sagt Ihnen, ob wir zu Ihnen passen — und wenn nicht, sagt er es ehrlich.
            </Callout>
        </div>
    </section>
</Layout>
