---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import SectionHead from '../components/SectionHead.astro';
import Features from '../components/Features.astro';
import Feature from '../components/Feature.astro';
import Callout from '../components/Callout.astro';
import AgentDiagnostic from '../components/AgentDiagnostic.astro';
---

<Layout
    title="VELYOS — Kontakt | Tři cesty, jak začít."
    description="Tři způsoby, jak kontaktovat VELYOS: AI diagnostický agent, e-mail, telefon. Odpovídáme do 24 hodin. Bez obchodníka, bez prezentace."
    active="kontakt"
    primaryCta={null}
    footerTagline="Bez obchodníka. Bez prezentace."
    footerVariant="v0.2 preview · kontakt"
>
    <Hero tagline="· Kontakt · Definujeme náskok.">
        <h1 class="hero__title">Tři způsoby. <span class="accent">Odpovídáme do 24 hodin.</span></h1>
        <p class="hero__lead">
            Agentem, e-mailem nebo telefonem. Bez obchodníka. Bez prezentací. Bez „vyplňte formulář, zavoláme vám".
            Vyberte si, co vám vyhovuje — my se postaráme o zbytek.
        </p>
    </Hero>

    <section>
        <div class="container">
            <SectionHead
                eyebrow="· 02 · Vyberte cestu"
                title="Tři způsoby, jak začít rozhovor."
                lead="Každá cesta končí u stejného specialisty. Liší se jen tím, kolik na začátku investujete času."
            />

            <Features cols={3}>
                <Feature
                    num="Nejrychlejší"
                    title="AI diagnostický agent"
                    body="Hlasový rozhovor s naší Stelou. 5–7 minut, přirozený tón, žádné formuláře. Specialista vám zavolá do 24 hodin s briefem. Spusťte níž →"
                />
                <Feature
                    num="Nejpohodlnější"
                    title="E-mail"
                    body="Krátká zpráva. Popište situaci ve dvou větách. Odpovíme do 24 hodin konkrétními dalšími kroky — ne prezentací."
                />
                <Feature
                    num="Nejosobnější"
                    title="Telefon"
                    body="Číslo doplníme po registraci firmy. Do té doby vás po e-mailu či formuláři sami zavoláme zpět — obvykle do jednoho pracovního dne."
                />
            </Features>
        </div>
    </section>

    <AgentDiagnostic agentId="cu9gllbBtpZWU6CuJXky" />

    <section class="section--alt">
        <div class="container">
            <SectionHead
                eyebrow="· 03 · Přímé kanály"
                title="Kontakt na obchod, specialistu, a zakladatele."
                lead="Pokud víte, s kým chcete mluvit, napište rovnou. Každý kanál má jasného vlastníka, žádné přepojování."
            />

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:var(--space-8); margin-top:var(--space-10);" data-stagger>
                <div style="padding:var(--space-8); background:var(--alpine-white); border:1px solid var(--black-08); border-radius:var(--radius-lg); border-top:3px solid var(--velocity-orange);">
                    <span class="eyebrow" style="color:var(--velocity-orange);">Obchod &amp; diagnostika</span>
                    <h3 style="margin-top:var(--space-3); margin-bottom:var(--space-4);">Štěpán Manda</h3>
                    <p style="color:var(--black-60); margin-bottom:var(--space-6);">Founder &amp; CEO. Bere osobně každého nového klienta — první call jdete přímo se zakladatelem.</p>
                    <p style="line-height:2; margin:0;">
                        <a href="mailto:stepan@velyos.ai" style="color:var(--velocity-black); border-bottom:1px solid var(--gold-30); font-weight:500;">stepan@velyos.ai</a><br>
                        <span style="color:var(--mist-gray); font-size:0.9rem; font-style:italic;">Telefon doplníme po registraci firmy.</span>
                    </p>
                </div>

                <div style="padding:var(--space-8); background:var(--alpine-white); border:1px solid var(--black-08); border-radius:var(--radius-lg); border-top:3px solid var(--signal-gold);">
                    <span class="eyebrow" style="color:var(--signal-gold);">Médii &amp; partneři</span>
                    <h3 style="margin-top:var(--space-3); margin-bottom:var(--space-4);">Spolupráce, PR, investoři</h3>
                    <p style="color:var(--black-60); margin-bottom:var(--space-6);">Novinářské dotazy, žádosti o rozhovor, partnerské iniciativy, investorské dotazy.</p>
                    <p style="line-height:2; margin:0;">
                        <a href="mailto:hello@velyos.ai" style="color:var(--velocity-black); border-bottom:1px solid var(--gold-30); font-weight:500;">hello@velyos.ai</a><br>
                        <span style="color:var(--mist-gray); font-size:0.9rem; font-style:italic;">LinkedIn po registraci firmy.</span>
                    </p>
                </div>
            </div>
        </div>
    </section>

    <section>
        <div class="container container--narrow">
            <SectionHead
                eyebrow="· 04 · Čas a místo"
                title="Kde nás najdete a kdy odpovídáme."
            />

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:var(--space-10); margin-top:var(--space-8);" data-stagger>
                <div>
                    <span class="eyebrow" style="color:var(--signal-gold);">Sídlo</span>
                    <p style="margin-top:var(--space-3); font-size:1.1rem; line-height:1.6;">
                        <strong>VELYOS</strong><br>
                        Františkovy Lázně 553/7<br>
                        351 01 Františkovy Lázně<br>
                        <span style="color:var(--black-60); font-size:0.95rem;">Česká republika</span>
                    </p>
                </div>
                <div>
                    <span class="eyebrow" style="color:var(--signal-gold);">Pracovní doba</span>
                    <p style="margin-top:var(--space-3); font-size:1.1rem; line-height:1.6;">
                        Pondělí–pátek, 9:00–17:00 CET<br>
                        <span style="color:var(--black-60); font-size:0.95rem;">
                            E-mail odpovědi: <strong>do 24 hodin</strong><br>
                            Telefonní číslo doplníme po registraci firmy
                        </span>
                    </p>
                </div>
            </div>
        </div>
    </section>

    <section class="section--editorial">
        <div class="container container--narrow">
            <SectionHead
                eyebrow="· 05 · Pro dodavatele a kariéru"
                title="Spolupracujete s námi, nebo chcete?"
            />

            <div class="section-body" data-reveal>
                <p>
                    <strong>Dodavatelé a subdodavatelé:</strong> Hledáme jen ověřené partnery s doloženou historií a schopností dodat v čase. Napište nám stručně: obor, specializace, reference.
                    Odpovídáme do týdne.
                </p>
                <p>
                    <strong>Kariéra:</strong> Nejsme tým, který sbírá juniory. Přijímáme seniorní specialisty s minimálně 5 lety praxe v oboru —
                    stavba, vývoj, analytika, design. Hledáme lidi, kteří už umí, ne ty, co se teprve učí. Pokud to jste vy, napište rovnou Štěpánovi.
                </p>
            </div>
        </div>
    </section>

    <section>
        <div class="container container--narrow">
            <SectionHead
                eyebrow="· 06 · Nejčastější otázky"
                title="Odpovědi, než se zeptáte."
            />

            <div class="section-body" data-reveal>
                <h3>Kolik to stojí?</h3>
                <p style="color:var(--black-60);">
                    Nemáme veřejný ceník. Každý projekt je jiný — záleží, co stavíme, na co napojujeme a kolik lidí se ho dotýká.
                    Konkrétní kalkulaci dostanete po prvním hovoru, ne z dotazníku.
                </p>

                <h3>Jak dlouho trvá nasazení?</h3>
                <p style="color:var(--black-60);">
                    Typicky 4 týdny od podpisu smlouvy do ostrého provozu. Menší projekty rychleji, komplexní případy do 6 týdnů. Rychlost je náš princip —
                    rozvleklé projekty nás nezajímají.
                </p>

                <h3>Co když to nebude fungovat?</h3>
                <p style="color:var(--black-60);">
                    Ve smlouvě máme garanci návratnosti do 6 měsíců. Pokud nedodáme, doděláme zdarma nebo vrátíme rozdíl. Nemáte co ztratit.
                </p>

                <h3>Kdo má k datům přístup?</h3>
                <p style="color:var(--black-60);">
                    Jen náš tým a vámi schválené systémy. Šifrování AES-256, GDPR, architektura v duchu ISO 27001.
                    Vaše data nikdy nepoužíváme k tréninku cizích modelů.
                </p>

                <h3>Co když s vámi ukončíme spolupráci — zůstaneme na tom sami?</h3>
                <p style="color:var(--black-60);">
                    Ne. Všechna nasazení stavíme tak, aby fungovala i bez nás. Používáme standardní nástroje a dodáváme kompletní dokumentaci.
                    Při ukončení dostanete <strong>předávací dokument</strong>: přihlašovací údaje, popis architektury, kontakty na integrátory.
                    Krátká výpovědní lhůta — žádný vendor lock-in, žádné penalizace.
                </p>

                <h3>Můžu VELYOS pozvat na schůzku?</h3>
                <p style="color:var(--black-60);">
                    Ano, pokud jste vážný zájemce a prošli jste alespoň krátkým agent diagnosticem nebo e-mailem. Ne proto, že jsme zaneprázdnění —
                    ale abyste od prvního setkání dostali hodnotu, ne prezentaci.
                </p>
            </div>
        </div>
    </section>

    <section class="section--alt section--tight">
        <div class="container container--narrow">
            <Callout>
                <strong>Ještě nevíte, jestli VELYOS dává smysl?</strong>
                Nejrychlejší způsob je 5 minut s naším agentem výše. Zjistí, jestli jsme pro vás — a pokud ne, upřímně vám to řekne.
            </Callout>
        </div>
    </section>
</Layout>
