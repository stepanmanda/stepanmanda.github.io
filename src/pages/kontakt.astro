---
import Layout from '../layouts/Layout.astro';
import Features from '../components/Features.astro';
import RevealCard from '../components/RevealCard.astro';

const faqs = [
    {
        q: 'Kolik to stojí?',
        a: 'Nemáme veřejný ceník. Každý projekt je jiný — záleží, co stavíme, na co se napojujeme a kolik lidí se ho dotýká. Konkrétní kalkulaci dostanete po prvním hovoru, ne z dotazníku.',
    },
    {
        q: 'Jak dlouho trvá nasazení?',
        a: 'Typicky 4 týdny od podpisu smlouvy do ostrého provozu. Menší projekty rychleji, komplexní případy do 6 týdnů. Rychlost je princip — rozvleklé projekty nás nezajímají.',
    },
    {
        q: 'Co když to nebude fungovat?',
        a: 'Ve smlouvě máme garanci návratnosti do 6 měsíců. Pokud nedodáme, doděláme zdarma nebo vrátíme rozdíl.',
    },
    {
        q: 'Co s mými daty?',
        a: 'Jen náš tým a vámi schválené systémy. Šifrování AES-256, GDPR, architektura v duchu ISO 27001. Vaše data nikdy nepoužíváme k tréninku cizích modelů.',
    },
    {
        q: 'Jsem na Vás zamčený?',
        a: 'Ne. Všechna nasazení stavíme tak, aby fungovala i bez nás. Používáme standardní nástroje a při ukončení dostanete předávací dokument: přihlašovací údaje, popis architektury, kontakty na integrátory. Krátká výpovědní lhůta. Žádné penalizace.',
    },
    {
        q: 'Můžeme se sejít osobně?',
        a: 'Ano. Sídlo je ve Františkových Lázních, ale pracujeme po celé ČR — můžeme přijet k Vám. Pokud rozumíte byznysu, který chceme automatizovat, je to levnější pro obě strany.',
    },
];
---

<Layout
    title="VELYOS — Kontakt"
    description="Tři způsoby, jak nás zastihnout: diagnostika, e-mail, telefon. Odpovídáme do 24 hodin. Bez obchodníka, bez prezentace."
    active="kontakt"
    primaryCta={null}
    footerTagline="Bez obchodníka. Bez prezentace."
>

    <!-- Sekce 1 — Hero kompaktní -->
    <section class="contact-hero">
        <div class="contact-hero__glow" aria-hidden="true"></div>
        <div class="container">
            <div class="contact-hero__inner">
                <span class="eyebrow">· KONTAKT</span>
                <h1 class="contact-hero__title">Tři způsoby, jak nás zastihnout.</h1>
                <p class="contact-hero__lead">Vyberte si, co Vám sedí. My to bereme rychle.</p>
            </div>
        </div>
    </section>

    <!-- Sekce 2 — Tři cesty (3 reveal cards) -->
    <section>
        <div class="container">
            <Features cols={3}>
                <RevealCard
                    num="01"
                    title="DIAGNOSTIKA"
                    body={`5 minut formulář, nebo 15 minut hovor s naším agentem. Pro Vás, pokud chcete strukturu. <a href="/diagnostika">Spustit diagnostiku →</a>`}
                />
                <RevealCard
                    num="02"
                    title="E-MAIL"
                    body={`Pište přímo Štěpánovi. Odpovídá do 24 hodin. <a href="mailto:stepan@velyos.ai">stepan@velyos.ai</a>`}
                />
                <RevealCard
                    num="03"
                    title="TELEFON"
                    body={`Po–Pá 9–17. Po 20:00 výjimečně. <span class="contact-pending">Číslo doplníme po registraci firmy.</span>`}
                />
            </Features>
        </div>
    </section>

    <!-- Sekce 3 — Čas a místo (1 odstavec, žádné karty) -->
    <section class="contact-where">
        <div class="container container--narrow">
            <span class="eyebrow">· KDE JSME</span>
            <h2 class="contact-where__title">Františkovy Lázně. Domluvit se dá i ve Vaší firmě.</h2>
            <p class="contact-where__body">
                Sídlo je ve Františkových Lázních. Pracujeme po celé ČR — vždy můžeme přijet
                k Vám. Když rozumíte byznysu, který chcete automatizovat, je to levnější pro
                obě strany. Pracovní doba: Po–Pá 9:00–17:00 (CET).
            </p>
        </div>
    </section>

    <!-- Sekce 4 — FAQ (native <details> accordion) -->
    <section>
        <div class="container container--narrow">
            <div class="contact-faq-head">
                <span class="eyebrow">· ČASTÉ OTÁZKY</span>
                <h2>Než se zeptáte.</h2>
            </div>
            <div class="contact-faq">
                {faqs.map((item) => (
                    <details class="faq-item">
                        <summary class="faq-item__summary">
                            <span class="faq-item__q">{item.q}</span>
                            <span class="faq-item__icon" aria-hidden="true">+</span>
                        </summary>
                        <div class="faq-item__answer">
                            <p>{item.a}</p>
                        </div>
                    </details>
                ))}
            </div>
        </div>
    </section>

    <!-- Sekce 5 — Final CTA (kompaktní, bez glow) -->
    <section class="contact-final">
        <div class="container container--narrow">
            <h2 class="contact-final__title">Pořád nevíte, kam dál?</h2>
            <a href="/diagnostika" class="btn btn--primary btn-arrow btn--lg">Začněte diagnostikou →</a>
        </div>
    </section>

</Layout>

<style>
    /* Hero kompaktní */
    .contact-hero {
        position: relative;
        padding: var(--space-16) 0 var(--space-10);
        overflow: hidden;
        text-align: center;
        border-bottom: 1px solid var(--border-soft);
    }

    .contact-hero__glow {
        position: absolute;
        top: -180px;
        left: 20%;
        width: 600px;
        height: 360px;
        background: radial-gradient(circle, rgba(184, 147, 92, 0.18), transparent 65%);
        pointer-events: none;
        filter: blur(50px);
    }

    [data-theme="dark"] .contact-hero__glow {
        background: radial-gradient(circle, rgba(184, 147, 92, 0.32), transparent 65%);
    }

    .contact-hero .container { position: relative; z-index: 1; }

    .contact-hero__inner {
        max-width: 56ch;
        margin: 0 auto;
    }

    .contact-hero__inner .eyebrow {
        display: block;
        margin-bottom: var(--space-3);
        color: var(--signal-gold);
    }

    .contact-hero__title {
        font-size: clamp(2rem, 4vw, 3rem);
        letter-spacing: -0.04em;
        line-height: 1.1;
        font-weight: 700;
        margin: 0 0 var(--space-4);
        color: var(--text-primary);
    }

    .contact-hero__lead {
        font-size: 1.15rem;
        line-height: 1.55;
        color: var(--text-secondary);
        margin: 0;
    }

    /* RevealCard pending text */
    :global(.contact-pending) {
        display: block;
        margin-top: 0.5rem;
        font-style: italic;
        color: var(--text-muted);
        font-size: 0.9rem;
    }

    /* Sekce 3 — Kde jsme */
    .contact-where {
        padding: var(--space-16) 0;
    }

    .contact-where .eyebrow {
        display: block;
        margin-bottom: var(--space-3);
        color: var(--signal-gold);
    }

    .contact-where__title {
        font-size: clamp(1.6rem, 3vw, 2.2rem);
        letter-spacing: -0.02em;
        margin: 0 0 var(--space-4);
        color: var(--text-primary);
        line-height: 1.2;
    }

    .contact-where__body {
        font-size: 1.05rem;
        line-height: 1.65;
        color: var(--text-secondary);
        max-width: 60ch;
        margin: 0;
    }

    /* Sekce 4 — FAQ */
    .contact-faq-head {
        margin-bottom: var(--space-10);
    }

    .contact-faq-head .eyebrow {
        display: block;
        margin-bottom: var(--space-3);
        color: var(--signal-gold);
    }

    .contact-faq-head h2 {
        font-size: clamp(1.6rem, 3vw, 2.2rem);
        letter-spacing: -0.02em;
        margin: 0;
        color: var(--text-primary);
    }

    .contact-faq {
        border-top: 1px solid var(--border-soft);
    }

    .faq-item {
        border-bottom: 1px solid var(--border-soft);
    }

    .faq-item__summary {
        list-style: none;
        cursor: pointer;
        padding: var(--space-5) 0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--space-4);
        font-family: var(--font-sans);
        transition: color 0.2s ease;
    }

    .faq-item__summary::-webkit-details-marker { display: none; }

    .faq-item__q {
        font-size: 1.05rem;
        font-weight: 600;
        color: var(--text-primary);
        letter-spacing: -0.01em;
        line-height: 1.4;
    }

    .faq-item__icon {
        font-family: var(--font-mono);
        font-size: 1.4rem;
        color: var(--accent);
        font-weight: 400;
        flex-shrink: 0;
        transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1);
        line-height: 1;
    }

    .faq-item[open] .faq-item__icon {
        transform: rotate(45deg);
    }

    .faq-item__summary:hover .faq-item__q {
        color: var(--accent);
    }

    .faq-item__answer {
        padding: 0 0 var(--space-5);
        max-width: 60ch;
    }

    .faq-item__answer p {
        margin: 0;
        font-size: 1rem;
        line-height: 1.65;
        color: var(--text-secondary);
    }

    /* Sekce 5 — Final CTA kompaktní */
    .contact-final {
        padding: var(--space-16) 0 var(--space-24);
        text-align: center;
        border-top: 1px solid var(--border-soft);
    }

    .contact-final__title {
        font-size: clamp(1.6rem, 3vw, 2.2rem);
        letter-spacing: -0.02em;
        margin: 0 0 var(--space-6);
        color: var(--text-primary);
    }

    @media (prefers-reduced-motion: reduce) {
        .faq-item__icon { transition: none !important; }
    }
</style>
