---
import Layout from '../layouts/Layout.astro';
---

<Layout
    title="404 — VELYOS"
    description="Stránka nebyla nalezena."
    lang="cs"
    active={null}
    primaryCta={false}
>
    <section class="notfound">
        <div class="notfound__ambient"></div>
        <div class="container notfound__container">
            <div class="notfound__code">
                <span>4</span>
                <span class="notfound__zero">0</span>
                <span>4</span>
            </div>

            <div class="notfound__content" data-lang-block="cs">
                <span class="eyebrow">· Chyba navigace</span>
                <h1 class="notfound__title">Tahle stránka <span class="accent">neexistuje.</span></h1>
                <p class="notfound__lead">Buď byla přesunuta, nebo jste šli jinou cestou. Nic se neděje — vraťte se na hlavní rozcestník a pokračujte dál.</p>
                <div class="notfound__ctas">
                    <a href="/" class="btn btn--primary btn-arrow btn--lg">Hlavní stránka</a>
                    <a href="/firmy" class="btn btn--ghost btn--lg">Pro firmy</a>
                    <a href="/jednotlivci" class="btn btn--ghost btn--lg">Pro jednotlivce</a>
                </div>
            </div>

            <div class="notfound__content" data-lang-block="en" hidden>
                <span class="eyebrow">· Navigation error</span>
                <h1 class="notfound__title">This page <span class="accent">doesn't exist.</span></h1>
                <p class="notfound__lead">It was either moved, or you took a different path. No harm done — head back to the main page and continue from there.</p>
                <div class="notfound__ctas">
                    <a href="/en" class="btn btn--primary btn-arrow btn--lg">Home</a>
                    <a href="/en/companies" class="btn btn--ghost btn--lg">For companies</a>
                    <a href="/en/individuals" class="btn btn--ghost btn--lg">For individuals</a>
                </div>
            </div>

            <div class="notfound__content" data-lang-block="de" hidden>
                <span class="eyebrow">· Navigationsfehler</span>
                <h1 class="notfound__title">Diese Seite <span class="accent">existiert nicht.</span></h1>
                <p class="notfound__lead">Sie wurde entweder verschoben, oder Sie sind einen anderen Weg gegangen. Kein Problem — kehren Sie zur Startseite zurück und setzen Sie fort.</p>
                <div class="notfound__ctas">
                    <a href="/de" class="btn btn--primary btn-arrow btn--lg">Startseite</a>
                    <a href="/de/unternehmen" class="btn btn--ghost btn--lg">Für Unternehmen</a>
                    <a href="/de/einzelpersonen" class="btn btn--ghost btn--lg">Für Einzelpersonen</a>
                </div>
            </div>
        </div>
    </section>
</Layout>

<script is:inline>
    (function () {
        const path = location.pathname;
        const browserLang = (navigator.language || "cs").toLowerCase();
        let lang = "cs";
        if (path.startsWith("/en")) lang = "en";
        else if (path.startsWith("/de")) lang = "de";
        else if (browserLang.startsWith("en")) lang = "en";
        else if (browserLang.startsWith("de")) lang = "de";

        document.querySelectorAll("[data-lang-block]").forEach((el) => {
            if (el.getAttribute("data-lang-block") === lang) el.hidden = false;
            else el.hidden = true;
        });
        document.documentElement.lang = lang;
    })();
</script>

<style>
    .notfound {
        position: relative;
        min-height: calc(100vh - 200px);
        display: flex;
        align-items: center;
        padding: var(--space-24) 0;
        background: var(--velocity-black);
        color: var(--ivory-silver);
        overflow: hidden;
    }

    .notfound__ambient {
        position: absolute;
        inset: 0;
        pointer-events: none;
        background:
            radial-gradient(ellipse 60% 70% at 20% 30%, rgba(232, 93, 31, 0.22) 0%, transparent 60%),
            radial-gradient(ellipse 50% 50% at 80% 70%, rgba(184, 147, 92, 0.15) 0%, transparent 60%);
        animation: glowBreathe 13s ease-in-out infinite;
    }

    .notfound__container {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: auto 1fr;
        gap: var(--space-16);
        align-items: center;
    }

    @media (max-width: 900px) {
        .notfound__container {
            grid-template-columns: 1fr;
            gap: var(--space-10);
            text-align: left;
        }
    }

    .notfound__code {
        font-family: var(--font-mono);
        font-size: clamp(6rem, 14vw, 12rem);
        font-weight: 500;
        line-height: 1;
        letter-spacing: -0.06em;
        color: var(--velocity-orange);
        display: flex;
        gap: 0.02em;
        text-shadow: 0 0 60px rgba(232, 93, 31, 0.35);
    }

    .notfound__zero {
        position: relative;
        display: inline-block;
        animation: notfoundSpin 6s linear infinite;
    }

    @keyframes notfoundSpin {
        from { transform: rotateY(0deg); }
        to { transform: rotateY(360deg); }
    }

    @media (prefers-reduced-motion: reduce) {
        .notfound__zero { animation: none; }
        .notfound__ambient { animation: none; }
    }

    .notfound__content .eyebrow {
        color: var(--velocity-orange);
        display: block;
        margin-bottom: var(--space-4);
    }

    .notfound__title {
        font-size: clamp(2.2rem, 4.5vw, 3.6rem);
        line-height: 1.1;
        letter-spacing: -0.02em;
        margin: 0 0 var(--space-6);
        color: var(--ivory-silver);
    }

    .notfound__title .accent { color: var(--velocity-orange); }

    .notfound__lead {
        font-size: 1.15rem;
        line-height: 1.6;
        color: var(--ivory-70);
        max-width: 58ch;
        margin: 0 0 var(--space-10);
    }

    .notfound__ctas {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-3);
    }
</style>
