---
// Renders nothing server-side — the indicator is built client-side by main.js
// from sections that have [data-section-name] attribute. Just ensures a mount point.
---

<aside class="section-indicator" aria-hidden="true" data-section-indicator></aside>

<style>
    .section-indicator {
        position: fixed;
        top: 50%;
        right: var(--space-6);
        transform: translateY(-50%);
        display: none;
        flex-direction: column;
        gap: 0.9rem;
        z-index: 30;
        pointer-events: auto;
    }

    .section-indicator.is-ready {
        display: flex;
    }

    @media (max-width: 1100px) {
        .section-indicator.is-ready { display: none; }
    }

    .section-indicator__dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: rgba(11, 15, 25, 0.18);
        border: 0;
        padding: 0;
        cursor: pointer;
        position: relative;
        transition: background 0.3s ease, transform 0.3s ease;
    }

    .section-indicator__dot::before {
        content: "";
        position: absolute;
        inset: -6px;
        border-radius: 50%;
    }

    .section-indicator__dot:hover {
        background: var(--velocity-orange);
        transform: scale(1.15);
    }

    .section-indicator__dot.is-active {
        background: var(--velocity-orange);
        transform: scale(1.25);
        box-shadow: 0 0 0 2px rgba(232, 93, 31, 0.25);
    }

    .section-indicator__label {
        position: absolute;
        right: 18px;
        top: 50%;
        transform: translateY(-50%) translateX(-4px);
        font-family: var(--font-mono);
        font-size: 0.72rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--velocity-black);
        background: var(--alpine-white);
        border: 1px solid var(--black-08);
        padding: 0.3rem 0.6rem;
        border-radius: var(--radius);
        white-space: nowrap;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.25s ease, transform 0.25s ease;
        box-shadow: 0 6px 20px -10px rgba(11, 15, 25, 0.25);
    }

    .section-indicator__dot:hover .section-indicator__label {
        opacity: 1;
        transform: translateY(-50%) translateX(0);
    }

    @media (prefers-reduced-motion: reduce) {
        .section-indicator__dot,
        .section-indicator__label { transition: none; }
    }
</style>
