---
interface Props {
    lang?: 'cs' | 'en' | 'de';
    variant?: 'strip' | 'full';
    href?: string;
}

const { lang = 'cs', variant = 'strip', href = '/o-nas' } = Astro.props;

const copy = {
    cs: {
        eyebrow: 'Kdo za VELYOS stojí',
        heading: 'Ne portfolio klientů. Partnerství.',
        name: 'Štěpán Manda',
        role: 'Zakladatel & ředitel VELYOS',
        body: 'Pracuji osobně s každým klientem. Diagnostiku vedu sám, smlouvu podepisujete s mým jménem. Technickou část staví Martin s týmem — já vedu obchod, vztah s klientem a všechna strategická rozhodnutí.',
        cta: 'Podívat se na profil →',
        photoAlt: 'Štěpán Manda — zakladatel a ředitel VELYOS',
    },
    en: {
        eyebrow: '· Who stands behind VELYOS',
        heading: 'Not a client portfolio. A partnership.',
        name: 'Štěpán Manda',
        role: 'Founder & CEO of VELYOS',
        body: 'I work personally with every client. I run the diagnostic myself, and the contract carries my name. The technical side is built by Martin and the team — I own sales, the client relationship, and every strategic decision.',
        cta: 'See profile →',
        photoAlt: 'Štěpán Manda — founder and CEO of VELYOS',
    },
    de: {
        eyebrow: '· Wer hinter VELYOS steht',
        heading: 'Kein Kundenportfolio. Eine Partnerschaft.',
        name: 'Štěpán Manda',
        role: 'Gründer & Geschäftsführer von VELYOS',
        body: 'Ich arbeite persönlich mit jedem Kunden. Die Diagnose führe ich selbst, der Vertrag trägt meinen Namen. Die technische Seite baut Martin mit dem Team — ich verantworte Vertrieb, Kundenbeziehung und jede strategische Entscheidung.',
        cta: 'Profil ansehen →',
        photoAlt: 'Štěpán Manda — Gründer und Geschäftsführer von VELYOS',
    },
};

const t = copy[lang];
const isStrip = variant === 'strip';
---

<section class={`founder ${isStrip ? 'founder--strip' : 'founder--full'}`}>
    <div class={isStrip ? 'container' : 'container container--narrow'}>
        <div class="founder__inner">
            <div class="founder__photo-wrap">
                <div class="founder__photo" aria-label={t.photoAlt}>
                    <!-- Fotka přijde brzy — zatím elegantní placeholder -->
                    <div class="founder__photo-placeholder">
                        <span class="founder__photo-initials">ŠM</span>
                        <span class="founder__photo-pending">Fotografie v přípravě</span>
                    </div>
                </div>
                <div class="founder__photo-accent"></div>
            </div>

            <div class="founder__content">
                <span class="eyebrow">{t.eyebrow}</span>
                <h2 class="founder__heading">{t.heading}</h2>

                <div class="founder__meta">
                    <span class="founder__name">{t.name}</span>
                    <span class="founder__sep">·</span>
                    <span class="founder__role">{t.role}</span>
                </div>

                <p class="founder__body">{t.body}</p>

                {isStrip && (
                    <a href={href} class="founder__cta">{t.cta}</a>
                )}

                <slot />
            </div>
        </div>
    </div>
</section>

<style>
    .founder {
        background: var(--ivory-silver);
        padding: var(--space-20) 0;
        position: relative;
        overflow: hidden;
    }

    .founder--full {
        padding: var(--space-24) 0;
    }

    .founder__inner {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1.4fr);
        gap: var(--space-12);
        align-items: center;
    }

    .founder--full .founder__inner {
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
        gap: var(--space-16);
    }

    @media (max-width: 820px) {
        .founder__inner,
        .founder--full .founder__inner {
            grid-template-columns: 1fr;
            gap: var(--space-8);
        }
    }

    .founder__photo-wrap {
        position: relative;
        aspect-ratio: 4 / 5;
        max-width: 420px;
        width: 100%;
    }

    .founder--full .founder__photo-wrap {
        max-width: 520px;
    }

    .founder__photo {
        position: relative;
        width: 100%;
        height: 100%;
        border-radius: var(--radius-lg);
        overflow: hidden;
        background: linear-gradient(135deg, #3a2510 0%, #0B0F19 60%, #1E3A5F 100%);
        box-shadow: 0 30px 80px -30px rgba(11, 15, 25, 0.4);
        z-index: 1;
    }

    .founder__photo-placeholder {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: var(--ivory-silver);
        text-align: center;
        padding: var(--space-6);
    }

    .founder__photo-initials {
        font-family: var(--font-sans);
        font-size: clamp(4rem, 9vw, 6.5rem);
        font-weight: 600;
        letter-spacing: -0.04em;
        color: var(--velocity-orange);
        line-height: 1;
    }

    .founder__photo-pending {
        margin-top: var(--space-4);
        font-family: var(--font-mono);
        font-size: 0.72rem;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: rgba(245, 243, 238, 0.5);
    }

    .founder__photo-accent {
        position: absolute;
        top: var(--space-6);
        left: calc(-1 * var(--space-4));
        width: 60%;
        height: 60%;
        background: linear-gradient(135deg, var(--velocity-orange), var(--signal-gold));
        border-radius: var(--radius-lg);
        z-index: 0;
        opacity: 0.9;
    }

    .founder__content .eyebrow {
        color: var(--velocity-orange);
        display: block;
        margin-bottom: var(--space-4);
    }

    .founder__heading {
        font-size: clamp(1.8rem, 3vw, 2.4rem);
        line-height: 1.2;
        letter-spacing: -0.02em;
        color: var(--velocity-black);
        margin: 0 0 var(--space-6);
        font-weight: 600;
    }

    .founder--full .founder__heading {
        font-size: clamp(2rem, 3.6vw, 2.8rem);
    }

    .founder__meta {
        display: flex;
        flex-wrap: wrap;
        align-items: baseline;
        gap: 0.5rem;
        margin-bottom: var(--space-6);
        font-size: 0.95rem;
        color: var(--black-60);
    }

    .founder__name {
        font-weight: 600;
        color: var(--velocity-black);
        font-size: 1.1rem;
    }

    .founder__sep { opacity: 0.4; }

    .founder__role {
        font-family: var(--font-mono);
        font-size: 0.82rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--signal-gold);
    }

    .founder__body {
        font-size: 1.05rem;
        line-height: 1.65;
        color: var(--black-90);
        margin: 0 0 var(--space-6);
        max-width: 58ch;
    }

    .founder__cta {
        display: inline-flex;
        align-items: center;
        color: var(--velocity-black);
        font-weight: 500;
        border-bottom: 1px solid rgba(232, 93, 31, 0.5);
        padding-bottom: 2px;
        transition: color 0.25s ease, border-color 0.25s ease;
    }

    .founder__cta:hover {
        color: var(--velocity-orange);
        border-color: var(--velocity-orange);
    }
</style>
