---
// AgentDiagnostic — prezentační sekce pro agenta (widget sám je globálně v Layoutu)
import { componentStrings, route, type Lang } from '../i18n/ui';

interface Props {
    agentId?: string; // ponechané pro kompatibilitu, reálně widget je v Layout.astro
    lang?: Lang;
}

const { lang = 'cs' } = Astro.props;
const t = componentStrings[lang].agent;
---

<section class="agent-diagnostic" id="diagnostikovat">
    <div class="agent-diagnostic__glow"></div>
    <div class="container container--narrow">
        <div class="agent-diagnostic__inner" data-reveal>
            <div class="agent-diagnostic__badge">
                <span class="agent-diagnostic__dot"></span>
                <span class="agent-diagnostic__badge-text">{t.badge}</span>
            </div>

            <h2 class="agent-diagnostic__title">
                {t.title1} <span class="accent">{t.title2}</span>
            </h2>

            <p class="agent-diagnostic__lead" set:html={t.lead}></p>

            <a href={route('diagnostika', lang)} class="btn btn--primary btn-arrow btn--lg">{t.cta}</a>

            <ul class="agent-diagnostic__points">
                <li>
                    <span class="agent-diagnostic__check">✓</span>
                    <span set:html={t.point1}></span>
                </li>
                <li>
                    <span class="agent-diagnostic__check">✓</span>
                    <span set:html={t.point2}></span>
                </li>
                <li>
                    <span class="agent-diagnostic__check">✓</span>
                    <span set:html={t.point3}></span>
                </li>
            </ul>

            <p class="agent-diagnostic__footnote" set:html={t.footnote}></p>
        </div>
    </div>
</section>

<style>
    .agent-diagnostic {
        background: var(--surface-card);
        padding: var(--space-24) 0;
        position: relative;
        overflow: hidden;
        border-top: 1px solid var(--border-soft);
        border-bottom: 1px solid var(--border-soft);
    }

    .agent-diagnostic__glow {
        position: absolute;
        width: 700px;
        height: 700px;
        background: radial-gradient(circle, rgba(232, 93, 31, 0.08) 0%, transparent 65%);
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        pointer-events: none;
        animation: glowBreathe 8s ease-in-out infinite;
    }

    .agent-diagnostic .container { position: relative; z-index: 1; }

    .agent-diagnostic__inner {
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--space-6);
    }

    .agent-diagnostic__badge {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        padding: 0.4rem 0.95rem;
        background: rgba(232, 93, 31, 0.08);
        border: 1px solid rgba(232, 93, 31, 0.25);
        border-radius: 999px;
        font-family: var(--font-mono);
        font-size: 0.7rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--velocity-orange);
    }

    .agent-diagnostic__dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--velocity-orange);
        box-shadow: 0 0 0 0 rgba(232, 93, 31, 0.6);
        animation: agentPulse 2s ease-in-out infinite;
    }

    @keyframes agentPulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(232, 93, 31, 0.6); }
        50%      { box-shadow: 0 0 0 8px rgba(232, 93, 31, 0); }
    }

    .agent-diagnostic__title {
        font-size: clamp(1.8rem, 3.2vw, 2.7rem);
        letter-spacing: -0.02em;
        max-width: 22ch;
        margin: 0;
        line-height: 1.1;
    }

    .agent-diagnostic__title .accent {
        color: var(--velocity-orange);
    }

    .agent-diagnostic__lead {
        font-size: 1.1rem;
        color: var(--text-secondary);
        max-width: 52ch;
        margin: 0;
        line-height: 1.55;
    }

    .agent-diagnostic__points {
        list-style: none;
        padding: 0;
        margin: var(--space-2) 0 0;
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
        text-align: left;
        max-width: 46ch;
    }

    .agent-diagnostic__points li {
        display: flex;
        gap: 0.7rem;
        font-size: 0.95rem;
        color: var(--text-secondary);
        line-height: 1.5;
    }

    .agent-diagnostic__check {
        color: var(--velocity-orange);
        font-weight: 600;
        flex-shrink: 0;
    }

    .agent-diagnostic__footnote {
        font-family: var(--font-serif);
        font-style: italic;
        font-size: 0.95rem;
        color: var(--mist-gray);
        margin: var(--space-2) 0 0;
    }

    .agent-diagnostic__footnote a {
        color: var(--text-primary);
        border-bottom: 1px solid var(--gold-30);
    }

    .agent-diagnostic__footnote a:hover {
        color: var(--velocity-orange);
        border-bottom-color: var(--velocity-orange);
    }

</style>
