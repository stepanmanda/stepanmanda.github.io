---
import NavContact from './NavContact.astro';
import LangSwitcher from './LangSwitcher.astro';
import { t, route, type Lang, type RouteKey } from '../i18n/ui';

interface Props {
    lang?: Lang;
    active?: RouteKey | null;
    primaryCta?: { label: string; href: string } | null | false;
}

const {
    lang = 'cs',
    active = null,
    primaryCta,
} = Astro.props;

const nav = t(lang, 'nav');

// Default primary CTA (pokud není explicitně předán)
const cta = primaryCta === undefined
    ? { label: nav.primaryCta, href: route('firmy', lang) }
    : primaryCta;
---

<header class="site-header" transition:name="velyos-header">
    <div class="site-header__inner">
        <div class="site-header__left">
            <a href={route('home', lang)} class="brand" transition:name="brand-logo" aria-label="VELYOS — domů">
                <img src="/logo/logo-lockup.svg" alt="VELYOS" class="brand__logo brand__logo--light" width="120" height="32" />
                <img src="/logo/logo-lockup-inverted.svg" alt="" aria-hidden="true" class="brand__logo brand__logo--dark" width="120" height="32" />
            </a>
        </div>

        <!-- Desktop nav -->
        <nav class="nav">
            <a href={route('firmy', lang)} class={active === 'firmy' ? 'active' : ''}>{nav.companies}</a>
            <a href={route('jednotlivci', lang)} class={active === 'jednotlivci' ? 'active' : ''}>{nav.individuals}</a>
            <NavContact lang={lang} />
            <button class="theme-toggle" id="theme-toggle" type="button" aria-label="Přepnout světlý nebo tmavý vzhled" aria-pressed="false">
                <svg class="theme-toggle__icon theme-toggle__icon--sun" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                    <circle cx="12" cy="12" r="4" fill="currentColor"/>
                    <g stroke="currentColor" stroke-width="2" stroke-linecap="round">
                        <line x1="12" y1="2.5" x2="12" y2="5"/>
                        <line x1="12" y1="19" x2="12" y2="21.5"/>
                        <line x1="2.5" y1="12" x2="5" y2="12"/>
                        <line x1="19" y1="12" x2="21.5" y2="12"/>
                        <line x1="5.6" y1="5.6" x2="7.4" y2="7.4"/>
                        <line x1="16.6" y1="16.6" x2="18.4" y2="18.4"/>
                        <line x1="5.6" y1="18.4" x2="7.4" y2="16.6"/>
                        <line x1="16.6" y1="7.4" x2="18.4" y2="5.6"/>
                    </g>
                </svg>
                <svg class="theme-toggle__icon theme-toggle__icon--moon" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" fill="currentColor"/>
                </svg>
            </button>
            <LangSwitcher lang={lang} active={active} />
            {cta && (
                <a href={cta.href} class="btn btn--primary btn--sm btn-arrow">{cta.label}</a>
            )}
        </nav>

        <!-- Mobile hamburger trigger -->
        <button class="nav-toggle" id="nav-toggle" aria-expanded="false" aria-controls="mobile-drawer" aria-label={nav.menuOpen} type="button">
            <span class="nav-toggle__bar"></span>
            <span class="nav-toggle__bar"></span>
            <span class="nav-toggle__bar"></span>
        </button>
    </div>

    <!-- Mobile drawer -->
    <div class="mobile-drawer" id="mobile-drawer" role="dialog" aria-label="Menu" aria-hidden="true">
        <div class="mobile-drawer__glow"></div>
        <nav class="mobile-drawer__nav">
            <a href={route('firmy', lang)} class={`mobile-drawer__link ${active === 'firmy' ? 'is-active' : ''}`}>
                <span class="mobile-drawer__link-num">01</span>
                <span>{nav.companies}</span>
            </a>
            <a href={route('jednotlivci', lang)} class={`mobile-drawer__link ${active === 'jednotlivci' ? 'is-active' : ''}`}>
                <span class="mobile-drawer__link-num">02</span>
                <span>{nav.individuals}</span>
            </a>
            <a href={route('diagnostika', lang)} class={`mobile-drawer__link ${active === 'diagnostika' ? 'is-active' : ''}`}>
                <span class="mobile-drawer__link-num">03</span>
                <span>{nav.diagnosticCta.replace(/ ?[→]/, '')}</span>
            </a>
            <a href={route('o-nas', lang)} class={`mobile-drawer__link ${active === 'o-nas' ? 'is-active' : ''}`}>
                <span class="mobile-drawer__link-num">04</span>
                <span>{t(lang, 'footer').linkAbout}</span>
            </a>
            <a href={route('pristup', lang)} class={`mobile-drawer__link ${active === 'pristup' ? 'is-active' : ''}`}>
                <span class="mobile-drawer__link-num">05</span>
                <span>{t(lang, 'footer').linkApproach}</span>
            </a>
            <a href={route('pripadove-studie', lang)} class={`mobile-drawer__link ${active === 'pripadove-studie' ? 'is-active' : ''}`}>
                <span class="mobile-drawer__link-num">06</span>
                <span>{t(lang, 'footer').linkCases}</span>
            </a>
            <a href={route('kontakt', lang)} class={`mobile-drawer__link ${active === 'kontakt' ? 'is-active' : ''}`}>
                <span class="mobile-drawer__link-num">07</span>
                <span>{nav.contact}</span>
            </a>
        </nav>

        <div class="mobile-drawer__footer">
            <LangSwitcher lang={lang} active={active} variant="mobile" />
            <span class="mobile-drawer__footer-label">{nav.contactDirect}</span>
            <a href="mailto:stepan@velyos.ai" class="mobile-drawer__footer-link">stepan@velyos.ai</a>
            <span class="mobile-drawer__footer-note">{nav.contactPhoneNote}.</span>

            {cta && (
                <a href={cta.href} class="btn btn--primary btn-arrow btn--lg" style="margin-top:1.5rem;">{cta.label}</a>
            )}
        </div>
    </div>
</header>
