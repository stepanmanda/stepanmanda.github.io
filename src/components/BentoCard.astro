---
interface Props {
    span?: 5 | 7;
    accent?: 'orange' | 'gold';
    num: string;
    title: string;
    body?: string;
}

const { span = 6, accent = 'orange', num, title, body } = Astro.props;
const spanClass = `bento-card--span-${span}`;
const accentClass = `bento-card--${accent}`;
---

<article class={`bento-card ${spanClass} ${accentClass}`}>
    <div class="bento-card__glow"></div>
    <span class="bento-card__num">{num}</span>
    <h4 class="bento-card__title" set:html={title}></h4>
    {body && <p class="bento-card__body" set:html={body}></p>}
    <slot />
</article>

<style>
    .bento-card {
        position: relative;
        padding: var(--space-8);
        background: var(--alpine-white);
        border: 1px solid rgba(11, 15, 25, 0.08);
        border-radius: var(--radius-lg);
        display: flex;
        flex-direction: column;
        gap: var(--space-3);
        overflow: hidden;
        transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 0.4s ease, border-color 0.4s ease;
    }

    .bento-card--span-5 { grid-column: span 5; }
    .bento-card--span-7 { grid-column: span 7; }

    @media (max-width: 900px) {
        .bento-card--span-5,
        .bento-card--span-7 { grid-column: span 1; }
        .bento-card { padding: var(--space-6); }
    }

    .bento-card__glow {
        position: absolute;
        top: -40%;
        right: -20%;
        width: 60%;
        height: 140%;
        pointer-events: none;
        opacity: 0;
        transition: opacity 0.6s ease;
        background: radial-gradient(ellipse at center, rgba(232, 93, 31, 0.14) 0%, transparent 60%);
    }

    .bento-card--gold .bento-card__glow {
        background: radial-gradient(ellipse at center, rgba(184, 147, 92, 0.14) 0%, transparent 60%);
    }

    .bento-card:hover {
        transform: translateY(-3px);
        border-color: rgba(232, 93, 31, 0.25);
        box-shadow: 0 20px 60px -30px rgba(11, 15, 25, 0.18), 0 2px 8px -2px rgba(232, 93, 31, 0.08);
    }

    .bento-card--gold:hover {
        border-color: rgba(184, 147, 92, 0.35);
        box-shadow: 0 20px 60px -30px rgba(11, 15, 25, 0.18), 0 2px 8px -2px rgba(184, 147, 92, 0.12);
    }

    .bento-card:hover .bento-card__glow { opacity: 1; }

    .bento-card__num {
        position: relative;
        font-family: var(--font-mono);
        font-size: 0.78rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--velocity-orange);
    }

    .bento-card--gold .bento-card__num { color: var(--signal-gold); }

    .bento-card__title {
        position: relative;
        margin: 0;
        font-size: clamp(1.35rem, 2vw, 1.7rem);
        line-height: 1.2;
        letter-spacing: -0.015em;
        color: var(--velocity-black);
    }

    .bento-card--span-7 .bento-card__title {
        font-size: clamp(1.55rem, 2.4vw, 2rem);
    }

    .bento-card__body {
        position: relative;
        margin: 0;
        color: var(--black-60);
        font-size: 1rem;
        line-height: 1.6;
    }

    @media (prefers-reduced-motion: reduce) {
        .bento-card,
        .bento-card__glow {
            transition: none;
        }
        .bento-card:hover { transform: none; }
    }
</style>
