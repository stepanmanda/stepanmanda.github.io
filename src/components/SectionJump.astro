---
interface Props {
    lang?: 'cs' | 'en' | 'de';
}
const { lang = 'cs' } = Astro.props;

const labels = {
    cs: { title: 'Přejít na sekci', trigger: 'Obsah', header: 'Navigace', esc: 'ESC' },
    en: { title: 'Jump to section', trigger: 'Sections', header: 'Contents', esc: 'ESC' },
    de: { title: 'Zum Abschnitt', trigger: 'Inhalt', header: 'Inhalt', esc: 'ESC' },
};

const t = labels[lang];
---

<div class="section-jump" data-section-jump aria-hidden="true">
    <button
        type="button"
        class="section-jump__trigger"
        aria-expanded="false"
        aria-controls="section-jump-panel"
        data-section-jump-trigger
    >
        <span class="section-jump__trigger-badge" data-section-jump-current>§</span>
        <span class="section-jump__trigger-label">{t.trigger}</span>
        <svg class="section-jump__caret" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true">
            <path d="M1 5L5 1L9 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
    </button>

    <div
        id="section-jump-panel"
        class="section-jump__panel"
        role="menu"
        aria-label={t.title}
    >
        <div class="section-jump__panel-head">
            <span class="section-jump__panel-title">{t.header}</span>
            <kbd class="section-jump__panel-hint">{t.esc}</kbd>
        </div>
        <div class="section-jump__items" data-section-jump-panel></div>
    </div>
</div>

<style is:global>
    .section-jump {
        position: fixed;
        bottom: 1.5rem;
        left: 1.5rem;
        z-index: 35;
        opacity: 0;
        transform: translateY(10px);
        transition: opacity 0.4s ease, transform 0.4s ease;
        pointer-events: none;
    }

    .section-jump.is-visible {
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
    }

    @media (max-width: 768px) {
        .section-jump { display: none; }
    }

    /* ========== TRIGGER ========== */
    .section-jump__trigger {
        display: inline-flex;
        align-items: center;
        gap: 0.65rem;
        background: var(--velocity-black);
        color: var(--ivory-silver);
        padding: 0.55rem 1.1rem 0.55rem 0.55rem;
        border-radius: 999px;
        font-family: var(--font-mono);
        font-size: 0.74rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        font-weight: 500;
        box-shadow: 0 20px 42px -20px rgba(11, 15, 25, 0.55),
                    0 0 0 1px rgba(245, 243, 238, 0.06);
        cursor: pointer;
        transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1),
                    background 0.25s ease,
                    box-shadow 0.3s ease;
    }

    .section-jump__trigger:hover {
        transform: translateY(-2px);
        background: #13172a;
        box-shadow: 0 26px 50px -20px rgba(11, 15, 25, 0.6),
                    0 0 0 1px rgba(232, 93, 31, 0.35);
    }

    .section-jump__trigger-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 1.75rem;
        height: 1.75rem;
        background: var(--velocity-orange);
        color: var(--alpine-white);
        border-radius: 999px;
        font-family: var(--font-mono);
        font-variant-numeric: tabular-nums;
        font-size: 0.78rem;
        letter-spacing: 0;
        font-weight: 600;
    }

    .section-jump__trigger-label {
        font-weight: 500;
    }

    .section-jump__caret {
        margin-left: 0.15rem;
        color: rgba(245, 243, 238, 0.55);
        transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), color 0.25s ease;
    }

    .section-jump.is-open .section-jump__caret {
        transform: rotate(180deg);
    }

    .section-jump__trigger:hover .section-jump__caret {
        color: var(--ivory-silver);
    }

    /* ========== PANEL ========== */
    .section-jump__panel {
        position: absolute;
        bottom: calc(100% + 0.85rem);
        left: 0;
        width: 340px;
        max-width: calc(100vw - 3rem);
        max-height: 64vh;
        display: flex;
        flex-direction: column;
        background: var(--alpine-white);
        border-radius: 10px;
        box-shadow:
            0 24px 60px -28px rgba(11, 15, 25, 0.35),
            0 4px 12px -4px rgba(11, 15, 25, 0.08),
            0 0 0 1px rgba(11, 15, 25, 0.05);
        opacity: 0;
        transform: translateY(8px) scale(0.985);
        transform-origin: bottom left;
        transition: opacity 0.25s ease,
                    transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
        pointer-events: none;
        overflow: hidden;
    }

    .section-jump.is-open .section-jump__panel {
        opacity: 1;
        transform: translateY(0) scale(1);
        pointer-events: auto;
    }

    /* Panel header */
    .section-jump__panel-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.85rem 1.15rem 0.8rem;
        border-bottom: 1px solid rgba(11, 15, 25, 0.06);
        background: rgba(245, 243, 238, 0.5);
    }

    .section-jump__panel-title {
        font-family: var(--font-mono);
        font-size: 0.68rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--velocity-orange);
        font-weight: 500;
    }

    .section-jump__panel-hint {
        font-family: var(--font-mono);
        font-size: 0.62rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--mist-gray);
        padding: 0.15rem 0.4rem;
        background: var(--alpine-white);
        border: 1px solid rgba(11, 15, 25, 0.1);
        border-radius: 3px;
        font-weight: 500;
    }

    /* Items container with scroll */
    .section-jump__items {
        overflow-y: auto;
        padding: 0.3rem 0;
    }

    .section-jump__items::-webkit-scrollbar { width: 6px; }
    .section-jump__items::-webkit-scrollbar-track { background: transparent; }
    .section-jump__items::-webkit-scrollbar-thumb {
        background: rgba(11, 15, 25, 0.12);
        border-radius: 3px;
    }

    /* ========== ITEM — consistent alignment ========== */
    .section-jump__item {
        display: flex;
        align-items: center;
        gap: 0.85rem;
        width: 100%;
        padding: 0.7rem 1.15rem;
        background: transparent;
        border: 0;
        text-align: left;
        font-size: 0.94rem;
        line-height: 1.3;
        color: var(--black-60);
        cursor: pointer;
        transition: background 0.18s ease, color 0.18s ease;
    }

    /* Number badge — fixed visual element, not stray text */
    .section-jump__item-num {
        flex-shrink: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 2rem;
        height: 1.65rem;
        padding: 0 0.4rem;
        background: rgba(11, 15, 25, 0.05);
        color: var(--black-60);
        font-family: var(--font-mono);
        font-variant-numeric: tabular-nums;
        font-size: 0.73rem;
        letter-spacing: 0.02em;
        font-weight: 500;
        border-radius: 4px;
        transition: background 0.2s ease, color 0.2s ease;
    }

    .section-jump__item-label {
        flex: 1;
        font-weight: 500;
        color: var(--velocity-black);
        letter-spacing: -0.005em;
    }

    /* Hover — neutral wash + strengthen label, badge darkens */
    .section-jump__item:hover {
        background: rgba(11, 15, 25, 0.03);
    }

    .section-jump__item:hover .section-jump__item-num {
        background: rgba(11, 15, 25, 0.09);
        color: var(--velocity-black);
    }

    /* Active — orange badge + gentle orange row tint */
    .section-jump__item.is-active {
        background: rgba(232, 93, 31, 0.06);
    }

    .section-jump__item.is-active .section-jump__item-num {
        background: var(--velocity-orange);
        color: var(--alpine-white);
    }

    .section-jump__item.is-active .section-jump__item-label {
        color: var(--velocity-orange);
    }

    @media (prefers-reduced-motion: reduce) {
        .section-jump,
        .section-jump__trigger,
        .section-jump__panel,
        .section-jump__caret,
        .section-jump__item,
        .section-jump__item-num { transition: none; }
    }
</style>
