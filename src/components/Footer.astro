---
import { t, route, type Lang } from '../i18n/ui';

interface Props {
    lang?: Lang;
    tagline?: string;
    variant?: string;
    email?: string;
    phone?: string;
    phoneDisplay?: string;
}

const {
    lang = 'cs',
    tagline = 'The Velocity Operating System.',
    variant = 'v0.3 preview',
    email = 'stepan@velyos.ai',
} = Astro.props;

const f = t(lang, 'footer');
const year = new Date().getFullYear();
---

<footer class="site-footer" id="kontakt">
    <div class="container">
        <div class="site-footer__grid">
            <div class="site-footer__brand">
                <div class="brand">VELY<span class="os">OS</span></div>
                <p>{tagline}</p>
            </div>
            <div>
                <h4>{f.columnSystem}</h4>
                <ul>
                    <li><a href={route('home', lang)}>{f.linkHome}</a></li>
                    <li><a href={route('firmy', lang)}>{f.linkCompanies}</a></li>
                    <li><a href={route('jednotlivci', lang)}>{f.linkIndividuals}</a></li>
                </ul>
            </div>
            <div>
                <h4>{f.columnFirm}</h4>
                <ul>
                    <li><a href={route('o-nas', lang)}>{f.linkAbout}</a></li>
                    <li><a href={route('pristup', lang)}>{f.linkApproach}</a></li>
                    <li><a href={route('pripadove-studie', lang)}>{f.linkCases}</a></li>
                    <li><a href={route('kontakt', lang)}>{f.linkContact}</a></li>
                </ul>
            </div>
            <div>
                <h4>{f.columnContact}</h4>
                <ul>
                    <li><a href={`mailto:${email}`}>{email}</a></li>
                    <li><span style="color:var(--mist-gray); font-style:italic;">{f.phoneAfterReg}</span></li>
                    <li><span style="color:var(--mist-gray); font-style:italic;">{f.linkedInAfterReg}</span></li>
                    <li>{f.location}</li>
                </ul>
            </div>
        </div>

        <div class="site-footer__legal">
            <a href="/impresum">{f.legalImpresum}</a>
            <span class="sep">·</span>
            <a href="/ochrana-osobnich-udaju">{f.legalGdpr}</a>
            <span class="sep">·</span>
            <a href={route('kontakt', lang)}>{f.linkContact}</a>
        </div>

        <div class="site-footer__bottom">
            <span>© {year} VELYOS. {f.copyright}</span>
            <span class="mono">{variant} · {email}</span>
        </div>
    </div>
</footer>
