---
// GrantBlock — dotační blok pod pricing (jen Firmy stránka)
import { componentStrings, type Lang } from '../i18n/ui';

interface Props {
    email?: string;
    lang?: Lang;
}

const { email = 'stepan@velyos.ai', lang = 'cs' } = Astro.props;
const t = componentStrings[lang].grant;
const subject = encodeURIComponent(t.subject);
---

<div id="dotace" class="hero__grant" data-reveal style="max-width:none; margin-top:var(--space-10); padding:var(--space-8) var(--space-10); display:grid; grid-template-columns:1fr auto; gap:var(--space-6); align-items:center; border-left-width:4px;">
    <div style="display:flex; flex-direction:column; gap:var(--space-3);">
        <span class="hero__grant__label">{t.label}</span>
        <h3 style="margin:0; font-size:1.4rem;">{t.title}</h3>
        <p style="margin:0; color:var(--black-60); font-size:1rem; line-height:1.6; max-width:62ch;" set:html={t.body}></p>
    </div>
    <a href={`mailto:${email}?subject=${subject}`} class="btn btn--primary btn-arrow" style="align-self:center; justify-self:end;">{t.cta}</a>
</div>
