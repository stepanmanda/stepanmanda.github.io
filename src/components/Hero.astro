---
interface Props {
    tagline?: string;
    variant?: 'split' | 'dense';
}

const { tagline, variant = 'dense' } = Astro.props;
const variantClass = variant === 'split' ? 'hero hero--split' : 'hero hero--dense';
---

<section class={variantClass} data-hero-cinematic>
    <!-- Canvas mesh gradient (zapnuto přes JS, respektuje reduced-motion) -->
    <canvas class="hero__mesh" aria-hidden="true"></canvas>
    <div class="hero__grid"></div>
    <div class="hero__glow hero__glow--primary" aria-hidden="true"></div>
    <div class="hero__glow hero__glow--secondary" aria-hidden="true"></div>
    <div class="hero__accent-line"></div>
    <!-- Jemný noise overlay — prémiový filmový efekt -->
    <div class="hero__noise" aria-hidden="true"></div>
    <div class="container">
        {tagline && <div class="hero__tagline">{tagline}</div>}
        <slot />
    </div>
</section>
