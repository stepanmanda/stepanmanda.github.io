---
// Typographic progress rail — populated by main.js from sections with numbered eyebrows.
// Hidden until scrolled past hero. Invisible on <1200px screens.
---

<aside class="progress-rail" aria-hidden="true" data-progress-rail></aside>

<style>
    .progress-rail {
        position: fixed;
        top: 50%;
        right: 2.25rem;
        transform: translateY(-50%);
        display: none;
        flex-direction: column;
        gap: 0.85rem;
        z-index: 30;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.5s ease;
    }

    .progress-rail.is-ready.is-visible {
        display: flex;
        opacity: 1;
        pointer-events: auto;
    }

    @media (max-width: 1200px) {
        .progress-rail,
        .progress-rail.is-ready.is-visible { display: none; }
    }

    .progress-rail__item {
        display: flex;
        align-items: center;
        gap: 0.7rem;
        cursor: pointer;
        background: transparent;
        border: 0;
        padding: 0.3rem 0;
        color: var(--mist-gray);
        position: relative;
    }

    .progress-rail__num {
        font-family: var(--font-mono);
        font-variant-numeric: tabular-nums;
        font-size: 0.7rem;
        letter-spacing: 0.08em;
        min-width: 1.4em;
        text-align: right;
        color: var(--mist-gray);
        transition: color 0.3s ease;
        order: 3;
    }

    .progress-rail__tick {
        width: 24px;
        height: 1px;
        background: rgba(184, 147, 92, 0.4);
        transition: width 0.45s cubic-bezier(0.22, 1, 0.36, 1),
                    height 0.3s ease,
                    background 0.3s ease,
                    box-shadow 0.3s ease;
        order: 2;
    }

    .progress-rail__label {
        font-family: var(--font-mono);
        font-size: 0.68rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--black-90);
        opacity: 0;
        transform: translateX(6px);
        transition: opacity 0.3s ease, transform 0.3s ease;
        white-space: nowrap;
        pointer-events: none;
        order: 1;
        margin-right: 0.1rem;
    }

    /* Hover — subtle but confident */
    .progress-rail__item:hover .progress-rail__num { color: var(--velocity-black); }
    .progress-rail__item:hover .progress-rail__tick {
        width: 36px;
        background: var(--velocity-orange);
    }
    .progress-rail__item:hover .progress-rail__label {
        opacity: 1;
        transform: translateX(0);
    }

    /* Active — active section glows */
    .progress-rail__item.is-active .progress-rail__num {
        color: var(--velocity-orange);
    }
    .progress-rail__item.is-active .progress-rail__tick {
        width: 48px;
        height: 2px;
        background: var(--velocity-orange);
        box-shadow: 0 0 10px rgba(232, 93, 31, 0.45);
    }
    .progress-rail__item.is-active .progress-rail__label {
        opacity: 1;
        transform: translateX(0);
        color: var(--velocity-black);
    }

    /* Dark-theme-aware for sections with Velocity Black background (Stats, 404) */
    body.is-on-dark .progress-rail__num { color: rgba(245, 243, 238, 0.45); }
    body.is-on-dark .progress-rail__item:hover .progress-rail__num { color: var(--ivory-silver); }
    body.is-on-dark .progress-rail__tick { background: rgba(184, 147, 92, 0.55); }
    body.is-on-dark .progress-rail__item.is-active .progress-rail__num { color: var(--velocity-orange); }
    body.is-on-dark .progress-rail__label { color: var(--ivory-silver); }

    @media (prefers-reduced-motion: reduce) {
        .progress-rail,
        .progress-rail__num,
        .progress-rail__tick,
        .progress-rail__label { transition: none; }
    }
</style>
