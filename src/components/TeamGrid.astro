---
interface Props {
    lang?: 'cs' | 'en' | 'de';
}

const { lang = 'cs' } = Astro.props;

const copy = {
    cs: {
        eyebrow: '· Tým, který to staví',
        heading: 'Technické řemeslo vede Martin. Dodávku stíhá mezinárodní tým.',
        lead: 'Štěpán řídí obchod a vztah s klientem. Martin architektonicky staví každé řešení. Pod Martinem pracuje síť zahraničních specialistů, se kterými jsme za roky postavili produkční systémy — nejsou to juniory z open space.',
        initialsLabel: 'Fotografie v přípravě',
    },
    en: {
        eyebrow: '· The team behind the work',
        heading: 'Tech is led by Martin. Delivery is run by an international team.',
        lead: "Štěpán owns sales and the client relationship. Martin architects every solution. Behind Martin is a network of international specialists we've shipped production systems with for years — not juniors in an open space.",
        initialsLabel: 'Photo in preparation',
    },
    de: {
        eyebrow: '· Das Team hinter der Arbeit',
        heading: 'Die Technik führt Martin. Die Umsetzung ein internationales Team.',
        lead: 'Štěpán verantwortet Vertrieb und Kundenbeziehung. Martin architektoniert jede Lösung. Hinter Martin steht ein Netzwerk internationaler Spezialisten, mit denen wir seit Jahren Produktivsysteme ausliefern — keine Junioren im Großraumbüro.',
        initialsLabel: 'Foto in Vorbereitung',
    },
};

// 8 členů technického týmu — Štěpán je ve FounderStrip nad touto sekcí
// Data doplní Štěpán později: initials, name, role, body, linkedin?
const members = [
    {
        initials: '01',
        name: { cs: 'Jméno Příjmení', en: 'First Last', de: 'Vor Nachname' },
        role: { cs: 'Procesní analytik', en: 'Process Analyst', de: 'Prozessanalyst' },
        body: {
            cs: 'Rozebírá provoz do detailu. Najde, kde utíkají hodiny a peníze.',
            en: 'Breaks operations down to detail. Finds where hours and money leak.',
            de: 'Zerlegt den Betrieb ins Detail. Findet Verluste.',
        },
        linkedin: null,
    },
    {
        initials: '02',
        name: { cs: 'Jméno Příjmení', en: 'First Last', de: 'Vor Nachname' },
        role: { cs: 'Lead AI Engineer', en: 'Lead AI Engineer', de: 'Lead AI Engineer' },
        body: {
            cs: 'Staví AI agenty — hlas, chat, e-mail. Od návrhu po produkci.',
            en: 'Builds AI agents — voice, chat, email. From design to production.',
            de: 'Baut AI-Agenten — Sprache, Chat, E-Mail.',
        },
        linkedin: null,
    },
    {
        initials: '03',
        name: { cs: 'Jméno Příjmení', en: 'First Last', de: 'Vor Nachname' },
        role: { cs: 'Integrační architekt', en: 'Integration Architect', de: 'Integrationsarchitekt' },
        body: {
            cs: 'Propojuje CRM, ERP, účetnictví. Data si sedí sama na místo.',
            en: 'Connects CRM, ERP, accounting. Data settles where it belongs.',
            de: 'Verbindet CRM, ERP, Buchhaltung. Daten finden ihren Platz.',
        },
        linkedin: null,
    },
    {
        initials: '04',
        name: { cs: 'Jméno Příjmení', en: 'First Last', de: 'Vor Nachname' },
        role: { cs: 'Operátor systému', en: 'Systems Operator', de: 'Systemoperator' },
        body: {
            cs: 'Denní dohled, ladění, učení. AI nikdy nenecháme samu.',
            en: 'Daily oversight, tuning, training. AI is never left alone.',
            de: 'Tägliche Überwachung, Tuning, Training.',
        },
        linkedin: null,
    },
    {
        initials: '05',
        name: { cs: 'Jméno Příjmení', en: 'First Last', de: 'Vor Nachname' },
        role: { cs: 'Frontend & brand', en: 'Frontend & Brand', de: 'Frontend & Brand' },
        body: {
            cs: 'Web, identita, rozhraní. Kde se klient poprvé potká s produktem.',
            en: 'Web, identity, interfaces. Where the client meets the product.',
            de: 'Web, Identität, Oberflächen.',
        },
        linkedin: null,
    },
    {
        initials: '06',
        name: { cs: 'Jméno Příjmení', en: 'First Last', de: 'Vor Nachname' },
        role: { cs: 'Data & reporting', en: 'Data & Reporting', de: 'Daten & Reporting' },
        body: {
            cs: 'Dashboardy, metriky, čísla, podle kterých se rozhoduje.',
            en: 'Dashboards, metrics, numbers that drive decisions.',
            de: 'Dashboards, Metriken, Entscheidungsgrundlagen.',
        },
        linkedin: null,
    },
    {
        initials: '07',
        name: { cs: 'Jméno Příjmení', en: 'First Last', de: 'Vor Nachname' },
        role: { cs: 'Security & compliance', en: 'Security & Compliance', de: 'Security & Compliance' },
        body: {
            cs: 'Architektura v duchu ISO 27001, GDPR, šifrování.',
            en: 'ISO 27001-style architecture, GDPR, encryption.',
            de: 'ISO 27001-Architektur, DSGVO, Verschlüsselung.',
        },
        linkedin: null,
    },
    {
        initials: '08',
        name: { cs: 'Jméno Příjmení', en: 'First Last', de: 'Vor Nachname' },
        role: { cs: 'Client success', en: 'Client Success', de: 'Client Success' },
        body: {
            cs: 'Drží vztah po nasazení. Měsíční revize, ladění, další kroky.',
            en: 'Holds the relationship after launch. Monthly reviews, tuning.',
            de: 'Hält die Beziehung nach dem Launch.',
        },
        linkedin: null,
    },
];

const t = copy[lang];
---

<section class="team">
    <div class="container">
        <div class="team__head" data-reveal>
            <span class="eyebrow">{t.eyebrow}</span>
            <h2 class="team__heading">{t.heading}</h2>
            <p class="team__lead">{t.lead}</p>
        </div>

        <div class="team__grid" data-stagger>
            {members.map((m) => (
                <article class="member">
                    <div class="member__photo" aria-label={m.name[lang]}>
                        <div class="member__photo-placeholder">
                            <span class="member__photo-initials">{m.initials}</span>
                            <span class="member__photo-pending">{t.initialsLabel}</span>
                        </div>
                    </div>

                    <div class="member__body">
                        <span class="member__role">{m.role[lang]}</span>
                        <h3 class="member__name">
                            {m.linkedin ? (
                                <a href={m.linkedin} target="_blank" rel="noopener noreferrer">{m.name[lang]}</a>
                            ) : (
                                m.name[lang]
                            )}
                        </h3>
                        <p class="member__text">{m.body[lang]}</p>
                    </div>
                </article>
            ))}
        </div>
    </div>
</section>

<style>
    .team {
        background: var(--alpine-white);
        padding: var(--space-20) 0;
        position: relative;
        border-top: 1px solid var(--black-08);
    }

    .team__head {
        max-width: 60ch;
        margin-bottom: var(--space-12);
    }

    .team__head .eyebrow {
        color: var(--velocity-orange);
        display: block;
        margin-bottom: var(--space-4);
    }

    .team__heading {
        font-size: clamp(1.8rem, 3vw, 2.4rem);
        line-height: 1.2;
        letter-spacing: -0.02em;
        color: var(--velocity-black);
        margin: 0 0 var(--space-5);
        font-weight: 600;
    }

    .team__lead {
        font-size: 1.05rem;
        line-height: 1.65;
        color: var(--black-60);
        margin: 0;
        max-width: 58ch;
    }

    .team__grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: var(--space-6);
    }

    @media (max-width: 1100px) {
        .team__grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    }

    @media (max-width: 820px) {
        .team__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }

    @media (max-width: 480px) {
        .team__grid { grid-template-columns: 1fr; }
    }

    .member {
        background: var(--ivory-silver);
        border: 1px solid var(--black-08);
        border-radius: var(--radius-lg);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition: transform 0.35s ease, box-shadow 0.35s ease, border-color 0.35s ease;
    }

    .member:hover {
        transform: translateY(-4px);
        box-shadow: 0 20px 50px -25px rgba(11, 15, 25, 0.22);
        border-color: rgba(232, 93, 31, 0.3);
    }

    .member__photo {
        position: relative;
        aspect-ratio: 1 / 1;
        background: linear-gradient(135deg, #3a2510 0%, #0B0F19 60%, #1E3A5F 100%);
        overflow: hidden;
    }

    .member__photo-placeholder {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: var(--ivory-silver);
        text-align: center;
        padding: var(--space-5);
    }

    .member__photo-initials {
        font-family: var(--font-mono);
        font-size: clamp(2.2rem, 4vw, 3rem);
        font-weight: 600;
        letter-spacing: -0.02em;
        color: var(--velocity-orange);
        line-height: 1;
    }

    .member__photo-pending {
        margin-top: var(--space-3);
        font-family: var(--font-mono);
        font-size: 0.6rem;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: rgba(245, 243, 238, 0.45);
    }

    .member__body {
        padding: var(--space-5);
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
        flex: 1;
    }

    .member__role {
        font-family: var(--font-mono);
        font-size: 0.68rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--signal-gold);
    }

    .member__name {
        font-size: 1.05rem;
        font-weight: 600;
        color: var(--velocity-black);
        margin: 0;
        letter-spacing: -0.01em;
        line-height: 1.3;
    }

    .member__name a {
        color: inherit;
        border-bottom: 1px solid rgba(232, 93, 31, 0);
        transition: border-color 0.25s ease;
    }

    .member__name a:hover {
        border-color: var(--velocity-orange);
    }

    .member__text {
        font-size: 0.9rem;
        line-height: 1.55;
        color: var(--black-60);
        margin: var(--space-2) 0 0;
    }
</style>
