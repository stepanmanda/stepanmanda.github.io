---
interface Props {
    lang?: 'cs' | 'en' | 'de';
}

const { lang = 'cs' } = Astro.props;

const copy = {
    cs: {
        eyebrow: '· Tým, který to staví',
        heading: 'IT vede Martin. Dodávku stíhá mezinárodní tým.',
        lead: 'Štěpán řídí obchod a vztah s klientem. Martin má na starosti kompletní IT — architekturu každého řešení, AI agenty, integrace a provozní dohled. Pod ním pracuje síť zahraničních specialistů, se kterými jsme za roky postavili produkční systémy.',
        initialsLabel: 'Fotografie v přípravě',
    },
    en: {
        eyebrow: '· The team behind the work',
        heading: 'IT is led by Martin. Delivery is run by an international team.',
        lead: "Štěpán owns sales and the client relationship. Martin runs the entire IT side — architecture of every solution, AI agents, integrations, and operational oversight. Behind him, a network of international specialists we've shipped production systems with for years.",
        initialsLabel: 'Photo in preparation',
    },
    de: {
        eyebrow: '· Das Team hinter der Arbeit',
        heading: 'Die IT führt Martin. Die Umsetzung ein internationales Team.',
        lead: 'Štěpán verantwortet Vertrieb und Kundenbeziehung. Martin führt die gesamte IT — Architektur jeder Lösung, AI-Agenten, Integrationen und Überwachung. Hinter ihm steht ein Netzwerk internationaler Spezialisten.',
        initialsLabel: 'Foto in Vorbereitung',
    },
};

// Tým VELYOS. Zatím pouze Martin (Head of IT). Další členové se přidají postupně.
const members = [
    {
        featured: true,
        photo: '/team/martin-svanda.webp',
        name: { cs: 'Martin Švanda', en: 'Martin Švanda', de: 'Martin Švanda' },
        role: { cs: 'Head of IT', en: 'Head of IT', de: 'Head of IT' },
        body: {
            cs: 'Architekt každého řešení VELYOS. Řídí kompletní IT — od AI agentů přes integrace po provozní dohled. IT background, špička v automatizaci.',
            en: "Architect of every VELYOS solution. Runs the entire IT — AI agents, integrations, operational oversight. IT background, top-tier in automation.",
            de: 'Architekt jeder VELYOS-Lösung. Führt die gesamte IT — von AI-Agenten über Integrationen bis zur Überwachung. IT-Hintergrund, Spitzenklasse in Automation.',
        },
        linkedin: null,
        country: '',
    },
];

const t = copy[lang];
---

<section class="team">
    <div class="container">
        <div class="team__head" data-reveal>
            <span class="eyebrow">{t.eyebrow}</span>
            <h2 class="team__heading">{t.heading}</h2>
            <p class="team__lead">{t.lead}</p>
        </div>

        <div class="team__grid" data-stagger>
            {members.map((m) => (
                <article class={`member ${m.featured ? 'member--featured' : ''}`}>
                    <div class="member__photo" aria-label={m.name[lang]}>
                        {m.photo ? (
                            <img
                                class="member__photo-img"
                                src={m.photo}
                                alt={m.name[lang]}
                                loading="lazy"
                                width="600"
                                height="600"
                            />
                        ) : (
                            <div class="member__photo-placeholder">
                                <span class="member__photo-initials">{m.initials}</span>
                                <span class="member__photo-pending">{t.initialsLabel}</span>
                            </div>
                        )}
                    </div>

                    <div class="member__body">
                        <span class="member__role">{m.role[lang]}</span>
                        <h3 class="member__name">
                            {m.linkedin ? (
                                <a href={m.linkedin} target="_blank" rel="noopener noreferrer">{m.name[lang]}</a>
                            ) : (
                                m.name[lang]
                            )}
                        </h3>
                        {m.country && <span class="member__location">{m.country}</span>}
                        <p class="member__text">{m.body[lang]}</p>
                    </div>
                </article>
            ))}
        </div>
    </div>
</section>

<style>
    .team {
        background: var(--alpine-white);
        padding: var(--space-20) 0;
        position: relative;
        border-top: 1px solid var(--black-08);
    }

    .team__head {
        max-width: 60ch;
        margin-bottom: var(--space-12);
    }

    .team__head .eyebrow {
        color: var(--velocity-orange);
        display: block;
        margin-bottom: var(--space-4);
    }

    .team__heading {
        font-size: clamp(1.8rem, 3vw, 2.4rem);
        line-height: 1.2;
        letter-spacing: -0.02em;
        color: var(--velocity-black);
        margin: 0 0 var(--space-5);
        font-weight: 600;
    }

    .team__lead {
        font-size: 1.05rem;
        line-height: 1.65;
        color: var(--black-60);
        margin: 0;
        max-width: 58ch;
    }

    .team__grid {
        display: grid;
        /* auto-fit adapts to number of members: 1 member = centered wide card, 4+ = grid */
        grid-template-columns: repeat(auto-fit, minmax(260px, 320px));
        gap: var(--space-6);
        justify-content: start;
    }

    @media (max-width: 480px) {
        .team__grid {
            grid-template-columns: 1fr;
        }
    }

    .member {
        background: var(--ivory-silver);
        border: 1px solid var(--black-08);
        border-radius: var(--radius-lg);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition: transform 0.35s ease, box-shadow 0.35s ease, border-color 0.35s ease;
        position: relative;
    }

    .member:hover {
        transform: translateY(-4px);
        box-shadow: 0 20px 50px -25px rgba(11, 15, 25, 0.22);
        border-color: rgba(232, 93, 31, 0.3);
    }

    /* Featured = Martin / CTO — gold border + gold top rail */
    .member--featured {
        border-color: rgba(184, 147, 92, 0.45);
        box-shadow: 0 10px 30px -20px rgba(184, 147, 92, 0.35);
    }

    .member--featured::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, var(--signal-gold), var(--velocity-orange));
        z-index: 2;
    }

    .member--featured .member__photo {
        background: linear-gradient(135deg, #1a1206 0%, #0B0F19 55%, #2a1c08 100%);
    }

    .member--featured .member__photo-initials {
        color: var(--signal-gold);
        font-family: var(--font-sans);
        font-size: clamp(2.6rem, 5vw, 3.6rem);
    }

    .member--featured .member__role {
        color: var(--velocity-orange);
    }

    .member__photo {
        position: relative;
        aspect-ratio: 1 / 1;
        background: linear-gradient(135deg, #3a2510 0%, #0B0F19 60%, #1E3A5F 100%);
        overflow: hidden;
    }

    .member__photo-placeholder {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: var(--ivory-silver);
        text-align: center;
        padding: var(--space-5);
    }

    .member__photo-initials {
        font-family: var(--font-mono);
        font-size: clamp(2.2rem, 4vw, 3rem);
        font-weight: 600;
        letter-spacing: -0.02em;
        color: var(--velocity-orange);
        line-height: 1;
    }

    .member__photo-pending {
        margin-top: var(--space-3);
        font-family: var(--font-mono);
        font-size: 0.6rem;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: rgba(245, 243, 238, 0.45);
    }

    .member__body {
        padding: var(--space-5);
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
        flex: 1;
    }

    .member__role {
        font-family: var(--font-mono);
        font-size: 0.68rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--signal-gold);
    }

    .member__name {
        font-size: 1.05rem;
        font-weight: 600;
        color: var(--velocity-black);
        margin: 0;
        letter-spacing: -0.01em;
        line-height: 1.3;
    }

    .member__name a {
        color: inherit;
        border-bottom: 1px solid rgba(232, 93, 31, 0);
        transition: border-color 0.25s ease;
    }

    .member__name a:hover {
        border-color: var(--velocity-orange);
    }

    .member__location {
        font-size: 0.78rem;
        color: var(--mist-gray);
        font-style: italic;
    }

    .member__text {
        font-size: 0.9rem;
        line-height: 1.55;
        color: var(--black-60);
        margin: var(--space-2) 0 0;
    }
</style>
