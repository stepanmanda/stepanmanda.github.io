---
interface Props {
    lang?: 'cs' | 'en' | 'de';
    variant?: 'strip' | 'full';
    href?: string;
}

const { lang = 'cs', variant = 'strip', href = '/o-nas' } = Astro.props;

const copy = {
    cs: {
        eyebrow: '· Tým, který to staví',
        heading: 'Devět lidí. Jedna smlouva. Jedna odpovědnost.',
        lead: 'VELYOS není agentura se 50 juniory. Devět specialistů, kteří se osobně podepisují pod každý projekt.',
        cta: 'Poznat celý tým →',
        initialsLabel: 'Fotografie v přípravě',
    },
    en: {
        eyebrow: '· The team behind the work',
        heading: 'Nine people. One contract. One accountability line.',
        lead: "VELYOS isn't an agency of 50 juniors. Nine specialists who personally sign off on every project.",
        cta: 'Meet the full team →',
        initialsLabel: 'Photo in preparation',
    },
    de: {
        eyebrow: '· Das Team dahinter',
        heading: 'Neun Menschen. Ein Vertrag. Eine Verantwortung.',
        lead: 'VELYOS ist keine Agentur mit 50 Junioren. Neun Spezialisten, die jedes Projekt persönlich unterschreiben.',
        cta: 'Das gesamte Team kennenlernen →',
        initialsLabel: 'Foto in Vorbereitung',
    },
};

// 9 členů týmu — data doplní Štěpán, zatím placeholder
// Struktura: { initials, name, role, body, linkedin?, location? }
const members = [
    {
        initials: 'ŠM',
        name: { cs: 'Štěpán Manda', en: 'Štěpán Manda', de: 'Štěpán Manda' },
        role: { cs: 'Founder & CEO', en: 'Founder & CEO', de: 'Gründer & CEO' },
        body: {
            cs: 'Vede diagnostiku osobně. Smlouvu podepisujete s jeho jménem. Rozhodnutí padají u něj.',
            en: 'Runs the diagnostic personally. You sign the contract with his name. Decisions land on his desk.',
            de: 'Führt die Diagnose persönlich. Sie unterschreiben den Vertrag mit seinem Namen. Entscheidungen landen bei ihm.',
        },
        linkedin: 'https://www.linkedin.com/in/štěpán-manda-96a648119/',
        location: 'Františkovy Lázně · Praha',
    },
    {
        initials: '02',
        name: { cs: 'Jméno Příjmení', en: 'First Last', de: 'Vor Nachname' },
        role: { cs: 'Procesní analytik', en: 'Process Analyst', de: 'Prozessanalyst' },
        body: {
            cs: 'Rozebírá provoz klienta do detailu. Najde, kde utíkají hodiny a peníze. Navrhne řád.',
            en: 'Breaks client operations down to detail. Finds where hours and money leak. Brings order.',
            de: 'Zerlegt den Betrieb ins Detail. Findet, wo Stunden und Geld verloren gehen. Schafft Ordnung.',
        },
        linkedin: null,
        location: '',
    },
    {
        initials: '03',
        name: { cs: 'Jméno Příjmení', en: 'First Last', de: 'Vor Nachname' },
        role: { cs: 'Lead AI Engineer', en: 'Lead AI Engineer', de: 'Lead AI Engineer' },
        body: {
            cs: 'Staví AI agenty a integrace. Hlas, chat, e-mail — od návrhu po produkční provoz.',
            en: 'Builds AI agents and integrations. Voice, chat, email — from design to production.',
            de: 'Baut AI-Agenten und Integrationen. Sprache, Chat, E-Mail — vom Design bis zur Produktion.',
        },
        linkedin: null,
        location: '',
    },
    {
        initials: '04',
        name: { cs: 'Jméno Příjmení', en: 'First Last', de: 'Vor Nachname' },
        role: { cs: 'Integrační architekt', en: 'Integration Architect', de: 'Integrationsarchitekt' },
        body: {
            cs: 'Napojuje systémy na sebe. CRM, ERP, účetnictví, interní nástroje — data si sedí sama na místo.',
            en: 'Connects systems together. CRM, ERP, accounting, internal tools — data settles in the right place.',
            de: 'Verbindet Systeme. CRM, ERP, Buchhaltung — Daten finden ihren Platz.',
        },
        linkedin: null,
        location: '',
    },
    {
        initials: '05',
        name: { cs: 'Jméno Příjmení', en: 'First Last', de: 'Vor Nachname' },
        role: { cs: 'Operátor systému', en: 'Systems Operator', de: 'Systemoperator' },
        body: {
            cs: 'Denní dohled nad provozem. Ladí, učí, opravuje. AI nenecháme samu.',
            en: 'Daily production oversight. Tunes, trains, fixes. AI is never left alone.',
            de: 'Tägliche Produktionsüberwachung. Stimmt ab, trainiert, repariert.',
        },
        linkedin: null,
        location: '',
    },
    {
        initials: '06',
        name: { cs: 'Jméno Příjmení', en: 'First Last', de: 'Vor Nachname' },
        role: { cs: 'Frontend & brand', en: 'Frontend & Brand', de: 'Frontend & Brand' },
        body: {
            cs: 'Web, identita, rozhraní. Tam, kde se klient poprvé setká s produktem.',
            en: 'Web, identity, interfaces. Where the client meets the product first.',
            de: 'Web, Identität, Oberflächen. Wo der Kunde das Produkt zuerst trifft.',
        },
        linkedin: null,
        location: '',
    },
    {
        initials: '07',
        name: { cs: 'Jméno Příjmení', en: 'First Last', de: 'Vor Nachname' },
        role: { cs: 'Data & reporting', en: 'Data & Reporting', de: 'Daten & Reporting' },
        body: {
            cs: 'Dashboardy, metriky, čísla, která rozhodují. Klient vidí výsledek, ne tabulku.',
            en: 'Dashboards, metrics, numbers that decide. Clients see the result, not the spreadsheet.',
            de: 'Dashboards, Metriken, Zahlen, die entscheiden. Kunden sehen das Ergebnis.',
        },
        linkedin: null,
        location: '',
    },
    {
        initials: '08',
        name: { cs: 'Jméno Příjmení', en: 'First Last', de: 'Vor Nachname' },
        role: { cs: 'Security & compliance', en: 'Security & Compliance', de: 'Security & Compliance' },
        body: {
            cs: 'Architektura v duchu ISO 27001, GDPR, šifrování. Bezpečnost není volitelná.',
            en: 'ISO 27001-style architecture, GDPR, encryption. Security is not optional.',
            de: 'ISO 27001-Architektur, DSGVO, Verschlüsselung. Sicherheit ist nicht optional.',
        },
        linkedin: null,
        location: '',
    },
    {
        initials: '09',
        name: { cs: 'Jméno Příjmení', en: 'First Last', de: 'Vor Nachname' },
        role: { cs: 'Client success', en: 'Client Success', de: 'Client Success' },
        body: {
            cs: 'Drží vztah s klientem po nasazení. Měsíční revize, ladění, další kroky.',
            en: 'Holds the client relationship after launch. Monthly reviews, tuning, next steps.',
            de: 'Hält die Kundenbeziehung nach dem Launch. Monatliche Reviews, Optimierung.',
        },
        linkedin: null,
        location: '',
    },
];

const t = copy[lang];
const isStrip = variant === 'strip';
---

<section class={`team ${isStrip ? 'team--strip' : 'team--full'}`}>
    <div class="container">
        <div class="team__head" data-reveal>
            <span class="eyebrow">{t.eyebrow}</span>
            <h2 class="team__heading">{t.heading}</h2>
            <p class="team__lead">{t.lead}</p>
        </div>

        <div class="team__grid" data-stagger>
            {members.map((m) => (
                <article class="member">
                    <div class="member__photo" aria-label={m.name[lang]}>
                        <div class="member__photo-placeholder">
                            <span class="member__photo-initials">{m.initials}</span>
                            <span class="member__photo-pending">{t.initialsLabel}</span>
                        </div>
                    </div>

                    <div class="member__body">
                        <span class="member__role">{m.role[lang]}</span>
                        <h3 class="member__name">
                            {m.linkedin ? (
                                <a href={m.linkedin} target="_blank" rel="noopener noreferrer">{m.name[lang]}</a>
                            ) : (
                                m.name[lang]
                            )}
                        </h3>
                        {m.location && <span class="member__location">{m.location}</span>}
                        <p class="member__text">{m.body[lang]}</p>
                    </div>
                </article>
            ))}
        </div>

        {isStrip && (
            <div class="team__cta-wrap">
                <a href={href} class="team__cta">{t.cta}</a>
            </div>
        )}
    </div>
</section>

<style>
    .team {
        background: var(--ivory-silver);
        padding: var(--space-20) 0;
        position: relative;
    }

    .team--full {
        padding: var(--space-24) 0;
    }

    .team__head {
        max-width: 60ch;
        margin-bottom: var(--space-12);
    }

    .team__head .eyebrow {
        color: var(--velocity-orange);
        display: block;
        margin-bottom: var(--space-4);
    }

    .team__heading {
        font-size: clamp(1.8rem, 3vw, 2.4rem);
        line-height: 1.2;
        letter-spacing: -0.02em;
        color: var(--velocity-black);
        margin: 0 0 var(--space-5);
        font-weight: 600;
    }

    .team__lead {
        font-size: 1.05rem;
        line-height: 1.65;
        color: var(--black-60);
        margin: 0;
        max-width: 58ch;
    }

    .team__grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: var(--space-8);
    }

    @media (max-width: 980px) {
        .team__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }

    @media (max-width: 620px) {
        .team__grid { grid-template-columns: 1fr; }
    }

    .member {
        background: var(--alpine-white);
        border: 1px solid var(--black-08);
        border-radius: var(--radius-lg);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition: transform 0.35s ease, box-shadow 0.35s ease, border-color 0.35s ease;
    }

    .member:hover {
        transform: translateY(-4px);
        box-shadow: 0 30px 60px -30px rgba(11, 15, 25, 0.25);
        border-color: rgba(232, 93, 31, 0.3);
    }

    .member__photo {
        position: relative;
        aspect-ratio: 4 / 5;
        background: linear-gradient(135deg, #3a2510 0%, #0B0F19 60%, #1E3A5F 100%);
        overflow: hidden;
    }

    .member__photo-placeholder {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: var(--ivory-silver);
        text-align: center;
        padding: var(--space-5);
    }

    .member__photo-initials {
        font-family: var(--font-sans);
        font-size: clamp(3rem, 6vw, 4.5rem);
        font-weight: 600;
        letter-spacing: -0.04em;
        color: var(--velocity-orange);
        line-height: 1;
    }

    .member__photo-pending {
        margin-top: var(--space-3);
        font-family: var(--font-mono);
        font-size: 0.65rem;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: rgba(245, 243, 238, 0.5);
    }

    .member__body {
        padding: var(--space-6);
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
    }

    .member__role {
        font-family: var(--font-mono);
        font-size: 0.72rem;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--signal-gold);
    }

    .member__name {
        font-size: 1.15rem;
        font-weight: 600;
        color: var(--velocity-black);
        margin: 0;
        letter-spacing: -0.01em;
    }

    .member__name a {
        color: inherit;
        border-bottom: 1px solid rgba(232, 93, 31, 0);
        transition: border-color 0.25s ease;
    }

    .member__name a:hover {
        border-color: var(--velocity-orange);
    }

    .member__location {
        font-size: 0.82rem;
        color: var(--mist-gray);
        font-style: italic;
    }

    .member__text {
        font-size: 0.95rem;
        line-height: 1.55;
        color: var(--black-60);
        margin: var(--space-2) 0 0;
    }

    .team__cta-wrap {
        margin-top: var(--space-10);
        display: flex;
        justify-content: flex-start;
    }

    .team__cta {
        color: var(--velocity-black);
        font-weight: 500;
        border-bottom: 1px solid rgba(232, 93, 31, 0.5);
        padding-bottom: 2px;
        transition: color 0.25s ease, border-color 0.25s ease;
    }

    .team__cta:hover {
        color: var(--velocity-orange);
        border-color: var(--velocity-orange);
    }
</style>
