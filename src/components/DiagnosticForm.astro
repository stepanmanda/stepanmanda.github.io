---
// DiagnosticForm — strukturovaný formulář pro sběr vstupů k diagnostice
// Submit: JS handler sestaví mailto URL s formátovaným tělem e-mailu
import { formStrings, type Lang } from '../i18n/ui';

interface Props {
    lang?: Lang;
}

const { lang = 'cs' } = Astro.props;
const f = formStrings[lang];
---

<form class="diag-form" id="diagnostikovat-form" data-lang={lang} novalidate>
    <div class="diag-form__group">
        <label class="diag-form__label" for="diag-name">{f.name}</label>
        <input type="text" id="diag-name" name="name" class="diag-form__input" required autocomplete="name" placeholder={f.namePh} />
    </div>

    <div class="diag-form__row">
        <div class="diag-form__group">
            <label class="diag-form__label" for="diag-position">{f.position}</label>
            <select id="diag-position" name="position" class="diag-form__input" required>
                <option value="" disabled selected>{f.select}</option>
                <option value="Owner">{f.positionOwner}</option>
                <option value="CEO">{f.positionCeo}</option>
                <option value="Manager">{f.positionManager}</option>
                <option value="IT">{f.positionIt}</option>
                <option value="Other">{f.positionOther}</option>
            </select>
        </div>

        <div class="diag-form__group">
            <label class="diag-form__label" for="diag-company">{f.company}</label>
            <input type="text" id="diag-company" name="company" class="diag-form__input" required autocomplete="organization" placeholder={f.companyPh} />
        </div>
    </div>

    <div class="diag-form__row">
        <div class="diag-form__group">
            <label class="diag-form__label" for="diag-industry">{f.industry}</label>
            <select id="diag-industry" name="industry" class="diag-form__input" required>
                <option value="" disabled selected>{f.select}</option>
                <option value="Healthcare">{f.indHealth}</option>
                <option value="Construction">{f.indConstr}</option>
                <option value="RealEstate">{f.indReal}</option>
                <option value="ProfessionalServices">{f.indProfServices}</option>
                <option value="Ecommerce">{f.indEcom}</option>
                <option value="Manufacturing">{f.indMfg}</option>
                <option value="Services">{f.indServices}</option>
                <option value="Other">{f.indOther}</option>
            </select>
        </div>

        <div class="diag-form__group">
            <label class="diag-form__label" for="diag-size">{f.size}</label>
            <select id="diag-size" name="size" class="diag-form__input" required>
                <option value="" disabled selected>{f.select}</option>
                <option value="1-10">{f.size10}</option>
                <option value="11-50">{f.size50}</option>
                <option value="51-200">{f.size200}</option>
                <option value="200+">{f.size200Plus}</option>
            </select>
        </div>
    </div>

    <hr class="diag-form__divider" />

    <div class="diag-form__group">
        <label class="diag-form__label" for="diag-pain">
            {f.pain}
            <span class="diag-form__hint">{f.painHint}</span>
        </label>
        <textarea id="diag-pain" name="pain" class="diag-form__input diag-form__input--area" rows="4" required placeholder={f.painPh}></textarea>
    </div>

    <div class="diag-form__row">
        <div class="diag-form__group">
            <label class="diag-form__label" for="diag-hours">{f.hours}</label>
            <select id="diag-hours" name="hours" class="diag-form__input">
                <option value="" disabled selected>{f.hoursUnknown}</option>
                <option value="<10h">{f.hours10}</option>
                <option value="10-30h">{f.hours30}</option>
                <option value="30-100h">{f.hours100}</option>
                <option value="100+h">{f.hours100Plus}</option>
            </select>
        </div>

        <div class="diag-form__group">
            <label class="diag-form__label" for="diag-priority">{f.priority}</label>
            <select id="diag-priority" name="priority" class="diag-form__input">
                <option value="" disabled selected>{f.select}</option>
                <option value="Critical">{f.priorityCrit}</option>
                <option value="High">{f.priorityHigh}</option>
                <option value="Medium">{f.priorityMid}</option>
                <option value="Exploring">{f.priorityExplore}</option>
            </select>
        </div>
    </div>

    <hr class="diag-form__divider" />

    <div class="diag-form__row">
        <div class="diag-form__group">
            <label class="diag-form__label" for="diag-email">{f.email}</label>
            <input type="email" id="diag-email" name="email" class="diag-form__input" required autocomplete="email" placeholder={f.emailPh} />
        </div>

        <div class="diag-form__group">
            <label class="diag-form__label" for="diag-phone">{f.phone} <span class="diag-form__optional">{f.optional}</span></label>
            <input type="tel" id="diag-phone" name="phone" class="diag-form__input" autocomplete="tel" placeholder={f.phonePh} />
        </div>
    </div>

    <div class="diag-form__group">
        <label class="diag-form__label" for="diag-when">{f.when} <span class="diag-form__optional">{f.optional}</span></label>
        <input type="text" id="diag-when" name="when" class="diag-form__input" placeholder={f.whenPh} />
    </div>

    <div class="diag-form__group diag-form__group--checkbox">
        <label class="diag-form__checkbox">
            <input type="checkbox" id="diag-gdpr" name="gdpr" required />
            <span>{f.gdpr}</span>
        </label>
    </div>

    <button type="submit" class="btn btn--primary btn-arrow btn--lg diag-form__submit">{f.submit}</button>

    <p class="diag-form__note">{f.submitNote}</p>
</form>

<style>
    .diag-form { display: flex; flex-direction: column; gap: var(--space-5); }
    .diag-form__group { display: flex; flex-direction: column; gap: 0.4rem; }
    .diag-form__row { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-4); }
    .diag-form__label {
        font-family: var(--font-mono);
        font-size: 0.72rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--black-90);
        font-weight: 500;
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 0.5rem;
    }
    .diag-form__hint {
        font-family: var(--font-serif);
        font-style: italic;
        font-size: 0.82rem;
        letter-spacing: 0;
        text-transform: none;
        color: var(--mist-gray);
        font-weight: 400;
    }
    .diag-form__optional {
        color: var(--mist-gray);
        font-weight: 400;
        letter-spacing: 0.04em;
    }
    .diag-form__input {
        width: 100%;
        padding: 0.85rem 1rem;
        font-family: var(--font-sans);
        font-size: 1rem;
        color: var(--velocity-black);
        background: var(--alpine-white);
        border: 1px solid var(--black-15);
        border-radius: var(--radius);
        transition: border-color 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
        appearance: none;
        -webkit-appearance: none;
    }
    .diag-form__input:hover { border-color: var(--black-40); }
    .diag-form__input:focus {
        outline: none;
        border-color: var(--velocity-orange);
        box-shadow: 0 0 0 3px rgba(232, 93, 31, 0.12);
    }
    .diag-form__input::placeholder {
        color: var(--mist-gray);
        font-style: italic;
    }
    .diag-form__input--area {
        min-height: 120px;
        resize: vertical;
        font-family: var(--font-sans);
        line-height: 1.5;
    }
    select.diag-form__input {
        background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='12' height='8' viewBox='0 0 12 8'><path d='M1 1l5 5 5-5' fill='none' stroke='%230B0F19' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/></svg>");
        background-repeat: no-repeat;
        background-position: right 1rem center;
        padding-right: 2.5rem;
        cursor: pointer;
    }
    .diag-form__divider {
        border: 0;
        height: 1px;
        background: linear-gradient(to right, transparent, var(--gold-30) 20%, var(--gold-30) 80%, transparent);
        margin: var(--space-3) 0;
    }
    .diag-form__group--checkbox { margin-top: var(--space-2); }
    .diag-form__checkbox {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 0.75rem;
        align-items: start;
        cursor: pointer;
        font-size: 0.9rem;
        color: var(--black-60);
        line-height: 1.5;
    }
    .diag-form__checkbox input[type="checkbox"] {
        width: 18px;
        height: 18px;
        margin-top: 2px;
        accent-color: var(--velocity-orange);
        cursor: pointer;
    }
    .diag-form__submit {
        margin-top: var(--space-3);
        align-self: flex-start;
    }
    .diag-form__note {
        font-family: var(--font-serif);
        font-style: italic;
        font-size: 0.9rem;
        color: var(--mist-gray);
        margin: 0;
        line-height: 1.55;
    }
    .diag-form.is-submitted { opacity: 0.5; pointer-events: none; }
    .diag-form__input:invalid:not(:placeholder-shown):not(:focus) {
        border-color: rgba(232, 93, 31, 0.5);
    }
    @media (max-width: 720px) {
        .diag-form__row { grid-template-columns: 1fr; }
    }
</style>

<script is:inline>
    (function () {
        const form = document.getElementById('diagnostikovat-form');
        if (!form) return;

        const lang = form.getAttribute('data-lang') || 'cs';

        // Lokalizované labels pro e-mail body podle jazyka
        const LABELS = {
            cs: {
                title: 'VELYOS — diagnostika přes web',
                contact: 'KONTAKT',
                name: 'Jméno', email: 'E-mail', phone: 'Telefon', when: 'Zastihnout',
                firm: 'FIRMA',
                company: 'Název', position: 'Pozice', industry: 'Obor', size: 'Velikost',
                diag: 'DIAGNOSTIKA',
                hours: 'Ztracený čas týdně', priority: 'Priorita',
                says: 'CO ŘEŠÍ (vlastní slova)',
                sentFrom: 'Odesláno z velyos.ai · ',
                notSet: 'neuvedeno',
                empty: '—',
                alertGdpr: 'Prosím potvrďte souhlas se zpracováním údajů.',
                subject: 'Diagnostika — ',
                subjectFallback: 'nová poptávka',
                locale: 'cs-CZ',
            },
            en: {
                title: 'VELYOS — diagnostic from web',
                contact: 'CONTACT',
                name: 'Name', email: 'Email', phone: 'Phone', when: 'Reach at',
                firm: 'COMPANY',
                company: 'Name', position: 'Position', industry: 'Industry', size: 'Size',
                diag: 'DIAGNOSTIC',
                hours: 'Time lost per week', priority: 'Priority',
                says: 'WHAT THEY FACE (own words)',
                sentFrom: 'Sent from velyos.ai · ',
                notSet: 'not provided',
                empty: '—',
                alertGdpr: 'Please confirm consent to data processing.',
                subject: 'Diagnostic — ',
                subjectFallback: 'new inquiry',
                locale: 'en-US',
            },
            de: {
                title: 'VELYOS — Diagnose übers Web',
                contact: 'KONTAKT',
                name: 'Name', email: 'E-Mail', phone: 'Telefon', when: 'Erreichbar',
                firm: 'UNTERNEHMEN',
                company: 'Name', position: 'Position', industry: 'Branche', size: 'Größe',
                diag: 'DIAGNOSE',
                hours: 'Zeitverlust pro Woche', priority: 'Priorität',
                says: 'WAS SIE BESCHÄFTIGT (eigene Worte)',
                sentFrom: 'Gesendet von velyos.ai · ',
                notSet: 'nicht angegeben',
                empty: '—',
                alertGdpr: 'Bitte bestätigen Sie die Einwilligung zur Datenverarbeitung.',
                subject: 'Diagnose — ',
                subjectFallback: 'neue Anfrage',
                locale: 'de-DE',
            },
        };
        const L = LABELS[lang] || LABELS.cs;

        form.addEventListener('submit', (e) => {
            e.preventDefault();

            const data = new FormData(form);
            const pick = (k) => (data.get(k) || '').toString().trim();

            if (!pick('gdpr')) {
                alert(L.alertGdpr);
                return;
            }

            const lines = [
                L.title,
                '═══════════════════════════',
                '',
                L.contact,
                '  ' + L.name + ':    ' + pick('name'),
                '  ' + L.email + ':   ' + pick('email'),
                '  ' + L.phone + ':   ' + (pick('phone') || L.empty),
                '  ' + L.when + ':    ' + (pick('when') || L.empty),
                '',
                L.firm,
                '  ' + L.company + ':  ' + pick('company'),
                '  ' + L.position + ': ' + pick('position'),
                '  ' + L.industry + ': ' + pick('industry'),
                '  ' + L.size + ':     ' + pick('size'),
                '',
                L.diag,
                '  ' + L.hours + ': ' + (pick('hours') || L.notSet),
                '  ' + L.priority + ':    ' + (pick('priority') || L.notSet),
                '',
                L.says,
                '  ' + pick('pain').split('\n').join('\n  '),
                '',
                '───────────────────────────',
                L.sentFrom + new Date().toLocaleString(L.locale),
            ];

            const subject = L.subject + (pick('company') || pick('name') || L.subjectFallback);
            const body = lines.join('\n');
            const mailto = 'mailto:stepan@velyos.ai?subject=' + encodeURIComponent(subject) + '&body=' + encodeURIComponent(body);

            window.location.href = mailto;
            form.classList.add('is-submitted');
            setTimeout(() => form.classList.remove('is-submitted'), 4000);
        });
    })();
</script>
