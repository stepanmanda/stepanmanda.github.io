---
// DiagnosticForm — strukturovaný formulář pro sběr vstupů k diagnostice
// Submit: JS handler sestaví mailto URL s formátovaným tělem e-mailu
---

<form class="diag-form" id="diagnostikovat-form" novalidate>
    <div class="diag-form__group">
        <label class="diag-form__label" for="diag-name">Jméno a příjmení</label>
        <input type="text" id="diag-name" name="name" class="diag-form__input" required autocomplete="name" placeholder="Štěpán Novák" />
    </div>

    <div class="diag-form__row">
        <div class="diag-form__group">
            <label class="diag-form__label" for="diag-position">Pozice ve firmě</label>
            <select id="diag-position" name="position" class="diag-form__input" required>
                <option value="" disabled selected>— vyberte —</option>
                <option value="Majitel">Majitel / jednatel</option>
                <option value="Ředitel">Ředitel / CEO</option>
                <option value="Manažer">Manažer / vedoucí</option>
                <option value="IT / provoz">IT / provoz</option>
                <option value="Jiné">Jiné</option>
            </select>
        </div>

        <div class="diag-form__group">
            <label class="diag-form__label" for="diag-company">Firma</label>
            <input type="text" id="diag-company" name="company" class="diag-form__input" required autocomplete="organization" placeholder="VELYOS s.r.o." />
        </div>
    </div>

    <div class="diag-form__row">
        <div class="diag-form__group">
            <label class="diag-form__label" for="diag-industry">Obor</label>
            <select id="diag-industry" name="industry" class="diag-form__input" required>
                <option value="" disabled selected>— vyberte —</option>
                <option value="Zdravotnictví">Zdravotnictví</option>
                <option value="Stavebnictví">Stavebnictví</option>
                <option value="Reality">Reality</option>
                <option value="Profesionální služby">Profesionální služby (právo, poradenství, účetnictví)</option>
                <option value="E-commerce">E-commerce / retail</option>
                <option value="Výroba">Výroba</option>
                <option value="Služby">Služby (B2C)</option>
                <option value="Jiné">Jiné</option>
            </select>
        </div>

        <div class="diag-form__group">
            <label class="diag-form__label" for="diag-size">Velikost týmu</label>
            <select id="diag-size" name="size" class="diag-form__input" required>
                <option value="" disabled selected>— vyberte —</option>
                <option value="1–10">1–10 lidí</option>
                <option value="11–50">11–50 lidí</option>
                <option value="51–200">51–200 lidí</option>
                <option value="200+">200+ lidí</option>
            </select>
        </div>
    </div>

    <hr class="diag-form__divider" />

    <div class="diag-form__group">
        <label class="diag-form__label" for="diag-pain">
            Kde vám utíká nejvíc času?
            <span class="diag-form__hint">Krátký popis — administrativa, dokumentace, propočty, komunikace…</span>
        </label>
        <textarea id="diag-pain" name="pain" class="diag-form__input diag-form__input--area" rows="4" required placeholder="Např. Obchodníci tráví denně 3–4 hodiny přípravou nabídek, než se dostanou k novému klientovi."></textarea>
    </div>

    <div class="diag-form__row">
        <div class="diag-form__group">
            <label class="diag-form__label" for="diag-hours">Odhad ztraceného času týdně</label>
            <select id="diag-hours" name="hours" class="diag-form__input">
                <option value="" disabled selected>— nevím —</option>
                <option value="do 10 h">Do 10 hodin týdně</option>
                <option value="10–30 h">10–30 hodin týdně</option>
                <option value="30–100 h">30–100 hodin týdně</option>
                <option value="100+ h">Přes 100 hodin týdně</option>
            </select>
        </div>

        <div class="diag-form__group">
            <label class="diag-form__label" for="diag-priority">Priorita řešení</label>
            <select id="diag-priority" name="priority" class="diag-form__input">
                <option value="" disabled selected>— vyberte —</option>
                <option value="Kritická">Kritická — potřebujeme teď</option>
                <option value="Vysoká">Vysoká — do 3 měsíců</option>
                <option value="Střední">Střední — letos</option>
                <option value="Zjišťujeme">Zatím zjišťujeme</option>
            </select>
        </div>
    </div>

    <hr class="diag-form__divider" />

    <div class="diag-form__row">
        <div class="diag-form__group">
            <label class="diag-form__label" for="diag-email">E-mail</label>
            <input type="email" id="diag-email" name="email" class="diag-form__input" required autocomplete="email" placeholder="vy@firma.cz" />
        </div>

        <div class="diag-form__group">
            <label class="diag-form__label" for="diag-phone">Telefon <span class="diag-form__optional">(nepovinné)</span></label>
            <input type="tel" id="diag-phone" name="phone" class="diag-form__input" autocomplete="tel" placeholder="+420 777 777 777" />
        </div>
    </div>

    <div class="diag-form__group">
        <label class="diag-form__label" for="diag-when">Kdy vás máme zastihnout? <span class="diag-form__optional">(nepovinné)</span></label>
        <input type="text" id="diag-when" name="when" class="diag-form__input" placeholder="Např. zítra dopoledne, nebo kdykoliv po 16:00" />
    </div>

    <div class="diag-form__group diag-form__group--checkbox">
        <label class="diag-form__checkbox">
            <input type="checkbox" id="diag-gdpr" name="gdpr" required />
            <span>
                Souhlasím se zpracováním poskytnutých údajů pro účely diagnostiky a kontaktu ze strany VELYOS.
                Data nikde nesdílíme, neprodáváme, ani nepoužíváme k tréninku cizích modelů.
            </span>
        </label>
    </div>

    <button type="submit" class="btn btn--primary btn-arrow btn--lg diag-form__submit">Odeslat diagnostiku</button>

    <p class="diag-form__note">
        Po odeslání dostanete do 24 hodin odpověď od specialisty.
        Pokud chcete rychleji, rovnou si promluvte s agentem →
    </p>
</form>

<style>
    .diag-form {
        display: flex;
        flex-direction: column;
        gap: var(--space-5);
    }

    .diag-form__group {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
    }

    .diag-form__row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--space-4);
    }

    .diag-form__label {
        font-family: var(--font-mono);
        font-size: 0.72rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--black-90);
        font-weight: 500;
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 0.5rem;
    }

    .diag-form__hint {
        font-family: var(--font-serif);
        font-style: italic;
        font-size: 0.82rem;
        letter-spacing: 0;
        text-transform: none;
        color: var(--mist-gray);
        font-weight: 400;
    }

    .diag-form__optional {
        color: var(--mist-gray);
        font-weight: 400;
        letter-spacing: 0.04em;
    }

    .diag-form__input {
        width: 100%;
        padding: 0.85rem 1rem;
        font-family: var(--font-sans);
        font-size: 1rem;
        color: var(--velocity-black);
        background: var(--alpine-white);
        border: 1px solid var(--black-15);
        border-radius: var(--radius);
        transition: border-color 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
        appearance: none;
        -webkit-appearance: none;
    }

    .diag-form__input:hover {
        border-color: var(--black-40);
    }

    .diag-form__input:focus {
        outline: none;
        border-color: var(--velocity-orange);
        box-shadow: 0 0 0 3px rgba(232, 93, 31, 0.12);
    }

    .diag-form__input::placeholder {
        color: var(--mist-gray);
        font-style: italic;
    }

    .diag-form__input--area {
        min-height: 120px;
        resize: vertical;
        font-family: var(--font-sans);
        line-height: 1.5;
    }

    select.diag-form__input {
        background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='12' height='8' viewBox='0 0 12 8'><path d='M1 1l5 5 5-5' fill='none' stroke='%230B0F19' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/></svg>");
        background-repeat: no-repeat;
        background-position: right 1rem center;
        padding-right: 2.5rem;
        cursor: pointer;
    }

    .diag-form__divider {
        border: 0;
        height: 1px;
        background: linear-gradient(to right, transparent, var(--gold-30) 20%, var(--gold-30) 80%, transparent);
        margin: var(--space-3) 0;
    }

    .diag-form__group--checkbox {
        margin-top: var(--space-2);
    }

    .diag-form__checkbox {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 0.75rem;
        align-items: start;
        cursor: pointer;
        font-size: 0.9rem;
        color: var(--black-60);
        line-height: 1.5;
    }

    .diag-form__checkbox input[type="checkbox"] {
        width: 18px;
        height: 18px;
        margin-top: 2px;
        accent-color: var(--velocity-orange);
        cursor: pointer;
    }

    .diag-form__submit {
        margin-top: var(--space-3);
        align-self: flex-start;
    }

    .diag-form__note {
        font-family: var(--font-serif);
        font-style: italic;
        font-size: 0.9rem;
        color: var(--mist-gray);
        margin: 0;
        line-height: 1.55;
    }

    /* Success / error states */
    .diag-form.is-submitted {
        opacity: 0.5;
        pointer-events: none;
    }

    .diag-form__input:invalid:not(:placeholder-shown):not(:focus) {
        border-color: rgba(232, 93, 31, 0.5);
    }

    @media (max-width: 720px) {
        .diag-form__row {
            grid-template-columns: 1fr;
        }
    }
</style>

<script is:inline>
    (function () {
        const form = document.getElementById('diagnostikovat-form');
        if (!form) return;

        form.addEventListener('submit', (e) => {
            e.preventDefault();

            const data = new FormData(form);
            const pick = (k) => (data.get(k) || '').toString().trim();

            if (!pick('gdpr')) {
                alert('Prosím potvrďte souhlas se zpracováním údajů.');
                return;
            }

            const lines = [
                'VELYOS — diagnostika přes web',
                '═══════════════════════════',
                '',
                'KONTAKT',
                '  Jméno:   ' + pick('name'),
                '  E-mail:  ' + pick('email'),
                '  Telefon: ' + (pick('phone') || '—'),
                '  Zastihnout: ' + (pick('when') || '—'),
                '',
                'FIRMA',
                '  Název:    ' + pick('company'),
                '  Pozice:   ' + pick('position'),
                '  Obor:     ' + pick('industry'),
                '  Velikost: ' + pick('size'),
                '',
                'DIAGNOSTIKA',
                '  Ztracený čas týdně: ' + (pick('hours') || 'neuvedeno'),
                '  Priorita:           ' + (pick('priority') || 'neuvedeno'),
                '',
                'CO ŘEŠÍ (vlastní slova)',
                '  ' + pick('pain').split('\n').join('\n  '),
                '',
                '───────────────────────────',
                'Odesláno z velyos.ai · ' + new Date().toLocaleString('cs-CZ'),
            ];

            const subject = 'Diagnostika — ' + (pick('company') || pick('name') || 'nová poptávka');
            const body = lines.join('\n');

            const mailto = 'mailto:stepan@velyos.ai'
                + '?subject=' + encodeURIComponent(subject)
                + '&body=' + encodeURIComponent(body);

            // Otevře e-mailový klient uživatele s pre-filled body.
            window.location.href = mailto;

            form.classList.add('is-submitted');

            setTimeout(() => {
                form.classList.remove('is-submitted');
            }, 4000);
        });
    })();
</script>
